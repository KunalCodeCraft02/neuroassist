# ============================================
# 🛡️ NEUROASSIST SAAS - ENVIRONMENT VARIABLES
# ============================================

# NODE ENVIRONMENT
NODE_ENVIRONMENT=production

# DATABASE
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/neuroassist?retryWrites=true&w=majority

# JWT AUTH (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-long-random-secret-key-minimum-64-characters-change-this-in-production
JWT_EXPIRES_IN=7d

# SESSION SECRET (separate from JWT, generate with: openssl rand -base64 64)
SESSION_SECRET=another-very-long-random-secret-minimum-64-chars-change-this-or-use-openssl

# ADMIN CONFIGURATION
# IMPORTANT: Do not use defaults. Set these in .env (not committed to git)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=SuperStrongAdminPassword123!ChangeThis
# After setting these, run: npm run create-admin
ALLOWED_ADMIN_IPS=123.456.789.0,98.765.432.1 # Optional: comma-separated whitelist

# CORS - Allowed origins for API (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com

# EMBED TOKEN SECRET (for bot script authentication)
EMBED_SECRET=another-very-long-random-secret-minimum-64-chars-use-different-from-jwt

# CLOUD STORAGE (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# EXTERNAL API KEYS
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key # if using Gemini
VAPI_API_KEY=your-vapi-api-key # for voice agents

# RAZORPAY (Payment Gateway)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# EMAIL SERVICE (Choose ONE or configure multiple for fallback)
# ============================================
# Recommended for Render (HTTP API, no SMTP blocking):
#
# Option 1: SendGrid (RECOMMENDED) - Most reliable on Render
# Get API key from: https://app.sendgrid.com/settings/api-keys
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
#
# Option 2: Resend - Modern, excellent deliverability
# Get API key from: https://resend.com/api-keys
# RESEND_API_KEY=your-resend-api-key-here
#
# Option 3: Brevo (Sendinblue) - Backup option
# Get API key from: https://app.brevo.com/settings/keys
# BREVO_API_KEY=your-brevo-api-key-here
# (or: BREVO_API=your-brevo-api-key-here)
#
# Option 4: SMTP - Last resort (may be blocked on some platforms)
# EMAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
#
# OPTIONAL: Customize sender details (works with all providers):
# SENDER_EMAIL=noreply@yourdomain.com
# SENDER_NAME=NeuroAssist AI

# WHATSAPP SERVICE (e.g., Twilio, Meta WhatsApp)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# VAPI WEBHOOK (for voice agents)
VAPI_WEBHOOK_BASE_URL=https://yourapp.onrender.com
VAPI_API_KEY=your-vapi-api-key

# LOGGING (optional)
LOG_LEVEL=info
LOG_TO_FILE=true

# ============================================
# 🚀 DEPLOYMENT NOTES (RENDER)
# ============================================
# 1. Change all default passwords and secrets
# 2. Use long random strings for all secrets (min 64 chars for session/jwt, 32+ for others)
# 3. Set NODE_ENVIRONMENT=production in production (Render sets this automatically)
# 4. Configure ALLOWED_ORIGINS to include your Render URL (e.g., https://yourapp.onrender.com)
# 5. MONGODB_URI: Must whitelist Render IPs in MongoDB Atlas or use 0.0.0.0/0 for testing
#    - Render's outbound IPs vary; easiest is to allow all (0.0.0.0/0) temporarily for testing
# 6. Add your actual admin email for 2FA
# 7. Set ALLOWED_ADMIN_IPS if you want IP whitelisting for admin panel (not needed typically)
# 8. Ensure all API keys are valid and have appropriate limits
# 9. IMPORTANT: The location fetch on signup uses OpenStreetMap API - ensure CSP allows it
#    (code already fixed to include https://nominatim.openstreetmap.org)
# 10. ⚠️  EMAIL SERVICE (REQUIRED for OTP): Configure AT LEAST ONE provider:
#     - SENDGRID_API_KEY (RECOMMENDED for Render) - https://app.sendgrid.com/settings/api-keys
#     - RESEND_API_KEY (excellent alternative) - https://resend.com/api-keys
#     - BREVO_API_KEY - https://app.brevo.com/settings/keys
#     - OR SMTP credentials (SMTP_HOST, SMTP_USER, SMTP_PASS)
#     ✓ OTP verification will NOT work without email service!
# 11. 📧 SENDER CONFIGURATION (important for deliverability):
#     - SENDER_EMAIL: Verified email address (your domain or Brevo/SendGrid verified)
#     - SENDER_NAME: Display name (e.g., "NeuroAssist AI")
#     Note: For Brevo, sender email must be verified in Brevo dashboard.
#           For SendGrid, you need to verify sender identity in SendGrid.
#           For Resend, domain verification is recommended for production.
# ============================================
