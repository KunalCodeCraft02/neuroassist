<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Admin Login</title>
  <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
 <style>
  :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;
    --accent3:#4f8ef7;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;
    --yellow:#f59e0b;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:30px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    box-sizing:border-box;
    margin:0;
    padding:0;
}

html{
    scroll-behavior:smooth;
    overflow-x:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow-x:hidden;
    min-height:100vh;
    width:100%;

    display:flex;
    align-items:center;
    justify-content:center;

    position:relative;

    cursor:none;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.16),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur,
#cur-ring{
    display:none;
}

@media(pointer:fine){

    #cur,
    #cur-ring{
        display:block;
        position:fixed;
        z-index:99999;
    }

    #cur{
        width:8px;
        height:8px;

        background:var(--accent);

        border-radius:50%;

        transform:translate(-50%,-50%);

        transition:
            width .25s,
            height .25s,
            background .25s;

        mix-blend-mode:screen;

        pointer-events:none;
    }

    #cur-ring{
        width:34px;
        height:34px;

        border:1px solid rgba(124,106,247,.4);

        border-radius:50%;

        transform:translate(-50%,-50%);

        pointer-events:none;

        z-index:99998;
    }

    body:has(a:hover) #cur,
    body:has(button:hover) #cur,
    body:has(input:hover) #cur{
        width:16px;
        height:16px;

        background:var(--accent2);
    }
}

/* NOISE */

body .noise{
    position:fixed;
    inset:0;

    opacity:.04;

    pointer-events:none;

    z-index:1;

    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ORBS */

.orb{
    position:fixed;

    border-radius:50%;

    pointer-events:none;

    z-index:0;
}

.orb-1{
    top:-180px;
    right:-120px;

    width:520px;
    height:520px;

    background:
        radial-gradient(circle,
        rgba(124,106,247,.16),
        transparent 70%);

    animation:floatA 12s ease-in-out infinite alternate;
}

.orb-2{
    bottom:-100px;
    left:-100px;

    width:420px;
    height:420px;

    background:
        radial-gradient(circle,
        rgba(91,240,192,.08),
        transparent 70%);

    animation:floatB 14s ease-in-out infinite alternate;
}

@keyframes floatA{
    from{
        transform:translate(0,0);
    }

    to{
        transform:translate(-30px,30px) scale(1.08);
    }
}

@keyframes floatB{
    from{
        transform:translate(0,0);
    }

    to{
        transform:translate(24px,-24px) scale(1.04);
    }
}

/* CONTAINER */

.login-container,
.verify-container{
    position:relative;
    z-index:2;

    width:100%;
    max-width:460px;

    padding:20px;
}

/* CARD */

.login-card,
.verify-card{
    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:36px;

    padding:48px 36px;

    position:relative;
    overflow:hidden;

    box-shadow:
        0 20px 80px rgba(124,106,247,.08);

    animation:fadeUp .8s ease both;
}

.login-card::before,
.verify-card::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );
}

@keyframes fadeUp{
    from{
        transform:translateY(24px);
        opacity:0;
    }

    to{
        transform:translateY(0);
        opacity:1;
    }
}

/* HEADER */

.login-header,
.verify-header{
    text-align:center;

    margin-bottom:34px;
}

/* LOGO */

.login-logo,
.verify-logo{
    display:flex;
    align-items:baseline;
    justify-content:center;

    gap:4px;

    margin-bottom:18px;
}

.login-logo h3,
.verify-logo h3{
    font-size:24px;

    font-weight:700;

    letter-spacing:-.03em;
}

.login-logo h3:nth-child(2),
.verify-logo h3:nth-child(2){
    color:var(--accent);
}

.login-logo h3:nth-child(3),
.verify-logo h3:nth-child(3){
    color:var(--text2);

    font-size:14px;
}

/* TITLES */

.login-title,
.verify-title{
    font-family:var(--font-display);

    font-size:clamp(46px,7vw,74px);

    line-height:.9;

    letter-spacing:-.05em;

    font-weight:400;

    margin-bottom:12px;
}

.login-subtitle,
.verify-subtitle{
    color:var(--text2);

    font-size:15px;

    line-height:1.8;
}

/* INFO BOX */

.verify-info{
    background:rgba(91,240,192,.06);

    border:1px solid rgba(91,240,192,.12);

    border-radius:20px;

    padding:18px;

    color:var(--text2);

    line-height:1.8;

    font-size:14px;

    margin-bottom:24px;
}

.verify-info i{
    color:var(--accent2);

    margin-right:8px;
}

/* FORM */

.form-group{
    margin-bottom:22px;
}

label{
    display:block;

    margin-bottom:10px;

    color:var(--text2);

    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);
}

/* INPUT */

input{
    width:100%;

    padding:16px 18px;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:18px;

    color:var(--text);

    font-size:14px;

    font-family:var(--font-sans);

    transition:.3s;

    outline:none;

    cursor:none;
}

input:focus{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

input::placeholder{
    color:var(--muted);
}

/* OTP */

#otp{
    text-align:center;

    letter-spacing:10px;

    font-size:28px;

    font-family:var(--font-mono);
}

/* BUTTON */

.btn-login,
.btn-verify{
    width:100%;

    margin-top:10px;

    padding:18px;

    border:none;

    border-radius:20px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:none;

    transition:.35s;

    position:relative;
    overflow:hidden;

    box-shadow:
        0 10px 30px rgba(124,106,247,.25);
}

.btn-login span,
.btn-verify span{
    position:relative;
    z-index:1;
}

.btn-login::before,
.btn-verify::before{
    content:'';

    position:absolute;
    inset:0;

    background:
        linear-gradient(
            135deg,
            var(--accent2),
            var(--accent)
        );

    opacity:0;

    transition:.35s;
}

.btn-login:hover::before,
.btn-verify:hover::before{
    opacity:1;
}

.btn-login:hover,
.btn-verify:hover{
    transform:translateY(-4px);

    box-shadow:
        0 18px 40px rgba(124,106,247,.32);
}

/* ALERTS */

.error-message,
.success-message{
    padding:14px 16px;

    border-radius:18px;

    font-size:13px;

    margin-bottom:20px;

    line-height:1.7;
}

.error-message{
    background:rgba(239,68,68,.08);

    border:1px solid rgba(239,68,68,.18);

    color:var(--red);
}

.success-message{
    background:rgba(16,185,129,.08);

    border:1px solid rgba(16,185,129,.16);

    color:var(--green);
}

/* LINKS */

.back-link,
.resend-link{
    display:block;

    text-align:center;

    margin-top:18px;

    color:var(--text2);

    text-decoration:none;

    font-size:13px;

    transition:.3s;
}

.back-link:hover,
.resend-link:hover{
    color:var(--accent);
}

/* TIMER */

.timer{
    text-align:center;

    margin-top:12px;

    color:var(--muted);

    font-size:12px;
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none !important;
    }

    .login-card,
    .verify-card{
        padding:36px 24px;

        border-radius:30px;
    }

    .login-title,
    .verify-title{
        font-size:58px;
    }

    #otp{
        font-size:22px;

        letter-spacing:6px;
    }
}
 </style>
</head>

<body>
  <div id="cur"></div>
  <div id="cur-ring"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="login-container">
    <div class="login-card">
      <div class="login-header">
        <div class="login-logo">
          <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
        </div>
        <h2 class="login-title">Admin Access</h2>
        <p class="login-subtitle">Sign in to manage the platform</p>
      </div>

      <% if(error) { %>
        <div class="error-message">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/<%= ADMIN_PATH %>/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="Enter admin username" required autocomplete="off">
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Enter admin password" required autocomplete="off">
        </div>

        <button type="submit" class="btn-login">
          <span>Sign In</span>
        </button>
      </form>

      <a href="/home" class="back-link">← Back to Home</a>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

  <script>
    // Custom cursor
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
      });

      (function ani() {
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(ani);
      })();
    }

    // Form submission feedback
    const form = document.querySelector('form');
    const btn = document.querySelector('.btn-login');

    form.addEventListener('submit', (e) => {
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span>Signing in...</span>';
      btn.style.pointerEvents = 'none';
    });

    // Reveal animation
    const card = document.querySelector('.login-card');
    card.style.opacity = '0';
    card.style.transform = 'translateY(20px)';

    setTimeout(() => {
      card.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }, 100);
  </script>
</body>

</html>