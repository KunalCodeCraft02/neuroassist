<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Admin 2FA</title>
  <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #04040a;
      --surface: #09090f;
      --surface2: #0e0e18;
      --accent: #ff7518;
      --accent-glow: rgba(255, 117, 24, 0.2);
      --text: #eeeef5;
      --muted: #5a5a78;
      --border: rgba(255, 255, 255, 0.07);
      --radius: 16px;
    }

    html {
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
      min-height: 100vh;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: none;
    }

    /* Custom Cursor - hide on mobile */
    #cur,
    #cur-ring {
      display: none;
    }

    @media (pointer: fine) {
      #cur,
      #cur-ring {
        display: block;
        position: fixed;
        z-index: 99999;
      }

      #cur {
        width: 10px;
        height: 10px;
        background: var(--accent);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.3s, height 0.3s;
        mix-blend-mode: difference;
        pointer-events: none;
      }

      #cur-ring {
        width: 38px;
        height: 38px;
        border: 1px solid rgba(255, 117, 24, .35);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: transform 0.13s ease-out;
        pointer-events: none;
        z-index: 99998;
      }

      body:has(a:hover) #cur,
      body:has(button:hover) #cur,
      body:has(input:hover) #cur {
        width: 18px;
        height: 18px;
      }
    }

    /* Background Grid */
    .bg-grid {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 117, 24, .03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 117, 24, .03) 1px, transparent 1px);
      background-size: 72px 72px;
      animation: gridScroll 20s linear infinite;
      pointer-events: none;
      z-index: 0;
    }

    @keyframes gridScroll {
      from { transform: translate(0, 0); }
      to { transform: translate(72px, 72px); }
    }

    /* Orbs */
    .orb {
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }

    .orb-1 {
      top: -100px;
      right: -80px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(255, 117, 24, 0.1) 0%, transparent 70%);
      animation: orbA 12s ease-in-out infinite alternate;
    }

    .orb-2 {
      bottom: -60px;
      left: -60px;
      width: 250px;
      height: 250px;
      background: radial-gradient(circle, rgba(79, 142, 247, 0.08) 0%, transparent 70%);
      animation: orbB 14s ease-in-out infinite alternate;
    }

    @media (min-width: 768px) {
      .orb-1 {
        top: -150px;
        right: -120px;
        width: 450px;
        height: 450px;
      }
      .orb-2 {
        bottom: -80px;
        left: -80px;
        width: 350px;
        height: 350px;
      }
    }

    @keyframes orbA {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(-30px, 30px) scale(1.1); }
    }

    @keyframes orbB {
      0% { transform: translate(0, 0); }
      100% { transform: translate(20px, -20px) scale(1.05); }
    }

    /* 2FA Container */
    .verify-container {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 400px;
      padding: 20px;
    }

    .verify-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 40px;
      position: relative;
      overflow: hidden;
      animation: fadeUp 0.8s ease both;
    }

    .verify-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent) 0%, #ff8c3d 100%);
    }

    @keyframes fadeUp {
      from {
        transform: translateY(20px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .verify-header {
      text-align: center;
      margin-bottom: 32px;
    }

    .verify-logo {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 6px;
      margin-bottom: 8px;
    }

    .verify-logo h1 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 24px;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .verify-logo h1:nth-child(2) {
      color: var(--accent);
    }

    .verify-logo h1:nth-child(3) {
      color: var(--muted);
      font-weight: 600;
      font-size: 14px;
    }

    .verify-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 28px;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .verify-subtitle {
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .verify-info {
      background: rgba(255, 117, 24, 0.1);
      border: 1px solid var(--accent);
      color: var(--text);
      padding: 16px;
      border-radius: 10px;
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 24px;
    }

    .verify-info i {
      color: var(--accent);
      margin-right: 6px;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      margin-bottom: 8px;
      letter-spacing: 0.02em;
    }

    input {
      width: 100%;
      padding: 14px 16px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      font-size: 14px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      transition: all 0.3s ease;
      cursor: none;
      text-align: center;
      letter-spacing: 8px;
      font-size: 24px;
    }

    input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    input::placeholder {
      color: var(--muted);
      opacity: 0.5;
      letter-spacing: normal;
      font-size: 14px;
    }

    .btn-verify {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--accent) 0%, #ff8c3d 100%);
      color: #04040a;
      border: none;
      border-radius: 10px;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: none;
      transition: all 0.3s ease;
      margin-top: 8px;
      position: relative;
      overflow: hidden;
    }

    .btn-verify::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #fff;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s ease;
    }

    .btn-verify:hover::before {
      transform: scaleX(1);
    }

    .btn-verify span {
      position: relative;
      z-index: 1;
    }

    .btn-verify:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(255, 117, 24, 0.3);
    }

    .error-message {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid #ef4444;
      color: #ef4444;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 20px;
      animation: fadeUp 0.5s ease both;
    }

    .success-message {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid #10b981;
      color: #10b981;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 20px;
    }

    .resend-link {
      display: block;
      text-align: center;
      margin-top: 16px;
      color: var(--muted);
      text-decoration: none;
      font-size: 13px;
      cursor: pointer;
      transition: color 0.3s;
    }

    .resend-link:hover {
      color: var(--accent);
    }

    .timer {
      text-align: center;
      font-size: 13px;
      color: var(--muted);
      margin-top: 8px;
    }

    @media (max-width: 768px) {
      .verify-container {
        padding: 15px;
      }

      .verify-card {
        padding: 30px 24px;
      }

      .verify-title {
        font-size: 24px;
      }

      input {
        letter-spacing: 4px;
        font-size: 20px;
      }
    }
  </style>
</head>

<body>
  <div id="cur"></div>
  <div id="cur-ring"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="verify-container">
    <div class="verify-card">
      <div class="verify-header">
        <div class="verify-logo">
          <h1>Neuro</h1>
          <h1>Assist</h1>
          <h1>Co</h1>
        </div>
        <h2 class="verify-title">Two-Factor Authentication</h2>
        <p class="verify-subtitle">Enter the 6-digit code sent to your email</p>
      </div>

      <% if (error) { %>
        <div class="error-message">
          <%= error %>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="success-message">
          <%= success %>
        </div>
      <% } %>

      <div class="verify-info">
        <i class="ri-shield-check-line"></i>
        A verification code has been sent to your admin email address.
        Please check your inbox and enter the code below.
      </div>

      <form method="POST" action="/<%= ADMIN_PATH %>/verify-2fa">
        <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">
        <div class="form-group">
          <label for="otp">Verification Code</label>
          <input type="text" id="otp" name="otp" placeholder="000000" maxlength="6" required autocomplete="off" inputmode="numeric" pattern="[0-9]{6}">
        </div>

        <button type="submit" class="btn-verify">
          <span>Verify</span>
        </button>
      </form>

      <a href="javascript:void(0)" class="resend-link" onclick="resendOTP()">Didn't receive code? Resend</a>

      <div class="timer" id="timer">Resend available in 60 seconds</div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

  <script>
    // Custom cursor
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
      });

      (function ani() {
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(ani);
      })();
    }

    // Form submission feedback
    const form = document.querySelector('form');
    const btn = document.querySelector('.btn-verify');

    form.addEventListener('submit', (e) => {
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span>Verifying...</span>';
      btn.style.pointerEvents = 'none';
    });

    // Reveal animation
    const card = document.querySelector('.verify-card');
    card.style.opacity = '0';
    card.style.transform = 'translateY(20px)';

    setTimeout(() => {
      card.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }, 100);

    // Resend OTP functionality
    let countdown = 60;
    let canResend = false;

    function startTimer() {
      const timerEl = document.getElementById('timer');
      countdown = 60;
      canResend = false;

      const interval = setInterval(() => {
        if (countdown <= 0) {
          clearInterval(interval);
          canResend = true;
          timerEl.textContent = 'You can now resend the code';
        } else {
          timerEl.textContent = `Resend available in ${countdown} seconds`;
          countdown--;
        }
      }, 1000);
    }

    function resendOTP() {
      if (!canResend) {
        alert('Please wait for the timer to finish');
        return;
      }

      fetch('/<%= ADMIN_PATH %>/resend-2fa', { method: 'POST' })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('Verification code resent!');
            startTimer();
            // Clear the input
            document.getElementById('otp').value = '';
          } else {
            alert('Failed to resend: ' + data.message);
          }
        })
        .catch(err => {
          alert('Error resending code');
          console.error(err);
        });
    }

    startTimer();

    // Auto-focus OTP input
    document.getElementById('otp').focus();

    // Format OTP input (digits only)
    document.getElementById('otp').addEventListener('input', (e) => {
      e.target.value = e.target.value.replace(/[^0-9]/g, '');
    });

    // Submit on Enter (if 6 digits entered)
    document.getElementById('otp').addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && e.target.value.length === 6) {
        form.submit();
      }
    });
  </script>
</body>
</html>
