<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Admin 2FA</title>
  <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
  <style>
    :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;
    --accent3:#4f8ef7;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;
    --yellow:#f59e0b;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:30px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    box-sizing:border-box;
    margin:0;
    padding:0;
}

html{
    scroll-behavior:smooth;
    overflow-x:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow-x:hidden;
    min-height:100vh;

    position:relative;

    cursor:none;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.15),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur,
#cur-ring{
    display:none;
}

@media(pointer:fine){

    #cur,
    #cur-ring{
        display:block;
        position:fixed;
        z-index:99999;
    }

    #cur{
        width:8px;
        height:8px;

        background:var(--accent);

        border-radius:50%;

        transform:translate(-50%,-50%);

        transition:
            width .25s,
            height .25s,
            background .25s;

        mix-blend-mode:screen;

        pointer-events:none;
    }

    #cur-ring{
        width:34px;
        height:34px;

        border:1px solid rgba(124,106,247,.4);

        border-radius:50%;

        transform:translate(-50%,-50%);

        pointer-events:none;

        z-index:99998;
    }

    body:has(button:hover) #cur,
    body:has(a:hover) #cur,
    body:has(.stat-card:hover) #cur{
        width:16px;
        height:16px;

        background:var(--accent2);
    }
}

/* NOISE */

.noise{
    position:fixed;
    inset:0;

    opacity:.04;

    pointer-events:none;

    z-index:1;

    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ORBS */

.orb{
    position:fixed;

    border-radius:50%;

    pointer-events:none;

    z-index:0;
}

.orb-1{
    top:-180px;
    right:-120px;

    width:540px;
    height:540px;

    background:
        radial-gradient(circle,
        rgba(124,106,247,.16),
        transparent 70%);

    animation:floatA 12s ease-in-out infinite alternate;
}

.orb-2{
    bottom:-100px;
    left:-100px;

    width:420px;
    height:420px;

    background:
        radial-gradient(circle,
        rgba(91,240,192,.08),
        transparent 70%);

    animation:floatB 14s ease-in-out infinite alternate;
}

@keyframes floatA{
    from{
        transform:translate(0,0);
    }

    to{
        transform:translate(-30px,30px) scale(1.08);
    }
}

@keyframes floatB{
    from{
        transform:translate(0,0);
    }

    to{
        transform:translate(24px,-24px) scale(1.04);
    }
}

/* NAV */

.nav{
    height:82px;

    width:100%;

    position:fixed;

    z-index:1000;

    padding:0 40px;

    display:flex;
    justify-content:space-between;
    align-items:center;

    background:rgba(10,12,16,.82);

    backdrop-filter:blur(22px);

    border-bottom:1px solid var(--border);
}

.nav h1{
    font-family:var(--font-display);

    font-size:36px;

    font-weight:400;

    letter-spacing:-.04em;
}

.nav h1 span{
    color:var(--accent);
}

/* LOGOUT */

.logout-btn{
    border:none;

    padding:14px 24px;

    border-radius:18px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:12px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:none;

    transition:.35s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.25);
}

.logout-btn:hover{
    transform:translateY(-4px);

    box-shadow:
        0 18px 40px rgba(124,106,247,.32);
}

/* CONTAINER */

.container{
    position:relative;
    z-index:2;

    max-width:1500px;

    margin:auto;

    padding:120px 40px 80px;
}

/* HEADER */

.page-header{
    margin-bottom:50px;

    animation:fadeUp .8s ease both;
}

.page-badge{
    display:inline-flex;
    align-items:center;
    gap:10px;

    padding:9px 16px;

    border-radius:100px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    color:var(--accent);

    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);

    margin-bottom:22px;
}

.page-badge span{
    width:6px;
    height:6px;

    border-radius:50%;

    background:var(--accent2);

    animation:pulse 2s infinite;
}

@keyframes pulse{
    0%,100%{
        opacity:1;
        transform:scale(1);
    }

    50%{
        opacity:.45;
        transform:scale(.8);
    }
}

.page-title{
    font-family:var(--font-display);

    font-size:clamp(70px,10vw,140px);

    line-height:.88;

    letter-spacing:-.06em;

    font-weight:400;
}

.page-title span{
    background:
        linear-gradient(
            135deg,
            var(--accent),
            var(--accent2)
        );

    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

@keyframes fadeUp{
    from{
        transform:translateY(20px);
        opacity:0;
    }

    to{
        transform:translateY(0);
        opacity:1;
    }
}

/* STATS */

.stats-grid{
    display:grid;

    grid-template-columns:
        repeat(auto-fit,minmax(260px,1fr));

    gap:24px;

    margin-bottom:50px;
}

.stat-card{
    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:30px;

    padding:30px;

    position:relative;
    overflow:hidden;

    transition:.35s;

    box-shadow:
        0 20px 60px rgba(124,106,247,.06);
}

.stat-card::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );
}

.stat-card:hover{
    transform:translateY(-6px);

    border-color:var(--border2);

    box-shadow:
        0 28px 70px rgba(124,106,247,.14);
}

.stat-icon{
    width:60px;
    height:60px;

    border-radius:18px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    display:flex;
    align-items:center;
    justify-content:center;

    font-size:26px;

    color:var(--accent);

    margin-bottom:18px;
}

.stat-value{
    font-family:var(--font-display);

    font-size:58px;

    line-height:1;

    letter-spacing:-.05em;

    margin-bottom:12px;
}

.stat-label{
    color:var(--text2);

    font-size:13px;

    letter-spacing:.08em;

    text-transform:uppercase;
}

/* CHARTS */

.charts-grid{
    display:grid;

    grid-template-columns:
        repeat(auto-fit,minmax(420px,1fr));

    gap:24px;

    margin-bottom:50px;
}

.chart-card{
    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:30px;

    padding:28px;

    box-shadow:
        0 20px 60px rgba(124,106,247,.06);
}

.chart-title{
    display:flex;
    align-items:center;
    gap:12px;

    font-family:var(--font-display);

    font-size:32px;

    font-weight:400;

    margin-bottom:24px;
}

.chart-title i{
    color:var(--accent);
}

.chart-container{
    position:relative;

    height:320px;
}

/* TABLES */

.table-section{
    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:30px;

    padding:30px;

    margin-bottom:36px;

    box-shadow:
        0 20px 60px rgba(124,106,247,.06);
}

.section-header{
    display:flex;
    justify-content:space-between;
    align-items:center;

    margin-bottom:24px;
}

.section-title{
    display:flex;
    align-items:center;
    gap:12px;

    font-family:var(--font-display);

    font-size:34px;

    font-weight:400;
}

.section-title i{
    color:var(--accent);
}

.table-responsive{
    overflow-x:auto;
}

table{
    width:100%;

    border-collapse:collapse;

    min-width:700px;
}

thead{
    background:rgba(124,106,247,.05);

    border-bottom:1px solid var(--border);
}

th{
    text-align:left;

    padding:18px 20px;

    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);

    color:var(--text2);

    font-weight:500;
}

td{
    padding:18px 20px;

    border-bottom:1px solid rgba(255,255,255,.04);

    font-size:14px;

    transition:.3s;
}

tbody tr{
    transition:.3s;
}

tbody tr:hover{
    background:rgba(124,106,247,.04);
}

tbody tr:hover td{
    color:white;
}

/* BADGES */

.badge{
    display:inline-flex;
    align-items:center;
    gap:8px;

    padding:6px 14px;

    border-radius:100px;

    font-size:11px;

    font-weight:700;

    letter-spacing:.06em;

    text-transform:uppercase;
}

.badge-free{
    background:rgba(255,255,255,.05);

    border:1px solid var(--border);

    color:var(--text2);
}

.badge-pro{
    background:var(--accent-dim);

    border:1px solid var(--border2);

    color:var(--accent);
}

.badge-business{
    background:rgba(91,240,192,.08);

    border:1px solid rgba(91,240,192,.14);

    color:var(--accent2);
}

/* NO DATA */

.no-data{
    text-align:center;

    padding:60px 20px;

    color:var(--text2);
}

.no-data i{
    font-size:54px;

    margin-bottom:16px;

    opacity:.5;

    display:block;
}

.no-data p{
    font-size:15px;
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none !important;
    }

    .nav{
        padding:0 20px;

        height:72px;
    }

    .nav h1{
        font-size:28px;
    }

    .container{
        padding:100px 20px 50px;
    }

    .page-title{
        font-size:76px;
    }

    .charts-grid{
        grid-template-columns:1fr;
    }

    .chart-card,
    .table-section,
    .stat-card{
        border-radius:26px;
    }

    .table-section{
        padding:22px;
    }

    .chart-title,
    .section-title{
        font-size:28px;
    }

    .stat-value{
        font-size:44px;
    }

    th,
    td{
        padding:14px;
    }
}
  </style>
</head>

<body>
  <div id="cur"></div>
  <div id="cur-ring"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="verify-container">
    <div class="verify-card">
      <div class="verify-header">
        <div class="verify-logo">
           <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
        </div>
        <h2 class="verify-title">Two-Factor Authentication</h2>
        <p class="verify-subtitle">Enter the 6-digit code sent to your email</p>
      </div>

      <% if (error) { %>
        <div class="error-message">
          <%= error %>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="success-message">
          <%= success %>
        </div>
      <% } %>

      <div class="verify-info">
        <i class="ri-shield-check-line"></i>
        A verification code has been sent to your admin email address.
        Please check your inbox and enter the code below.
      </div>

      <form method="POST" action="/<%= ADMIN_PATH %>/verify-2fa">
        <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">
        <div class="form-group">
          <label for="otp">Verification Code</label>
          <input type="text" id="otp" name="otp" placeholder="000000" maxlength="6" required autocomplete="off" inputmode="numeric" pattern="[0-9]{6}">
        </div>

        <button type="submit" class="btn-verify">
          <span>Verify</span>
        </button>
      </form>

      <a href="javascript:void(0)" class="resend-link" onclick="resendOTP()">Didn't receive code? Resend</a>

      <div class="timer" id="timer">Resend available in 60 seconds</div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

  <script>
    // Custom cursor
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
      });

      (function ani() {
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(ani);
      })();
    }

    // Form submission feedback
    const form = document.querySelector('form');
    const btn = document.querySelector('.btn-verify');

    form.addEventListener('submit', (e) => {
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span>Verifying...</span>';
      btn.style.pointerEvents = 'none';
    });

    // Reveal animation
    const card = document.querySelector('.verify-card');
    card.style.opacity = '0';
    card.style.transform = 'translateY(20px)';

    setTimeout(() => {
      card.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    }, 100);

    // Resend OTP functionality
    let countdown = 60;
    let canResend = false;

    function startTimer() {
      const timerEl = document.getElementById('timer');
      countdown = 60;
      canResend = false;

      const interval = setInterval(() => {
        if (countdown <= 0) {
          clearInterval(interval);
          canResend = true;
          timerEl.textContent = 'You can now resend the code';
        } else {
          timerEl.textContent = `Resend available in ${countdown} seconds`;
          countdown--;
        }
      }, 1000);
    }

    function resendOTP() {
      if (!canResend) {
        alert('Please wait for the timer to finish');
        return;
      }

      fetch('/<%= ADMIN_PATH %>/resend-2fa', { method: 'POST' })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('Verification code resent!');
            startTimer();
            // Clear the input
            document.getElementById('otp').value = '';
          } else {
            alert('Failed to resend: ' + data.message);
          }
        })
        .catch(err => {
          alert('Error resending code');
          console.error(err);
        });
    }

    startTimer();

    // Auto-focus OTP input
    document.getElementById('otp').focus();

    // Format OTP input (digits only)
    document.getElementById('otp').addEventListener('input', (e) => {
      e.target.value = e.target.value.replace(/[^0-9]/g, '');
    });

    // Submit on Enter (if 6 digits entered)
    document.getElementById('otp').addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && e.target.value.length === 6) {
        form.submit();
      }
    });
  </script>
</body>
</html>
