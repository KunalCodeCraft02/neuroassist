<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Dashboard</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f5f6fa;
            color: #111;
        }

        /* HEADER */

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 30px;
            background: white;
            border-bottom: 1px solid #eee;
        }

        .header h1 {
            font-size: 22px;
        }

        .logout {
            background: black;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        /* CONTAINER */

        .container {
            padding: 30px;
            max-width: 1400px;
            margin: auto;
        }

        /* STATS */

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .stat h2 {
            font-size: 30px;
            margin-bottom: 5px;
        }

        .stat p {
            color: #777;
            font-size: 14px;
        }

        /* SECTION */

        .section {
            margin-top: 40px;
        }

        .section h2 {
            margin-bottom: 20px;
        }

        /* TABLE */

        .table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 14px;
            text-align: left;
            border-bottom: 1px solid #eee;
            font-size: 14px;
        }

        th {
            background: #fafafa;
        }

        /* BADGE */

        .badge {
            background: #e7f7ee;
            color: #0a8a42;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        /* MOBILE */

        @media(max-width:768px) {

            table {
                font-size: 12px;
            }

            .header {
                flex-direction: column;
                gap: 10px;
            }

        }
    </style>

</head>

<body>

    <div class="header">

        <h1>Admin Dashboard</h1>

        <button class="logout" onclick="window.location='/logout'">
            Logout
        </button>

    </div>

    <div class="container">

        <!-- STATS -->

        <div class="stats">

            <div class="stat">
                <h2>
                    <%= users.length %>
                </h2>
                <p>Total Users</p>
            </div>

            <div class="stat">
                <h2>
                    <%= bots.length %>
                </h2>
                <p>Total Bots</p>
            </div>

            <div class="stat">
                <h2>
                    <%= conversations.length %>
                </h2>
                <p>Total Conversations</p>
            </div>

            <div class="stat">
                <h2>Active</h2>
                <p>Server Status</p>
            </div>

        </div>


        <!-- USERS TABLE -->

        <div class="section">

            <h2>Registered Users</h2>

            <div class="table">

                <table>

                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Company</th>
                        <th>Joined</th>
                    </tr>

                    <% users.forEach(user=> { %>

                        <tr>

                            <td>
                                <%= user.name %>
                            </td>

                            <td>
                                <%= user.email %>
                            </td>

                            <td>
                                <%= user.companyname || "—" %>
                            </td>

                            <td>
                                <%= user.createdAt ? new Date(user.createdAt).toDateString() : "N/A" %>
                            </td>

                        </tr>

                        <% }) %>

                </table>

            </div>

        </div>


        <!-- BOTS TABLE -->

        <div class="section">

            <h2>All Created Bots</h2>

            <div class="table">

                <table>

                    <tr>
                        <th>Bot Name</th>
                        <th>Category</th>
                        <th>Bot ID</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>

                    <% bots.forEach(bot=> { %>

                        <tr>

                            <td>
                                <%= bot.name %>
                            </td>

                            <td>
                                <%= bot.category %>
                            </td>

                            <td>
                                <%= bot.botId %>
                            </td>

                            <td><span class="badge">Active</span></td>

                            <td>
                                <%= bot.createdAt.toDateString() %>
                            </td>

                        </tr>

                        <% }) %>

                </table>

            </div>

        </div>

    </div>

</body>

</html>