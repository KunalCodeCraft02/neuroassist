<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
}

body {
    background: #ffffff;
    color: #111;
}

/* NAVBAR */
.nav {
    height: 70px;
    border-bottom: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 30px;
}

.nav h1 {
    font-size: 18px;
    font-weight: 600;
}

.logout {
    border: 1px solid #111;
    background: transparent;
    padding: 8px 14px;
    cursor: pointer;
    border-radius: 6px;
}

/* CONTAINER */
.container {
    max-width: 1300px;
    margin: auto;
    padding: 30px 20px;
}

/* STATS */
.stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.stat {
    border: 1px solid #eee;
    padding: 20px;
    border-radius: 10px;
}

.stat h2 {
    font-size: 28px;
    margin-bottom: 5px;
}

.stat p {
    font-size: 13px;
    color: #666;
}

/* GRAPH */
.graph {
    border: 1px solid #eee;
    padding: 20px;
    border-radius: 10px;
    margin-bottom: 30px;
}

.graph h3 {
    margin-bottom: 15px;
    font-size: 15px;
}

/* TABLE */
.section {
    margin-top: 40px;
}

.section h2 {
    margin-bottom: 15px;
    font-size: 16px;
}

.table {
    border: 1px solid #eee;
    border-radius: 10px;
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
    min-width: 600px;
}

th {
    text-align: left;
    padding: 12px;
    background: #fafafa;
    font-size: 13px;
}

td {
    padding: 12px;
    border-top: 1px solid #eee;
    font-size: 13px;
}

tr:hover {
    background: #fafafa;
}

/* BADGE */
.badge {
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 12px;
    border: 1px solid #ddd;
}

/* RESPONSIVE */
@media(max-width:768px){
    .nav {
        flex-direction: column;
        height: auto;
        padding: 15px;
        gap: 10px;
    }

    .container {
        padding: 20px 10px;
    }
}
</style>

</head>

<body>

<!-- NAV -->
<div class="nav">
    <h1>NeuroAssist Admin</h1>
    <button class="logout" onclick="window.location='/admin/logout'">Logout</button>
</div>

<div class="container">

<!-- STATS -->
<div class="stats">
    <div class="stat">
        <h2><%= users.length %></h2>
        <p>Total Users</p>
    </div>

    <div class="stat">
        <h2><%= bots.length %></h2>
        <p>Total Bots</p>
    </div>

    <div class="stat">
        <h2><%= bookings.length %></h2>
        <p>Total Bookings</p>
    </div>

    <div class="stat">
        <h2>₹ <%= totalRevenue %></h2>
        <p>Total Revenue</p>
    </div>
</div>

<!-- GRAPH 1 -->
<div class="graph">
    <h3>User Plans</h3>
    <canvas id="planChart"></canvas>
</div>

<!-- GRAPH 2 -->
<div class="graph">
    <h3>Bot Growth</h3>
    <canvas id="botChart"></canvas>
</div>

<!-- GRAPH 3 -->
<div class="graph">
    <h3>Booking Growth</h3>
    <canvas id="bookingChart"></canvas>
</div>

<!-- USERS -->
<div class="section">
<h2>Users</h2>
<div class="table">
<table>
<tr>
<th>Name</th>
<th>Email</th>
<th>Plan</th>
<th>Joined</th>
</tr>

<% users.forEach(u=>{ %>
<tr>
<td><%= u.name %></td>
<td><%= u.email %></td>
<td><span class="badge"><%= u.plan %></span></td>
<td><%= new Date(u.createdAt).toDateString() %></td>
</tr>
<% }) %>

</table>
</div>
</div>

<!-- BOOKINGS -->
<div class="section">
<h2>Bookings</h2>
<div class="table">
<table>
<tr>
<th>Customer</th>
<th>Phone</th>
<th>Date</th>
<th>Time</th>
</tr>

<% bookings.forEach(b=>{ %>
<tr>
<td><%= b.name || "Caller" %></td>
<td><%= b.phone %></td>
<td><%= b.date %></td>
<td><%= b.time %></td>
</tr>
<% }) %>

</table>
</div>
</div>

</div>

<script>

// SAFE DATA
const users = JSON.parse('<%- JSON.stringify(users || []) %>');
const bots = JSON.parse('<%- JSON.stringify(bots || []) %>');
const bookings = JSON.parse('<%- JSON.stringify(bookings || []) %>');

// PLAN CHART
new Chart(document.getElementById("planChart"), {
    type: "pie",
    data: {
        labels: ["Free","Pro","Business"],
        datasets: [{
            data: [
                users.filter(u=>u.plan==="free").length,
                users.filter(u=>u.plan==="pro").length,
                users.filter(u=>u.plan==="business").length
            ]
        }]
    }
});

// BOT GRAPH
const botMap = {};
bots.forEach(b=>{
    const d = new Date(b.createdAt).toDateString();
    botMap[d] = (botMap[d]||0)+1;
});

new Chart(document.getElementById("botChart"), {
    type:"line",
    data:{
        labels:Object.keys(botMap),
        datasets:[{data:Object.values(botMap)}]
    }
});

// BOOKING GRAPH
const bookMap = {};
bookings.forEach(b=>{
    bookMap[b.date] = (bookMap[b.date]||0)+1;
});

new Chart(document.getElementById("bookingChart"), {
    type:"line",
    data:{
        labels:Object.keys(bookMap),
        datasets:[{data:Object.values(bookMap)}]
    }
});

</script>

</body>
</html>