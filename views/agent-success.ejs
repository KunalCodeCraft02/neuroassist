<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Agent Created</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
 <style>
  :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;
    --accent3:#4f8ef7;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:30px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    box-sizing:border-box;
    margin:0;
    padding:0;
}

html{
    scroll-behavior:smooth;
    overflow-x:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow-x:hidden;
    min-height:100vh;
    width:100%;

    display:flex;
    align-items:center;
    justify-content:center;

    position:relative;

    cursor:none;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.16),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur,
#cur-ring{
    display:none;
}

@media(pointer:fine){

    #cur,
    #cur-ring{
        display:block;
        position:fixed;
        z-index:99999;
    }

    #cur{
        width:8px;
        height:8px;

        background:var(--accent);

        border-radius:50%;

        transform:translate(-50%,-50%);

        transition:
            width .25s,
            height .25s,
            background .25s;

        pointer-events:none;

        mix-blend-mode:screen;
    }

    #cur-ring{
        width:34px;
        height:34px;

        border:1px solid rgba(124,106,247,.4);

        border-radius:50%;

        transform:translate(-50%,-50%);

        pointer-events:none;

        z-index:99998;
    }

    body:has(a:hover) #cur,
    body:has(button:hover) #cur{
        width:16px;
        height:16px;

        background:var(--accent2);
    }
}

/* NOISE */

.noise{
    position:fixed;
    inset:0;

    opacity:.04;

    pointer-events:none;

    z-index:1;

    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ORBS */

.orb{
    position:fixed;

    border-radius:50%;

    pointer-events:none;

    z-index:0;
}

.orb-1{
    top:-180px;
    right:-120px;

    width:520px;
    height:520px;

    background:
        radial-gradient(circle,
        rgba(124,106,247,.16),
        transparent 70%);

    animation:floatA 12s ease-in-out infinite alternate;
}

.orb-2{
    bottom:-100px;
    left:-100px;

    width:420px;
    height:420px;

    background:
        radial-gradient(circle,
        rgba(91,240,192,.08),
        transparent 70%);

    animation:floatB 14s ease-in-out infinite alternate;
}

@keyframes floatA{
    from{
        transform:translate(0,0);
    }

    to{
        transform:translate(-30px,30px) scale(1.08);
    }
}

@keyframes floatB{
    from{
        transform:translate(0,0);
    }

    to{
        transform:translate(24px,-24px) scale(1.04);
    }
}

/* CONTENT */

.content-wrapper{
    position:relative;
    z-index:2;

    width:100%;

    padding:40px 20px;
}

/* CARD */

.success-card{
    max-width:720px;

    margin:auto;

    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:36px;

    padding:64px 46px;

    position:relative;
    overflow:hidden;

    text-align:center;

    box-shadow:
        0 20px 80px rgba(124,106,247,.08);
}

.success-card::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );
}

/* ICON */

.success-icon{
    width:120px;
    height:120px;

    margin:0 auto 28px;

    border-radius:32px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    display:flex;
    align-items:center;
    justify-content:center;

    font-size:56px;

    animation:pulse 2.4s ease-in-out infinite;
}

@keyframes pulse{

    0%,100%{
        transform:scale(1);
        box-shadow:0 0 0 0 rgba(124,106,247,.3);
    }

    50%{
        transform:scale(1.05);
        box-shadow:0 0 0 24px rgba(124,106,247,0);
    }
}

/* BADGE */

.page-badge{
    display:inline-flex;
    align-items:center;
    gap:10px;

    padding:9px 16px;

    border-radius:100px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    color:var(--accent);

    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);

    margin-bottom:28px;
}

.page-badge span{
    width:6px;
    height:6px;

    border-radius:50%;

    background:var(--accent2);

    animation:pulseDot 2s infinite;
}

@keyframes pulseDot{
    0%,100%{
        opacity:1;
    }

    50%{
        opacity:.4;
    }
}

/* TITLE */

.page-title{
    font-family:var(--font-display);

    font-size:clamp(56px,8vw,110px);

    line-height:.9;

    letter-spacing:-.06em;

    font-weight:400;

    margin-bottom:20px;
}

.page-title span{
    background:
        linear-gradient(
            135deg,
            var(--accent),
            var(--accent2)
        );

    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

/* SUBTITLE */

.page-subtitle{
    max-width:560px;

    margin:0 auto 36px;

    color:var(--text2);

    font-size:16px;

    line-height:1.9;
}

/* NUMBER */

.number-display{
    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:24px;

    padding:28px;

    margin:34px 0;

    transition:.35s;
}

.number-display:hover{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

.number-label{
    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);

    color:var(--text2);

    margin-bottom:16px;
}

.number-value{
    font-family:var(--font-display);

    font-size:clamp(34px,5vw,52px);

    letter-spacing:.04em;

    color:var(--accent);

    word-break:break-word;
}

/* COPY */

.btn-copy{
    border:none;

    padding:16px 32px;

    border-radius:18px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:none;

    transition:.35s;

    margin-bottom:30px;

    position:relative;
    overflow:hidden;

    box-shadow:
        0 10px 30px rgba(124,106,247,.25);
}

.btn-copy span{
    position:relative;
    z-index:1;

    display:flex;
    align-items:center;
    gap:10px;
}

.btn-copy::before{
    content:'';

    position:absolute;
    inset:0;

    background:linear-gradient(
        135deg,
        var(--accent2),
        var(--accent)
    );

    opacity:0;

    transition:.35s;
}

.btn-copy:hover::before{
    opacity:1;
}

.btn-copy:hover{
    transform:translateY(-4px);

    box-shadow:
        0 18px 40px rgba(124,106,247,.32);
}

/* BUTTONS */

.button-group{
    display:flex;
    gap:16px;

    justify-content:center;

    flex-wrap:wrap;

    margin-bottom:34px;
}

.btn{
    padding:14px 26px;

    border-radius:18px;

    text-decoration:none;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.35s;

    display:inline-flex;
    align-items:center;
    gap:10px;
}

.btn-primary{
    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    box-shadow:
        0 10px 30px rgba(124,106,247,.25);
}

.btn-primary:hover{
    transform:translateY(-4px);
}

.btn-secondary{
    background:transparent;

    border:1px solid var(--border);

    color:var(--text);
}

.btn-secondary:hover{
    border-color:var(--border2);

    background:var(--accent-dim);

    color:var(--accent);
}

/* INFO */

.info-box{
    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:24px;

    padding:28px;

    text-align:left;
}

.info-box h3{
    display:flex;
    align-items:center;
    gap:10px;

    font-family:var(--font-display);

    font-size:28px;

    font-weight:400;

    margin-bottom:18px;
}

.info-box h3 i{
    color:var(--accent);
}

.info-box ul{
    list-style:none;

    display:flex;
    flex-direction:column;
    gap:14px;
}

.info-box ul li{
    position:relative;

    padding-left:30px;

    color:var(--text2);

    line-height:1.8;
}

.info-box ul li::before{
    content:'';

    position:absolute;
    left:0;
    top:10px;

    width:10px;
    height:10px;

    border-radius:50%;

    background:var(--accent2);

    box-shadow:
        0 0 12px rgba(91,240,192,.4);
}

/* TOAST */

.toast{
    position:fixed;

    bottom:26px;
    left:50%;

    transform:
        translateX(-50%)
        translateY(100px);

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    padding:14px 24px;

    border-radius:18px;

    font-size:13px;
    font-weight:700;

    opacity:0;

    transition:.35s;

    z-index:99999;

    box-shadow:
        0 16px 40px rgba(124,106,247,.25);
}

.toast.show{
    opacity:1;

    transform:
        translateX(-50%)
        translateY(0);
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none !important;
    }

    .success-card{
        padding:42px 24px;

        border-radius:30px;
    }

    .page-title{
        font-size:68px;
    }

    .success-icon{
        width:100px;
        height:100px;

        font-size:48px;
    }

    .button-group{
        flex-direction:column;
    }

    .btn{
        width:100%;

        justify-content:center;
    }

    .number-value{
        font-size:34px;
    }

    .info-box{
        padding:22px;
    }

    .info-box h3{
        font-size:24px;
    }
}
 </style>
</head>

<body>
  <div id="cur"></div>
  <div id="cur-ring"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <div class="content-wrapper">
    <div class="success-card">
      <div class="success-icon">🎉</div>

      <div class="page-badge"><span></span>Setup Complete</div>

      <h1 class="page-title">Your AI Call Booking<br>Agent is Ready!</h1>

      <p class="page-subtitle">
        Share this phone number with your customers. Your AI assistant will handle bookings automatically.
      </p>

      <div class="number-display">
        <div class="number-label">Your Dedicated Phone Number</div>
        <div class="number-value" id="phoneNumber"><%= phoneNumber %></div>
      </div>

      <button class="btn-copy" onclick="copyNumber()">
        <span><i class="ri-file-copy-line"></i> Copy Number</span>
      </button>

      <div class="button-group">
        <a href="/bookings" class="btn btn-primary">
          <i class="ri-calendar-check-line"></i> View Bookings
        </a>
        <a href="/home" class="btn btn-secondary">
          <i class="ri-home-4-line"></i> Back to Home
        </a>
      </div>

      <div class="info-box">
        <h3><i class="ri-lightbulb-flash-line"></i> How it works</h3>
        <ul>
          <li>Customers call your dedicated number anytime</li>
          <li>AI greets them and collects booking details</li>
          <li>Automatic reminders sent to customers</li>
          <li>Bookings appear in your dashboard instantly</li>
          <li>No human intervention needed - 24/7 automation</li>
        </ul>
      </div>
    </div>
  </div>

  <div id="toast" class="toast">Number copied to clipboard!</div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

  <script>
    // Custom cursor
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
      });

      (function ani() {
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(ani);
      })();
    }

    // Copy number functionality
    function copyNumber() {
      const number = document.getElementById('phoneNumber').innerText;
      navigator.clipboard.writeText(number).then(() => {
        const toast = document.getElementById('toast');
        toast.classList.add('show');
        setTimeout(() => {
          toast.classList.remove('show');
        }, 2500);
      }).catch(err => {
        console.error('Copy failed:', err);
        alert('Failed to copy. Please copy manually: ' + number);
      });
    }

    // Animate card on page load
    const card = document.querySelector('.success-card');
    gsap.fromTo(card,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' }
    );
  </script>
</body>

</html>