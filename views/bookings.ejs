<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <title>Bookings Dashboard</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        :root{
            --bg:#0a0c10;
            --surface:#0f1117;
            --surface2:#14161e;
            --surface3:#1a1d28;

            --accent:#7c6af7;
            --accent2:#5bf0c0;
            --accent3:#4f8ef7;

            --accent-dim:rgba(124,106,247,.14);
            --accent2-dim:rgba(91,240,192,.08);

            --text:#e8eaf0;
            --text2:#9da3b8;
            --muted:#4a5070;

            --green:#10b981;
            --red:#ef4444;
            --yellow:#f59e0b;

            --border:rgba(255,255,255,.06);
            --border2:rgba(124,106,247,.22);

            --radius:26px;

            --font-display:'Instrument Serif', serif;
            --font-sans:'Outfit', sans-serif;
            --font-mono:'JetBrains Mono', monospace;
        }

        *,
        *::before,
        *::after{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        html{
            scroll-behavior:smooth;
            overflow-x:hidden;
        }

        body{
            background:var(--bg);
            color:var(--text);

            font-family:var(--font-sans);

            overflow-x:hidden;
            min-height:100vh;

            padding:40px;

            cursor:none;

            position:relative;
        }

        /* GRID */

        body::before{
            content:'';

            position:fixed;
            inset:0;

            background-image:
                linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

            background-size:60px 60px;

            z-index:-2;
        }

        /* MESH */

        body::after{
            content:'';

            position:fixed;
            inset:0;

            background:
                radial-gradient(circle at top right,
                rgba(124,106,247,.14),
                transparent 35%),

                radial-gradient(circle at bottom left,
                rgba(91,240,192,.08),
                transparent 35%);

            filter:blur(20px);

            z-index:-1;
        }

        /* CURSOR */

        #cur{
            position:fixed;

            width:8px;
            height:8px;

            background:var(--accent);

            border-radius:50%;

            pointer-events:none;

            z-index:99999;

            transform:translate(-50%,-50%);

            transition:
                width .25s,
                height .25s,
                background .25s;

            mix-blend-mode:screen;
        }

        #cur-ring{
            position:fixed;

            width:34px;
            height:34px;

            border:1px solid rgba(124,106,247,.4);

            border-radius:50%;

            pointer-events:none;

            z-index:99998;

            transform:translate(-50%,-50%);
        }

        body:has(button:hover) #cur,
        body:has(tr:hover) #cur{
            width:16px;
            height:16px;

            background:var(--accent2);
        }

        /* HEADER */

        .page-header{
            margin-bottom:40px;
        }

        .page-badge{
            display:inline-flex;
            align-items:center;
            gap:10px;

            padding:10px 16px;

            border-radius:100px;

            background:var(--accent-dim);

            border:1px solid var(--border2);

            color:var(--accent);

            font-size:11px;

            letter-spacing:.12em;

            text-transform:uppercase;

            font-family:var(--font-mono);

            margin-bottom:24px;
        }

        .page-badge span{
            width:6px;
            height:6px;

            border-radius:50%;

            background:var(--accent2);

            animation:pulse 2s infinite;
        }

        @keyframes pulse{
            0%,100%{
                opacity:1;
                transform:scale(1);
            }

            50%{
                opacity:.4;
                transform:scale(.75);
            }
        }

        .page-title{
            font-family:var(--font-display);

            font-size:clamp(60px,9vw,120px);

            line-height:.88;

            letter-spacing:-.06em;

            font-weight:400;

            margin-bottom:16px;
        }

        .page-title span{
            background:
                linear-gradient(
                    135deg,
                    var(--accent),
                    var(--accent2)
                );

            -webkit-background-clip:text;
            -webkit-text-fill-color:transparent;
        }

        .page-subtitle{
            color:var(--text2);

            max-width:760px;

            font-size:16px;

            line-height:1.9;
        }

        /* STATS */

        .stats{
            display:grid;

            grid-template-columns:
                repeat(auto-fit,minmax(260px,1fr));

            gap:24px;

            margin-bottom:36px;
        }

        .card{
            background:rgba(15,17,23,.82);

            backdrop-filter:blur(24px);

            border:1px solid var(--border);

            border-radius:28px;

            padding:30px;

            position:relative;
            overflow:hidden;

            transition:.35s;

            box-shadow:
                0 20px 60px rgba(124,106,247,.06);
        }

        .card::before{
            content:'';

            position:absolute;
            top:0;
            left:0;
            right:0;

            height:1px;

            background:
                linear-gradient(
                    90deg,
                    transparent,
                    var(--accent),
                    transparent
                );
        }

        .card:hover{
            transform:translateY(-6px);

            border-color:var(--border2);

            box-shadow:
                0 28px 70px rgba(124,106,247,.14);
        }

        .card h3{
            color:var(--text2);

            font-size:11px;

            letter-spacing:.12em;

            text-transform:uppercase;

            font-family:var(--font-mono);

            margin-bottom:16px;
        }

        .card p{
            font-size:54px;

            font-weight:700;

            letter-spacing:-.04em;
        }

        /* TABLE */

        .table-container{
            background:rgba(15,17,23,.82);

            backdrop-filter:blur(24px);

            border:1px solid var(--border);

            border-radius:30px;

            overflow:hidden;

            box-shadow:
                0 20px 70px rgba(124,106,247,.08);
        }

        .table-header{
            padding:28px 30px;

            border-bottom:1px solid var(--border);

            display:flex;
            align-items:center;
            justify-content:space-between;
        }

        .table-header h2{
            font-family:var(--font-display);

            font-size:38px;

            font-weight:400;

            letter-spacing:-.04em;
        }

        .table-header p{
            color:var(--text2);

            font-size:13px;
        }

        table{
            width:100%;
            border-collapse:collapse;
        }

        thead{
            background:rgba(124,106,247,.08);

            border-bottom:1px solid var(--border);
        }

        th{
            text-align:left;

            padding:20px 24px;

            color:var(--text2);

            font-size:11px;

            letter-spacing:.12em;

            text-transform:uppercase;

            font-family:var(--font-mono);

            font-weight:500;
        }

        td{
            padding:22px 24px;

            border-bottom:1px solid rgba(255,255,255,.04);

            font-size:14px;

            transition:.3s;
        }

        tbody tr{
            transition:.3s;
        }

        tbody tr:hover{
            background:rgba(124,106,247,.04);
        }

        tbody tr:hover td{
            color:white;
        }

        .customer-name{
            font-weight:600;
        }

        .phone{
            color:var(--accent2);

            font-family:var(--font-mono);
        }

        .date-badge{
            display:inline-flex;
            align-items:center;
            justify-content:center;

            padding:8px 12px;

            border-radius:100px;

            background:var(--accent-dim);

            border:1px solid var(--border2);

            color:var(--accent);

            font-size:12px;

            font-family:var(--font-mono);
        }

        .time-badge{
            display:inline-flex;
            align-items:center;
            justify-content:center;

            padding:8px 12px;

            border-radius:100px;

            background:rgba(91,240,192,.08);

            border:1px solid rgba(91,240,192,.14);

            color:var(--accent2);

            font-size:12px;

            font-family:var(--font-mono);
        }

        /* EMPTY */

        .empty{
            text-align:center;

            padding:80px 20px;

            color:var(--text2);
        }

        .empty h3{
            font-size:28px;

            margin-bottom:12px;

            font-family:var(--font-display);

            font-weight:400;
        }

        /* MOBILE */

        @media(max-width:768px){

            body{
                padding:20px;
                cursor:auto;
            }

            #cur,
            #cur-ring{
                display:none !important;
            }

            .page-title{
                font-size:72px;
            }

            .table-container{
                overflow-x:auto;
            }

            table{
                min-width:700px;
            }

            .table-header{
                flex-direction:column;
                align-items:flex-start;

                gap:10px;
            }

            .card p{
                font-size:42px;
            }
        }

    </style>

</head>

<body>

    <div id="cur"></div>
    <div id="cur-ring"></div>

    <!-- HEADER -->

    <div class="page-header">

        <div class="page-badge">
            <span></span>
            Live Booking Analytics
        </div>

        <h1 class="page-title">
            Booking <span>Dashboard</span>
        </h1>

        <p class="page-subtitle">
            Monitor appointments, customer activity, and real-time booking performance through your AI-powered scheduling system.
        </p>

    </div>

    <!-- STATS -->

    <div class="stats">

        <div class="card">
            <h3>Total Bookings</h3>
            <p id="total">0</p>
        </div>

        <div class="card">
            <h3>Today's Bookings</h3>
            <p id="today">0</p>
        </div>

    </div>

    <!-- TABLE -->

    <div class="table-container">

        <div class="table-header">
            <h2>Appointments</h2>
            <p>Real-time customer booking records</p>
        </div>

        <table>

            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Phone</th>
                    <th>Date</th>
                    <th>Time</th>
                </tr>
            </thead>

            <tbody id="bookingTable">

                <tr>
                    <td colspan="4" class="empty">
                        <h3>Loading bookings...</h3>
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

    <script>

        const botId = "<%= botId %>";

        fetch(`/bookings/${botId}`)
            .then(res => res.json())
            .then(data => {

                document.getElementById("total").innerText = data.length;

                const todayDate = new Date()
                    .toISOString()
                    .slice(0,10)
                    .replace(/-/g, "");

                let todayCount = 0;

                const table = document.getElementById("bookingTable");

                table.innerHTML = "";

                if(data.length === 0){

                    table.innerHTML = `
                        <tr>
                            <td colspan="4" class="empty">
                                <h3>No bookings yet</h3>
                                <p>Your upcoming appointments will appear here.</p>
                            </td>
                        </tr>
                    `;

                    return;
                }

                data.forEach(b => {

                    if (b.date === todayDate) todayCount++;

                    const formattedDate =
                        `${b.date.slice(0,4)}-${b.date.slice(4,6)}-${b.date.slice(6,8)}`;

                    const formattedTime =
                        `${b.time.slice(0,2)}:${b.time.slice(2,4)}`;

                    table.innerHTML += `
                        <tr>
                            <td>
                                <div class="customer-name">
                                    ${b.name}
                                </div>
                            </td>

                            <td>
                                <div class="phone">
                                    ${b.phone}
                                </div>
                            </td>

                            <td>
                                <div class="date-badge">
                                    ${formattedDate}
                                </div>
                            </td>

                            <td>
                                <div class="time-badge">
                                    ${formattedTime}
                                </div>
                            </td>
                        </tr>
                    `;
                });

                document.getElementById("today").innerText = todayCount;
            });

        /* CURSOR */

        const cur = document.getElementById('cur');
        const curRing = document.getElementById('cur-ring');

        if(window.matchMedia('(pointer:fine)').matches){

            let mouseX = 0;
            let mouseY = 0;

            let ringX = 0;
            let ringY = 0;

            function animateRing(){

                ringX += (mouseX - ringX) * 0.15;
                ringY += (mouseY - ringY) * 0.15;

                curRing.style.left = ringX + 'px';
                curRing.style.top = ringY + 'px';

                requestAnimationFrame(animateRing);
            }

            document.addEventListener('mousemove',(e)=>{

                mouseX = e.clientX;
                mouseY = e.clientY;

                cur.style.left = mouseX + 'px';
                cur.style.top = mouseY + 'px';
            });

            animateRing();

            document.addEventListener('mouseleave',()=>{

                cur.style.opacity='0';
                curRing.style.opacity='0';
            });

            document.addEventListener('mouseenter',()=>{

                cur.style.opacity='1';
                curRing.style.opacity='1';
            });
        }

    </script>

</body>

</html>