<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Community</title>
  <script src="/socket.io/socket.io.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;
  0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;
    --accent3:#4f8ef7;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;
    --yellow:#f59e0b;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:26px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
    overflow:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow:hidden;
    min-height:100vh;

    cursor:none;

    position:relative;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.14),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur{
    position:fixed;

    width:8px;
    height:8px;

    background:var(--accent);

    border-radius:50%;

    pointer-events:none;

    z-index:99999;

    transform:translate(-50%,-50%);

    transition:
        width .25s,
        height .25s,
        background .25s;

    mix-blend-mode:screen;
}

#cur-ring{
    position:fixed;

    width:34px;
    height:34px;

    border:1px solid rgba(124,106,247,.4);

    border-radius:50%;

    pointer-events:none;

    z-index:99998;

    transform:translate(-50%,-50%);
}

body:has(button:hover) #cur,
body:has(input:hover) #cur,
body:has(select:hover) #cur,
body:has(a:hover) #cur{
    width:16px;
    height:16px;

    background:var(--accent2);
}

/* MOBILE MENU */

#fixediv{
    display:none;

    height:100vh;
    width:100%;

    background:rgba(10,12,16,.96);

    backdrop-filter:blur(24px);

    position:fixed;

    z-index:9999;

    top:-110%;

    transition:.55s cubic-bezier(.16,1,.3,1);

    border-bottom:1px solid var(--border);
}

#fixediv.open{
    top:0;
}

.links-fixed{
    height:100%;

    display:flex;
    flex-direction:column;

    align-items:flex-end;
    justify-content:center;

    gap:12px;

    padding-right:40px;
}

.links-fixed a{
    color:var(--text);

    text-decoration:none;

    font-family:var(--font-display);

    font-size:clamp(38px,8vw,84px);

    letter-spacing:-.05em;

    opacity:.45;

    transition:.3s;
}

.links-fixed a:hover{
    opacity:1;
    color:var(--accent);
}

.close-btn{
    position:absolute;

    top:26px;
    right:26px;

    background:none;
    border:none;

    color:var(--text2);

    font-size:32px;

    cursor:pointer;
}

/* NAV */

#nav{
    height:78px;

    width:100%;

    position:fixed;

    z-index:1000;

    padding:0 40px;

    display:flex;
    justify-content:space-between;
    align-items:center;

    background:rgba(10,12,16,.82);

    backdrop-filter:blur(22px);

    border-bottom:1px solid var(--border);
}

.logo{
    display:flex;
    align-items:baseline;
    gap:4px;

    text-decoration:none;
}

.logo h3{
    font-size:22px;
    font-weight:700;

    letter-spacing:-.02em;
}

.logo h3:nth-child(2){
    color:var(--accent);
}

.logo h3:nth-child(3){
    color:var(--text2);
    font-size:14px;
}

#navPart2{
    display:flex;
    align-items:center;
    gap:30px;
}

#nav-links{
    display:flex;
    gap:26px;
}

#nav-links a{
    color:var(--text2);

    text-decoration:none;

    font-size:13px;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.3s;
}

#nav-links a:hover{
    color:var(--accent);
}

#icon{
    display:flex;
    align-items:center;
    gap:18px;
}

#icon i{
    color:var(--text2);

    font-size:20px;

    cursor:pointer;

    transition:.3s;
}

#icon i:hover{
    color:var(--accent);
}

/* CONTENT */

.content-wrapper{
    padding-top:78px;

    position:relative;
    z-index:2;

    height:100vh;
}

/* ONLINE BOX */

.online-box{
    position:fixed;

    top:96px;
    right:22px;

    width:240px;

    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:24px;

    padding:20px;

    z-index:100;

    box-shadow:
        0 20px 60px rgba(124,106,247,.08);
}

.online-box h3{
    display:flex;
    align-items:center;
    gap:10px;

    font-size:13px;

    letter-spacing:.08em;

    text-transform:uppercase;

    margin-bottom:16px;
}

.online-box h3 i{
    color:var(--accent);
}

#online-users-list{
    display:flex;
    flex-direction:column;
    gap:10px;
}

/* LAYOUT */

.chat-container{
    display:flex;

    height:calc(100vh - 78px);
}

/* SIDEBAR */

.sidebar{
    width:320px;

    background:rgba(15,17,23,.72);

    backdrop-filter:blur(24px);

    border-right:1px solid var(--border);

    padding:28px;

    overflow-y:auto;
}

.sidebar h2{
    display:flex;
    align-items:center;
    gap:12px;

    font-family:var(--font-display);

    font-size:34px;

    font-weight:400;

    margin-bottom:28px;
}

.sidebar h2 i{
    color:var(--accent);
}

/* FILTER */

.filter{
    display:flex;
    flex-direction:column;
    gap:16px;
}

.filter select,
.filter input{
    width:100%;

    padding:16px 18px;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:18px;

    color:var(--text);

    font-size:14px;

    transition:.3s;

    outline:none;
}

.filter select:focus,
.filter input:focus{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

.filter input::placeholder{
    color:var(--muted);
}

.filter select{
    appearance:none;

    background-image:
        linear-gradient(45deg, transparent 50%, var(--accent) 50%),
        linear-gradient(135deg, var(--accent) 50%, transparent 50%);

    background-position:
        calc(100% - 20px) calc(50% - 3px),
        calc(100% - 14px) calc(50% - 3px);

    background-size:6px 6px;

    background-repeat:no-repeat;
}

.filter button{
    padding:16px;

    border:none;

    border-radius:18px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.22);
}

.filter button:hover{
    transform:translateY(-3px);
}

/* CHAT */

.chat{
    flex:1;

    display:flex;
    flex-direction:column;

    background:
        linear-gradient(
            180deg,
            rgba(15,17,23,.45),
            rgba(10,12,16,.92)
        );
}

/* HEADER */

.chat-header{
    height:78px;

    padding:0 28px;

    background:rgba(15,17,23,.72);

    backdrop-filter:blur(18px);

    border-bottom:1px solid var(--border);

    display:flex;
    justify-content:space-between;
    align-items:center;
}

.chat-header span:first-child{
    font-family:var(--font-display);

    font-size:34px;

    letter-spacing:-.04em;
}

/* MESSAGES */

.messages{
    flex:1;

    overflow-y:auto;

    padding:30px;

    display:flex;
    flex-direction:column;

    gap:14px;
}

/* ROW */

.chat-row{
    width:100%;

    display:flex;
}

.chat-row.left{
    justify-content:flex-start;
}

.chat-row.right{
    justify-content:flex-end;
}

/* BUBBLE */

.chat-bubble{
    max-width:min(70%,620px);

    padding:16px 18px;

    border-radius:24px;

    position:relative;

    display:flex;
    flex-direction:column;

    gap:6px;

    animation:fadeUp .35s ease;
}

@keyframes fadeUp{
    from{
        opacity:0;
        transform:translateY(12px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }
}

.chat-bubble.me{
    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    border-bottom-right-radius:8px;

    box-shadow:
        0 10px 30px rgba(124,106,247,.22);
}

.chat-bubble.other{
    background:rgba(91,240,192,.06);

    border:1px solid rgba(91,240,192,.1);

    border-bottom-left-radius:8px;
}

.name{
    font-size:11px;

    letter-spacing:.08em;

    text-transform:uppercase;

    opacity:.7;

    font-weight:700;
}

.text{
    line-height:1.8;

    word-break:break-word;
}

.time{
    font-size:10px;

    opacity:.55;

    text-align:right;
}

/* TYPING */

#typing{
    min-height:24px;

    padding:0 28px 12px;

    color:var(--text2);

    font-size:12px;

    font-style:italic;
}

/* INPUT */

.input-box{
    padding:20px;

    border-top:1px solid var(--border);

    background:rgba(15,17,23,.78);

    backdrop-filter:blur(20px);

    display:flex;
    gap:14px;
}

.input-box input{
    flex:1;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:20px;

    padding:16px 18px;

    color:var(--text);

    font-size:14px;

    outline:none;

    transition:.3s;
}

.input-box input:focus{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

.input-box input::placeholder{
    color:var(--muted);
}

.input-box button{
    padding:16px 24px;

    border:none;

    border-radius:20px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.22);
}

.input-box button:hover{
    transform:translateY(-3px);
}

/* TOAST */

#toast{
    position:fixed;

    bottom:28px;
    right:28px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    padding:14px 20px;

    border-radius:18px;

    font-size:13px;
    font-weight:700;

    opacity:0;

    transform:translateY(20px);

    transition:.35s;

    z-index:99999;

    box-shadow:
        0 14px 40px rgba(124,106,247,.25);
}

#toast.show{
    opacity:1;

    transform:translateY(0);
}

/* SCROLL */

.sidebar::-webkit-scrollbar,
.messages::-webkit-scrollbar{
    width:6px;
}

.sidebar::-webkit-scrollbar-thumb,
.messages::-webkit-scrollbar-thumb{
    background:rgba(124,106,247,.22);

    border-radius:100px;
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none !important;
    }

    #nav{
        padding:0 20px;
        height:70px;
    }

    #nav-links{
        display:none;
    }

    #menuicon{
        display:block;
    }

    .content-wrapper{
        padding-top:70px;
    }

    .chat-container{
        flex-direction:column;

        height:calc(100vh - 70px);
    }

    .sidebar{
        width:100%;

        border-right:none;
        border-bottom:1px solid var(--border);

        padding:22px;

        max-height:260px;
    }

    .sidebar h2{
        font-size:28px;
    }

    .online-box{
        display:none;
    }

    .chat-header{
        height:72px;

        padding:0 20px;
    }

    .chat-header span:first-child{
        font-size:28px;
    }

    .messages{
        padding:20px;
    }

    .chat-bubble{
        max-width:88%;
    }

    .input-box{
        padding:14px;
    }

    .input-box button{
        padding:16px 18px;
    }

    #toast{
        left:20px;
        right:20px;

        bottom:20px;

        text-align:center;
    }

    .links-fixed{
        padding-right:24px;
    }
}
  </style>
</head>

<body>
  <div id="app-wrapper">
    <div id="cur"></div>
    <div id="cur-ring"></div>
    <div class="bg-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div id="fixediv">
      <button class="close-btn" id="closeMenu">
        <i class="ri-close-line"></i>
      </button>
      <div class="links-fixed">
        <a href="/home">HOME</a>
        <a href="/about">ABOUT</a>
        <a href="/chat">Community</a>
        <a href="/pricing">PRICING</a>
        <a href="/profile">PROFILE</a>
        <a href="/bookings">BOOKINGS</a>
        <a href="/createbot">Create Bot</a>
        <a href="/logout">Logout</a>
      </div>
    </div>

    <div id="nav">
      <div class="logo">
        <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
      </div>
      <div id="navPart2">
        <div id="nav-links">
          <a href="/home">Home</a>
          <a href="/about">About</a>
          <a href="/pricing">Pricing</a>
          <a href="/profile">Profile</a>
          <a href="/bookings">Bookings</a>
          <a href="/logout">Logout</a>
        </div>
        <div id="icon">
          <i id="menuicon" class="ri-menu-line"></i>
          <i class="ri-shopping-cart-2-line"></i>
        </div>
      </div>
    </div>

    <div class="content-wrapper">
      <div class="online-box">
        <h3><i class="ri-user-smile-line"></i> Online Users</h3>
        <div id="online-users-list"></div>
      </div>

      <div class="chat-container">
        <div class="sidebar">
          <h2><i class="ri-pushpin-2-line"></i> Location Filter</h2>
          <div class="filter">
            <select id="state">
              <option value="">Select State</option>
              <option value="Maharashtra" <%= user.state === 'Maharashtra' ? 'selected' : '' %>>Maharashtra</option>
              <option value="Karnataka" <%= user.state === 'Karnataka' ? 'selected' : '' %>>Karnataka</option>
              <option value="Delhi" <%= user.state === 'Delhi' ? 'selected' : '' %>>Delhi</option>
              <option value="Gujarat" <%= user.state === 'Gujarat' ? 'selected' : '' %>>Gujarat</option>
              <option value="Tamil Nadu" <%= user.state === 'Tamil Nadu' ? 'selected' : '' %>>Tamil Nadu</option>
            </select>
            <input id="district" type="text" placeholder="Enter District" autocomplete="off" value="<%= user.district || '' %>">
            <button id="joinBtn" onclick="joinLocation()">
              <i class="ri-login-circle-line"></i> Join Chat
            </button>
          </div>
        </div>

        <div class="chat">
          <div class="chat-header">
            <span id="room-display">🌍 Community Chat</span>
            <span id="connection-status" style="font-size: 12px; color: var(--muted);">
              <i class="ri-r-loader-2-line ri-spin"></i> Connecting...
            </span>
          </div>

          <div class="messages" id="messages"></div>
          <div id="typing"></div>

          <div class="input-box">
            <input id="msg" type="text" placeholder="Join a room first to chat..." autocomplete="off" disabled>
            <button id="sendBtn" onclick="sendMessage()" disabled>
              <i class="ri-send-plane-fill"></i> Send
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="toast"></div>

    <!-- Debug Panel (shows real-time status) -->
    <div style="position: fixed; bottom: 10px; left: 10px; font-size: 11px; color: var(--muted); font-family: monospace; z-index: 99999; background: rgba(0,0,0,0.8); padding: 10px; border-radius: 8px; line-height: 1.6;">
      <div style="color: #fff; margin-bottom: 5px; font-weight: bold;">🐛 DEBUG</div>
      <div>hasJoined: <span id="debug-joined" style="color: #ff7518;">false</span></div>
      <div>Socket: <span id="debug-socket" style="color: #ff7518;">connecting...</span></div>
      <div>Room: <span id="debug-room" style="color: #ff7518;">none</span></div>
      <div style="margin-top: 5px; font-size: 10px; opacity: 0.7;">Check F12 console for logs</div>
    </div>


    <script>
      const userId = "<%= user && user._id ? user._id.toString() : '' %>";
      const username = "<%= user && user.name ? user.name : '' %>";

      const socket = io();

      let myRoom = null;
      let hasJoined = false;

      function showToast(msg) {
        // Create toast element if not exists
        let toast = document.getElementById('toast');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'toast';
          document.body.appendChild(toast);
        }
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3000);
      }

      function updateDebugPanel() {
        const debugJoined = document.getElementById('debug-joined');
        const debugSocket = document.getElementById('debug-socket');
        const debugRoom = document.getElementById('debug-room');

        if (debugJoined) debugJoined.textContent = hasJoined ? '✅ true' : '❌ false';
        if (debugSocket) debugSocket.textContent = socket.connected ? '✅ connected' : '❌ disconnected';
        if (debugRoom) debugRoom.textContent = myRoom || 'none';
      }

      function appendMessage(data) {
        console.log("🧱 appendMessage called with:", data);

        // Handle both formats: {text} or {message}
        const messageText = data.text || data.message || '';
        const userName = data.user || data.userName || 'Unknown';
        const userIdFromData = data.userId || data.user_id || '';

        if (!messageText) {
          console.warn("⚠️  Message has no text content:", data);
          return;
        }

        const container = document.getElementById('messages');
        if (!container) {
          console.error("❌ Messages container not found!");
          return;
        }

        try {
          // If this is the first message and container has placeholder, clear it
          if (container.innerHTML.includes('No messages yet')) {
            container.innerHTML = '';
          }

          const chatRow = document.createElement('div');
          const isMe = userIdFromData === userId;
          chatRow.className = `chat-row ${isMe ? 'right' : 'left'}`;

          const chatBubble = document.createElement('div');
          chatBubble.className = `chat-bubble ${isMe ? 'me' : 'other'}`;

          const now = new Date();
          const time = now.getHours().toString().padStart(2, '0') + ':' +
                      now.getMinutes().toString().padStart(2, '0');

          chatBubble.innerHTML = `
            <div class="name">${ userName }</div>
            <div class="text">${ messageText }</div>
            <div class="time">${ time }</div>
          `;

          chatRow.appendChild(chatBubble);
          container.appendChild(chatRow);
          container.scrollTop = container.scrollHeight;

          console.log("✅ Message appended to DOM:", { user: userName, text: messageText, isMe });
        } catch (err) {
          console.error("❌ Error in appendMessage:", err);
        }
      }

      function updateOnlineUsers(users) {
        const list = document.getElementById('online-users-list');
        if (!list) return;

        if (users.length === 0) {
          list.innerHTML = '<em style="color: var(--muted)">No users online</em>';
          return;
        }

        list.innerHTML = users.map(u => `
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="color: #22c55e;">●</span>
            <span style="color: var(--text);">${u.user} ${u.user === username ? '(you)' : ''}</span>
          </div>
        `).join('');
      }

      function joinLocation() {
        try {
          // Prevent joining if already joined
          if (hasJoined) {
            showToast("You have already joined a chat room.");
            return;
          }

          const state = document.getElementById('state').value;
          const district = document.getElementById('district').value;
          const btn = document.getElementById('joinBtn');

          if (!state || !district) {
            showToast("Please select state and enter district");
            return;
          }

          if (!userId) {
            showToast("Not logged in. Please login again.");
            return;
          }

          // Show loading state
          btn.innerHTML = '<i class="ri-loader-4-line ri-spin"></i> Joining...';
          btn.disabled = true;

          myRoom = `${state.trim()}-${district.trim()}`;
          updateDebugPanel();

          console.log("Joining room:", { state, district, userId, room: myRoom });

          // Set a timeout to reset button if no response
          const joinTimeout = setTimeout(() => {
            if (!hasJoined) {
              btn.innerHTML = '<i class="ri-login-circle-line"></i> Join Chat';
              btn.disabled = false;
              myRoom = null;
              updateDebugPanel();
              showToast("Join timed out. Please try again.");
            }
          }, 10000);

          // Store timeout ID to clear it when loadMessages arrives
          window.currentJoinTimeout = joinTimeout;

          socket.emit("joinLocation", {
            state: state.trim(),
            district: district.trim(),
            userId
          });

          console.log("✅ joinLocation emitted, waiting for response...");

          // Will receive loadMessages or error from server
        } catch (err) {
          console.error("joinLocation error:", err);
          showToast("Error joining chat: " + err.message);
          const btn = document.getElementById('joinBtn');
          if (btn) {
            btn.innerHTML = '<i class="ri-login-circle-line"></i> Join Chat';
            btn.disabled = false;
          }
        }
      }

      function sendMessage() {
        console.log("=== sendMessage() called ===");
        console.log("hasJoined:", hasJoined);
        console.log("socket.connected:", socket.connected);

        if (!hasJoined) {
          console.log("❌ BLOCKED: hasJoined is false");
          showToast("Please join a chat room first");
          return;
        }

        if (!socket.connected) {
          console.log("❌ BLOCKED: socket not connected");
          showToast("Connection lost. Please refresh.");
          return;
        }

        const input = document.getElementById('msg');
        const message = input.value.trim();

        if (!message) {
          console.log("❌ Empty message, not sending");
          return;
        }

        // Show sending indicator
        const originalPlaceholder = input.placeholder;
        input.placeholder = "Sending...";
        input.disabled = true;

        console.log("📤 Attempting to send:", message);
        console.log("🔢 Socket ID:", socket.id);
        console.log("📍 Current room:", myRoom);

        try {
          socket.emit("sendMessage", { message }, (ack) => {
            console.log("📨 Server ACK/NACK:", ack);

            // Re-enable input
            input.disabled = false;
            input.placeholder = originalPlaceholder;

            if (ack && ack.error) {
              showToast("Failed: " + ack.error);
              console.error("❌ Server rejected message:", ack.error);
            } else if (ack && ack.success) {
              console.log("✅ Server confirmed message sent");
              input.value = "";
            }
          });
          console.log("✅ socket.emit called successfully");
        } catch (err) {
          console.error("❌ socket.emit error:", err);
          showToast("Error sending message: " + err.message);
          input.disabled = false;
          input.placeholder = originalPlaceholder;
        }
      }

      document.getElementById('msg').addEventListener("keypress", (e) => {
        if (e.key === "Enter") {
          sendMessage();
        }
      });

      // AUTO-JOIN on page load if state and district are pre-filled
      document.addEventListener('DOMContentLoaded', () => {
        const stateInput = document.getElementById('state');
        const districtInput = document.getElementById('district');

        if (stateInput && districtInput && stateInput.value && districtInput.value && !hasJoined) {
          console.log('Auto-joining room with:', stateInput.value, districtInput.value);
          setTimeout(() => joinLocation(), 1000); // Wait a bit for socket to be ready
        }
      });

      // SOCKET EVENTS

      socket.on("connect", () => {
        console.log("✅ Connected to server");
        updateDebugPanel();
        const connStatus = document.getElementById('connection-status');
        if (connStatus) {
          connStatus.innerHTML = '<i class="ri-checkbox-circle-line" style="color: #22c55e;"></i> Connected';
          connStatus.style.color = '#22c55e';
        }
      });

      socket.on("loadMessages", (messages) => {
        console.log("📥 Loaded messages:", messages.length);
        hasJoined = true;
        updateDebugPanel();

        // Clear join timeout if exists
        if (window.currentJoinTimeout) {
          clearTimeout(window.currentJoinTimeout);
          window.currentJoinTimeout = null;
        }

        // Update UI to show joined state
        const sendBtn = document.getElementById('sendBtn');
        const msgInput = document.getElementById('msg');
        const roomDisplay = document.getElementById('room-display');
        const joinBtn = document.getElementById('joinBtn');
        const connStatus = document.getElementById('connection-status');

        if (sendBtn) {
          sendBtn.disabled = false;
        }
        if (msgInput) {
          msgInput.disabled = false;
          msgInput.placeholder = `Message in ${myRoom ? myRoom.replace('-', ' / ') : 'chat'}...`;
        }
        if (roomDisplay) {
          roomDisplay.textContent = `🌍 ${myRoom ? myRoom.replace('-', ' / ') : 'Community Chat'}`;
        }
        if (joinBtn) {
          joinBtn.innerHTML = '<i class="ri-check-line"></i> Leave';
          joinBtn.style.background = '#ef4444'; // Red for leave
        }
        if (connStatus) {
          connStatus.innerHTML = '<i class="ri-checkbox-circle-line" style="color: #22c55e;"></i> Connected';
          connStatus.style.color = '#22c55e';
        }

        const container = document.getElementById('messages');
        container.innerHTML = "";

        if (messages.length === 0) {
          container.innerHTML = '<div style="text-align: center; color: var(--muted); padding: 20px;">No messages yet. Be the first to say hello! 🎉</div>';
        } else {
          messages.forEach(m => appendMessage({
            userId: m.userId,
            user: m.user,
            text: m.message
          }));
        }

        showToast(`Joined ${myRoom}! You can now chat.`, 'success');
      });

      socket.on("message", (data) => {
        console.log("📨 New message:", data);
        appendMessage(data);
      });

      socket.on("onlineUsers", (users) => {
        console.log("👥 Online users:", users);
        updateOnlineUsers(users);
      });

      // Handle connection errors
      socket.on("connect_error", (err) => {
        console.error("❌ Connection error:", err);
        showToast("Connection error. Please refresh.");
      });

      socket.on("disconnect", () => {
        console.log("🔌 Disconnected");
        showToast("Disconnected. Reconnecting...");
      });

      // Custom cursor functionality
      const cur = document.getElementById('cur');
      const curRing = document.getElementById('cur-ring');

      // Check if device supports fine pointer (desktop/laptop)
      if (window.matchMedia('(pointer: fine)').matches) {
        let mouseX = 0, mouseY = 0;
        let ringX = 0, ringY = 0;

        // Throttle ring animation for smooth effect
        function animateRing() {
          ringX += (mouseX - ringX) * 0.15;
          ringY += (mouseY - ringY) * 0.15;

          curRing.style.left = ringX + 'px';
          curRing.style.top = ringY + 'px';

          requestAnimationFrame(animateRing);
        }

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;

          cur.style.left = mouseX + 'px';
          cur.style.top = mouseY + 'px';
        });

        // Start ring animation
        animateRing();

        // Hide cursor when leaving window
        document.addEventListener('mouseleave', () => {
          cur.style.opacity = '0';
          curRing.style.opacity = '0';
        });

        document.addEventListener('mouseenter', () => {
          cur.style.opacity = '1';
          curRing.style.opacity = '1';
        });
      }

      // ── Mobile menu toggle ──
      const mobileMenuBtn = document.getElementById('menuicon');
      const mobileMenu = document.getElementById('fixediv');
      const closeMobileMenuBtn = document.getElementById('closeMenu');

      if (mobileMenuBtn && mobileMenu && closeMobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.add('open');
        });

        closeMobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
        });

        // Close menu when clicking on links
        document.querySelectorAll('.links-fixed a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
          });
        });

        // Close menu on escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
            mobileMenu.classList.remove('open');
          }
        });

        // Close menu on resize to desktop
        window.addEventListener('resize', () => {
          if (window.innerWidth > 768 && mobileMenu.classList.contains('open')) {
            mobileMenu.classList.remove('open');
          }
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
          window.addEventListener('pageshow', (event) => {
            if (event.persisted) {
              mobileMenu.classList.remove('open');
            }
          });
        });
      }
    </script>



</body>

</html>