<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeuroAssist Community</title>

    <script src="/socket.io/socket.io.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Poppins", sans-serif;
        }

        body {
            background: #f5f7fb;
        }

        /* LAYOUT */
        .container {
            display: flex;
            height: 100vh;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: white;
            border-right: 1px solid #eee;
            padding: 20px;
        }

        .sidebar h2 {
            font-size: 18px;
            margin-bottom: 20px;
        }

        /* FILTER */
        .filter {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .filter select,
        .filter input {
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
        }

        .filter button {
            padding: 10px;
            border: none;
            background: black;
            color: white;
            border-radius: 8px;
            cursor: pointer;
        }

        /* ONLINE USERS */
        .online-box {
            background: white;
            padding: 15px;
            border-radius: 10px;
            margin: 15px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        /* CHAT */
        .chat {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* HEADER */
        .chat-header {
            padding: 14px 20px;
            background: white;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            font-weight: 500;
        }

        /* MESSAGES */
        .messages {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
        }

        /* CHAT ROW */
        .chat-row {
            display: flex;
            margin: 10px 0;
        }

        /* LEFT (OTHERS) */
        .chat-row.left {
            justify-content: flex-start;
        }

        /* RIGHT (ME) */
        .chat-row.right {
            justify-content: flex-end;
        }

        /* BUBBLE */
        .chat-bubble {
            max-width: 70%;
            padding: 12px 14px;
            border-radius: 14px;
            font-size: 14px;
            position: relative;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        /* MY MESSAGE */
        .chat-bubble.me {
            background: black;
            color: white;
            border-bottom-right-radius: 4px;
        }

        /* OTHER MESSAGE */
        .chat-bubble.other {
            background: white;
            border: 1px solid #eee;
            border-bottom-left-radius: 4px;
        }

        /* USER NAME */
        .name {
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 4px;
            color: #555;
        }

        /* MESSAGE TEXT */
        .text {
            word-wrap: break-word;
        }

        /* TIME */
        .time {
            font-size: 10px;
            margin-top: 5px;
            opacity: 0.6;
            text-align: right;
        }

        /* INPUT */
        .input-box {
            display: flex;
            padding: 10px;
            background: white;
            border-top: 1px solid #eee;
        }

        .input-box input {
            flex: 1;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 14px;
        }

        .input-box button {
            margin-left: 10px;
            padding: 10px 18px;
            border: none;
            background: black;
            color: white;
            border-radius: 8px;
            cursor: pointer;
        }

        .name {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 3px;
            color: #007bff;
        }

        /* TYPING */
        #typing {
            font-size: 12px;
            color: #666;
            margin-left: 15px;
            font-style: italic;
        }

        /* TOAST */
        #toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: black;
            color: white;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 13px;
            opacity: 0;
            transform: translateY(20px);
            transition: 0.3s;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .chat-row {
            width: 100%;
            display: flex;
        }

        .chat-row.right {
            justify-content: flex-end;
        }

        .chat-row.left {
            justify-content: flex-start;
        }

        /* MOBILE */
        @media(max-width:768px) {

            .container {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid #eee;
            }

            .chat {
                height: calc(100vh - 180px);
            }

            .chat-bubble {
                max-width: 80%;
                font-size: 13px;
            }

            .chat-header {
                font-size: 13px;
            }

        }
    </style>

</head>

<body>
    <div class="online-box">
        <h3>🟢 Online Users</h3>
        <div id="onlineUsers"></div>
    </div>
    <div class="container">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <h2>Location Filter</h2>

            <div class="filter">

                <select id="state">
                    <option value="">Select State</option>
                    <option>Maharashtra</option>
                    <option>Karnataka</option>
                    <option>Delhi</option>
                    <option>Gujarat</option>
                    <option>Tamil Nadu</option>
                </select>

                <input id="district" placeholder="Enter District">

                <button onclick="joinLocation()">Join Chat</button>

            </div>

        </div>

        <!-- CHAT -->
        <div class="chat">

            <div class="chat-header">
                <span>🌍 Community Chat</span>
                <span>
                    <%= user.name %>
                </span>
            </div>

            <div class="messages" id="messages"></div>
            <div id="typing" style="font-size:12px;color:#666;margin:5px 15px;"></div>

            <div class="input-box">
                <input id="msg" placeholder="Type message...">
                <button onclick="send()">Send</button>
            </div>

        </div>

    </div>

    <div id="toast"></div>


    <script>

        const user = "<%= user && user.name ? user.name : 'Guest' %>";
        const userId = "<%= user._id.toString() %>";

        const socket = io();

        // AUTO FOCUS
        document.getElementById("msg").focus();

        // ENTER KEY SEND
        document.getElementById("msg").addEventListener("keypress", function (e) {
            if (e.key === "Enter") {
                send();
            }
        });

        console.log("SENDING USER:", user);

        // JOIN LOCATION
        function joinLocation() {

            let state = document.getElementById("state").value;
            let district = document.getElementById("district").value;

            if (!state || !district) {
                alert("Select state & district");
                return;
            }

            state = state.trim().toLowerCase();
            district = district.trim().toLowerCase();

            socket.emit("joinLocation", {
                state,
                district,
                user,
                userId
            });

            alert("Joined chat");
        }

        // SEND MESSAGE
        function send() {

            const msgInput = document.getElementById("msg");
            const message = msgInput.value;

            if (!message.trim()) return;

            socket.emit("sendMessage", {
                message
            });

            msgInput.value = "";
        }

        // ✅ RECEIVE MESSAGE (FIXED)
        socket.on("message", (data) => {

            const container = document.getElementById("messages");
            const div = document.createElement("div");

            const isMe = String(data.userId || "") === String(userId || "");

            div.className = isMe ? "chat-row right" : "chat-row left";

            div.innerHTML = `
        <div class="chat-bubble ${isMe ? "me" : "other"}">

            <!-- 🔥 FIX: ALWAYS SHOW NAME -->
            <div class="name">${data.user}</div>

            <div class="text">${data.text || data.message}</div>

            <div class="time">
                ${new Date(data.time).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}
            </div>

        </div>
    `;

            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        });

        // ONLINE USERS
        socket.on("onlineUsers", (users) => {

            const container = document.getElementById("onlineUsers");

            container.innerHTML = `
        <div style="font-size:14px;font-weight:500">
            ${users.length} users online
        </div>
    `;
        });

        // ✅ LOAD OLD (FIXED)
        socket.on("loadMessages", (messages) => {

            const container = document.getElementById("messages");
            container.innerHTML = "";

            messages.forEach(data => {

                const div = document.createElement("div");

                const isMe = String(data.userId || "") === String(userId || "");

                div.className = isMe ? "chat-row right" : "chat-row left";

                div.innerHTML = `
            <div class="chat-bubble ${isMe ? "me" : "other"}">

                <!-- 🔥 FIX: ALWAYS SHOW NAME -->
                <div class="name">${data.user}</div>

                <div class="text">${data.message}</div>

                <div class="time">
                    ${new Date(data.createdAt).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}
                </div>

            </div>
        `;

                container.appendChild(div);
            });

            container.scrollTop = container.scrollHeight;
        });

        // TYPING
        const input = document.getElementById("msg");

        input.addEventListener("input", () => {
            socket.emit("typing");
        });

        let typingTimeout;

        socket.on("typing", (data) => {

            const typingDiv = document.getElementById("typing");

            typingDiv.innerText = `${data.user} is typing...`;

            clearTimeout(typingTimeout);

            typingTimeout = setTimeout(() => {
                typingDiv.innerText = "";
            }, 2000);

        });

    </script>

</body>

</html>