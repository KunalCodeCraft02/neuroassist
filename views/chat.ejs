<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

<title>NeuroAssist Chat</title>

<script src="/socket.io/socket.io.js"></script>

<link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>

<style>

/* ===== RESET ===== */
*{margin:0;padding:0;box-sizing:border-box;}

:root{
  --bg:#04040a;
  --surface:#09090f;
  --surface2:#0e0e18;
  --accent:#ff7518;
  --text:#eeeef5;
  --muted:#5a5a78;
  --border:rgba(255,255,255,0.07);
}

/* ===== BODY ===== */
body{
  background:var(--bg);
  color:var(--text);
  font-family:'DM Sans',sans-serif;
}

/* ===== NAVBAR (HOME SAME) ===== */
#nav{
  height:80px;
  width:100%;
  position:fixed;
  top:0;
  z-index:1000;
  padding:0 40px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:rgba(4,4,10,0.9);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}

.logo{
  display:flex;
  gap:4px;
}

.logo h3{
  font-family:'Syne';
  font-weight:800;
}

.logo h3:nth-child(2){color:var(--accent);}
.logo h3:nth-child(3){color:var(--muted);font-size:14px;}

#nav-links{
  display:flex;
  gap:20px;
}

#nav-links a{
  color:var(--muted);
  text-decoration:none;
  font-size:13px;
}

#nav-links a:hover{color:white;}

/* ===== MAIN ===== */
.container{
  display:flex;
  height:calc(100dvh - 80px);
  margin-top:80px;
}

/* ===== SIDEBAR ===== */
.sidebar{
  width:260px;
  background:var(--surface);
  border-right:1px solid var(--border);
  padding:20px;
}

.sidebar h2{
  font-family:'Syne';
  margin-bottom:20px;
}

.sidebar select,
.sidebar input{
  width:100%;
  padding:12px;
  margin-bottom:12px;
  background:var(--bg);
  border:1px solid var(--border);
  color:white;
  border-radius:8px;
}

.sidebar button{
  width:100%;
  padding:12px;
  background:var(--accent);
  border:none;
  border-radius:8px;
}

/* ===== CHAT ===== */
.chat{
  flex:1;
  display:flex;
  flex-direction:column;
}

/* HEADER */
.chat-header{
  padding:15px 20px;
  background:var(--surface2);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
}

/* MESSAGES */
.messages{
  flex:1;
  padding:20px;
  overflow-y:auto;
}

.chat-row{
  display:flex;
  margin-bottom:10px;
}

.right{justify-content:flex-end;}

.bubble{
  padding:12px 16px;
  border-radius:16px;
  max-width:70%;
}

.me{
  background:var(--accent);
  color:black;
}

.other{
  background:var(--surface2);
}

/* INPUT */
.input-box{
  display:flex;
  padding:12px;
  gap:10px;
  background:var(--surface2);
  border-top:1px solid var(--border);

  position:sticky;
  bottom:0;
}

.input-box input{
  flex:1;
  padding:12px;
  border-radius:25px;
  border:1px solid var(--border);
  background:var(--bg);
  color:white;
}

.input-box button{
  padding:12px 20px;
  border:none;
  border-radius:25px;
  background:var(--accent);
}

/* ===== RESPONSIVE ===== */
@media(max-width:768px){

  .container{
    flex-direction:column;
    height:auto;
  }

  .sidebar{
    width:100%;
    border-right:none;
    border-bottom:1px solid var(--border);
  }

  .chat{
    height:calc(100dvh - 200px);
  }

  #nav{
    padding:0 20px;
  }

  #nav-links{
    display:none;
  }

}

</style>
</head>

<body>

<!-- NAV -->
<div id="nav">
  <div class="logo">
    <h3>Neuro</h3>
    <h3>Assist</h3>
    <h3>Co</h3>
  </div>

  <div id="nav-links">
    <a href="/home">Home</a>
    <a href="/about">About</a>
    <a href="/profile">Profile</a>
    <a href="/bookings">Bookings</a>
    <a href="/logout">Logout</a>
  </div>
</div>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h2>Location Filter</h2>

    <select id="state">
      <option>Select State</option>
      <option>Maharashtra</option>
    </select>

    <input id="district" placeholder="District">

    <button onclick="joinLocation()">Join Chat</button>
  </div>

  <!-- CHAT -->
  <div class="chat">

    <div class="chat-header">
      <span>Community Chat</span>
      <span><%= user.name %></span>
    </div>

    <div class="messages" id="messages"></div>

    <div class="input-box">
      <input id="msg" placeholder="Type message">
      <button onclick="send()">Send</button>
    </div>

  </div>

</div>

<script>

const socket = io();
const user = "<%= user.name %>";
const userId = "<%= user._id %>";

function joinLocation(){
  socket.emit("joinLocation",{user});
}

function send(){
  let msg=document.getElementById("msg").value;
  if(!msg.trim()) return;

  socket.emit("sendMessage",{message:msg});
  document.getElementById("msg").value="";
}

socket.on("message",(data)=>{
  let div=document.createElement("div");

  let isMe = data.userId === userId;

  div.className="chat-row "+(isMe?"right":"");

  div.innerHTML=`
    <div class="bubble ${isMe?'me':'other'}">
      ${data.message}
    </div>
  `;

  document.getElementById("messages").appendChild(div);
});

</script>

</body>
</html>
