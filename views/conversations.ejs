<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Bot Conversations</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

   <style>
    :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --blue:#4f8ef7;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:24px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
    overflow:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow:hidden;
    height:100vh;

    cursor:none;

    position:relative;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.14),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur{
    position:fixed;

    width:8px;
    height:8px;

    background:var(--accent);

    border-radius:50%;

    pointer-events:none;

    z-index:99999;

    transform:translate(-50%,-50%);

    transition:
        width .25s,
        height .25s,
        background .25s;

    mix-blend-mode:screen;
}

#cur-ring{
    position:fixed;

    width:34px;
    height:34px;

    border:1px solid rgba(124,106,247,.4);

    border-radius:50%;

    pointer-events:none;

    z-index:99998;

    transform:translate(-50%,-50%);
}

body:has(button:hover) #cur,
body:has(input:hover) #cur,
body:has(.chat-item:hover) #cur{
    width:16px;
    height:16px;

    background:var(--accent2);
}

/* HEADER */

.header{
    height:78px;

    padding:0 34px;

    display:flex;
    align-items:center;
    justify-content:space-between;

    background:rgba(10,12,16,.82);

    backdrop-filter:blur(22px);

    border-bottom:1px solid var(--border);

    position:relative;
    z-index:10;
}

.header h1{
    font-family:var(--font-display);

    font-size:42px;

    font-weight:400;

    letter-spacing:-.04em;
}

.header h1 span{
    color:var(--accent);
}

/* LAYOUT */

.container{
    display:flex;

    height:calc(100vh - 78px);

    position:relative;
    z-index:2;
}

/* SIDEBAR */

.sidebar{
    width:360px;

    background:rgba(15,17,23,.72);

    backdrop-filter:blur(24px);

    border-right:1px solid var(--border);

    overflow-y:auto;

    padding:20px;
}

/* SIDEBAR TITLE */

.sidebar::before{
    content:'Conversations';

    display:block;

    margin-bottom:18px;

    color:var(--text2);

    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);
}

/* CHAT ITEM */

.chat-item{
    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:20px;

    padding:18px;

    margin-bottom:14px;

    cursor:pointer;

    transition:.3s;

    position:relative;
    overflow:hidden;
}

.chat-item::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );

    opacity:0;
    transition:.3s;
}

.chat-item:hover{
    transform:translateY(-3px);

    border-color:var(--border2);

    background:rgba(124,106,247,.06);

    box-shadow:
        0 12px 30px rgba(124,106,247,.12);
}

.chat-item:hover::before{
    opacity:1;
}

.chat-item h3{
    font-size:16px;

    font-weight:700;

    margin-bottom:8px;
}

.chat-item p{
    color:var(--text2);

    font-size:13px;

    line-height:1.7;

    overflow:hidden;
    text-overflow:ellipsis;

    display:-webkit-box;
    -webkit-line-clamp:2;
    -webkit-box-orient:vertical;
}

/* CHAT WINDOW */

.chat-window{
    flex:1;

    display:flex;
    flex-direction:column;

    background:
        linear-gradient(
            180deg,
            rgba(15,17,23,.55),
            rgba(10,12,16,.9)
        );
}

/* CHAT TOP */

.chat-top{
    height:72px;

    padding:0 28px;

    display:flex;
    align-items:center;

    border-bottom:1px solid var(--border);

    backdrop-filter:blur(16px);
}

.chat-top h2{
    font-size:18px;

    font-weight:700;
}

/* MESSAGES */

.messages{
    flex:1;

    overflow-y:auto;

    padding:30px;

    display:flex;
    flex-direction:column;

    gap:16px;
}

/* EMPTY */

.messages p{
    color:var(--text2);
}

/* MESSAGE */

.message{
    max-width:min(75%,680px);

    padding:16px 18px;

    border-radius:22px;

    font-size:14px;

    line-height:1.8;

    word-wrap:break-word;

    position:relative;

    animation:fadeUp .35s ease;
}

@keyframes fadeUp{
    from{
        opacity:0;
        transform:translateY(12px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }
}

/* USER */

.user{
    align-self:flex-end;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    border-bottom-right-radius:8px;

    box-shadow:
        0 10px 28px rgba(124,106,247,.22);
}

/* BOT */

.bot{
    align-self:flex-start;

    background:rgba(91,240,192,.08);

    border:1px solid rgba(91,240,192,.14);

    color:var(--text);

    border-bottom-left-radius:8px;
}

/* INPUT */

.input-area{
    padding:20px;

    border-top:1px solid var(--border);

    background:rgba(15,17,23,.72);

    backdrop-filter:blur(20px);

    display:flex;
    gap:14px;
}

.input-area input{
    flex:1;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:18px;

    padding:16px 18px;

    color:var(--text);

    font-size:14px;

    outline:none;

    transition:.3s;
}

.input-area input:focus{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

.input-area input::placeholder{
    color:var(--muted);
}

.input-area button{
    padding:16px 22px;

    border:none;

    border-radius:18px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.22);
}

.input-area button:hover{
    transform:translateY(-3px);
}

.input-area button:disabled{
    opacity:.5;

    cursor:not-allowed;

    transform:none;
}

/* SCROLLBAR */

.sidebar::-webkit-scrollbar,
.messages::-webkit-scrollbar{
    width:6px;
}

.sidebar::-webkit-scrollbar-thumb,
.messages::-webkit-scrollbar-thumb{
    background:rgba(124,106,247,.22);

    border-radius:100px;
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none !important;
    }

    .header{
        padding:0 20px;
    }

    .header h1{
        font-size:34px;
    }

    .container{
        flex-direction:column;
    }

    .sidebar{
        width:100%;

        height:260px;

        border-right:none;

        border-bottom:1px solid var(--border);

        padding:16px;
    }

    .chat-window{
        height:calc(100vh - 338px);
    }

    .messages{
        padding:20px;
    }

    .message{
        max-width:90%;
    }

    .input-area{
        padding:14px;
    }

    .input-area button{
        padding:16px 18px;
    }
}
   </style>

</head>

<body>

    <div class="header">
        <h1>Bot Conversations</h1>
    </div>

    <div class="container">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <% conversations.forEach(function(conv,index){ %>

                <div class="chat-item" data-index="<%= index %>">

                    <h3>Conversation <%= index + 1 %>
                    </h3>

                    <p>
                        <% if(conv.messages && conv.messages.length> 0){ %>
                            <%= conv.messages[0].text %>
                                <% } else { %>
                                    No messages
                                    <% } %>
                    </p>

                </div>

                <% }) %>

        </div>


        <!-- CHAT WINDOW -->

        <div class="chat-window">

            <div class="messages" id="messages">
                <p style="color:#777">Select a conversation</p>
            </div>

            <div class="input-area">
                <input placeholder="Send message..." disabled>
                <button disabled>Send</button>
            </div>

        </div>

    </div>


    <!-- SAFE JSON DATA (no red errors) -->

    <script id="conversationData" type="application/json">
<%- JSON.stringify(conversations) %>
</script>


    <script>

        const conversations = JSON.parse(
            document.getElementById("conversationData").textContent
        );

        function openConversation(index) {

            const messagesDiv = document.getElementById("messages")

            messagesDiv.innerHTML = ""

            const conversation = conversations[index]

            if (!conversation) return

            conversation.messages.forEach(function (msg) {

                const div = document.createElement("div")

                div.classList.add("message")

                if (msg.role === "user") {
                    div.classList.add("user")
                } else {
                    div.classList.add("bot")
                }

                div.innerText = msg.text

                messagesDiv.appendChild(div)

            })

            messagesDiv.scrollTop = messagesDiv.scrollHeight

        }

    </script>

</body>

</html>