<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Create Booking Agent</title>
  <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;
    --yellow:#f59e0b;
    --blue:#4f8ef7;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:30px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
    overflow-x:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow-x:hidden;
    min-height:100vh;

    cursor:none;

    position:relative;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.15),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur{
    position:fixed;

    width:8px;
    height:8px;

    background:var(--accent);

    border-radius:50%;

    pointer-events:none;

    z-index:99999;

    transform:translate(-50%,-50%);

    transition:
        width .25s,
        height .25s,
        background .25s;

    mix-blend-mode:screen;
}

#cur-ring{
    position:fixed;

    width:34px;
    height:34px;

    border:1px solid rgba(124,106,247,.4);

    border-radius:50%;

    pointer-events:none;

    z-index:99998;

    transform:translate(-50%,-50%);
}

body:has(a:hover) #cur,
body:has(button:hover) #cur,
body:has(input:hover) #cur,
body:has(select:hover) #cur{
    width:16px;
    height:16px;

    background:var(--accent2);
}

/* NAVBAR */

#nav{
    height:78px;

    position:fixed;
    inset:0 0 auto 0;

    z-index:1000;

    display:flex;
    align-items:center;
    justify-content:space-between;

    padding:0 40px;

    background:rgba(10,12,16,.82);

    backdrop-filter:blur(22px);

    border-bottom:1px solid var(--border);
}

.logo{
    display:flex;
    align-items:baseline;
    gap:4px;

    text-decoration:none;
}

.logo h3{
    font-size:22px;
    font-weight:700;
    letter-spacing:-.02em;
}

.logo h3:nth-child(2){
    color:var(--accent);
}

.logo h3:nth-child(3){
    color:var(--text2);
    font-size:14px;
}

#nav-links{
    display:flex;
    align-items:center;
    gap:24px;
}

#nav-links a{
    color:var(--text2);

    text-decoration:none;

    font-size:13px;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.3s;
}

#nav-links a:hover{
    color:var(--accent);
}

/* CONTENT */

.content-wrapper{
    position:relative;
    z-index:2;

    padding-top:110px;
    padding-bottom:80px;
}

/* HERO */

.page-header{
    max-width:1000px;

    margin:auto;

    text-align:center;

    padding:40px 20px 60px;
}

.page-badge{
    display:inline-flex;
    align-items:center;
    gap:8px;

    padding:8px 16px;

    border-radius:100px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    color:var(--accent);

    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    font-family:var(--font-mono);

    margin-bottom:26px;
}

.page-badge span{
    width:6px;
    height:6px;

    border-radius:50%;

    background:var(--accent2);

    animation:pulse 2s infinite;
}

@keyframes pulse{
    0%,100%{
        opacity:1;
        transform:scale(1);
    }

    50%{
        opacity:.4;
        transform:scale(.75);
    }
}

.page-title{
    font-family:var(--font-display);

    font-size:clamp(64px,10vw,140px);

    line-height:.88;

    letter-spacing:-.06em;

    font-weight:400;

    margin-bottom:22px;
}

.page-title span{
    background:
        linear-gradient(
            135deg,
            var(--accent),
            var(--accent2)
        );

    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.page-subtitle{
    max-width:760px;

    margin:auto;

    color:var(--text2);

    font-size:17px;

    line-height:1.9;
}

/* FORM */

.form-container{
    max-width:860px;

    margin:auto;

    padding:48px;

    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:36px;

    position:relative;
    overflow:hidden;

    box-shadow:
        0 20px 80px rgba(124,106,247,.08);
}

.form-container::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );
}

/* SECTION */

.form-section{
    margin-bottom:42px;
}

.form-section:last-child{
    margin-bottom:0;
}

.section-title{
    display:flex;
    align-items:center;
    gap:12px;

    font-family:var(--font-display);

    font-size:34px;

    font-weight:400;

    margin-bottom:24px;
}

.section-title i{
    color:var(--accent);
}

/* FORM GROUP */

.form-group{
    margin-bottom:22px;
}

.form-group label{
    display:block;

    margin-bottom:10px;

    color:var(--text2);

    font-size:11px;

    letter-spacing:.08em;

    text-transform:uppercase;

    font-family:var(--font-mono);
}

.required-star{
    color:var(--accent);
}

/* INPUTS */

input[type=\"text\"],
select{
    width:100%;

    padding:16px 18px;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:18px;

    color:var(--text);

    font-size:14px;

    font-family:var(--font-sans);

    transition:.3s;

    outline:none;
}

input[type=\"text\"]:focus,
select:focus{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

input::placeholder{
    color:var(--muted);
}

/* SELECT */

select{
    appearance:none;

    background-image:
        linear-gradient(45deg, transparent 50%, var(--accent) 50%),
        linear-gradient(135deg, var(--accent) 50%, transparent 50%);

    background-position:
        calc(100% - 20px) calc(50% - 3px),
        calc(100% - 14px) calc(50% - 3px);

    background-size:6px 6px;

    background-repeat:no-repeat;
}

/* CHECKBOX */

.checkbox-group{
    display:flex;
    flex-wrap:wrap;

    gap:12px;
}

.checkbox-group label{
    display:flex;
    align-items:center;
    gap:8px;

    padding:12px 18px;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:14px;

    cursor:pointer;

    transition:.3s;

    color:var(--text);

    font-size:13px;
}

.checkbox-group label:hover{
    border-color:var(--border2);

    background:var(--accent-dim);
}

.checkbox-group input[type=\"checkbox\"]{
    accent-color:var(--accent);

    width:16px;
    height:16px;
}

/* TIME */

.time-row{
    display:grid;

    grid-template-columns:1fr 1fr;

    gap:16px;
}

/* INFO NOTE */

.form-group p{
    margin-top:8px;

    color:var(--text2);

    font-size:12px;

    line-height:1.7;
}

.form-group p i{
    color:var(--accent);
}

/* BUTTON */

.btn-submit{
    width:100%;

    margin-top:14px;

    padding:18px;

    border:none;

    border-radius:20px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.28);

    position:relative;
    overflow:hidden;
}

.btn-submit:hover{
    transform:translateY(-4px);

    box-shadow:
        0 16px 40px rgba(124,106,247,.38);
}

/* NOTE */

.form-note{
    margin-top:22px;

    padding:18px 20px;

    border-radius:18px;

    background:var(--surface2);

    border:1px solid var(--border);

    color:var(--text2);

    line-height:1.8;

    font-size:13px;

    text-align:center;
}

.form-note i{
    color:var(--accent);

    margin-right:8px;
}

/* FOOTER */

.footer{
    margin-top:80px;

    border-top:1px solid var(--border);

    background:rgba(15,17,23,.35);

    backdrop-filter:blur(18px);
}

.footer-content{
    max-width:1300px;

    margin:auto;

    padding:70px 40px;

    display:grid;

    grid-template-columns:
        1.4fr 1fr 1fr 1fr;

    gap:40px;
}

.footer-logo h1{
    font-family:var(--font-display);

    font-size:40px;

    font-weight:400;
}

.footer-logo span{
    color:var(--accent);
}

.footer-desc{
    color:var(--text2);

    line-height:1.9;

    margin-top:16px;

    max-width:320px;
}

.footer-menu-name{
    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    color:var(--text2);

    margin-bottom:20px;
}

.footer-menu-list{
    list-style:none;

    display:flex;
    flex-direction:column;

    gap:14px;
}

.footer-menu-list a{
    color:var(--text);

    opacity:.7;

    text-decoration:none;

    transition:.3s;
}

.footer-menu-list a:hover{
    opacity:1;

    color:var(--accent);
}

.footer-call-to-action-button{
    display:inline-flex;
    align-items:center;
    justify-content:center;

    padding:14px 24px;

    border-radius:100px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    text-decoration:none;

    font-size:12px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.3s;
}

.footer-call-to-action-button:hover{
    transform:translateY(-3px);
}

.footer-copyright{
    border-top:1px solid var(--border);

    padding:22px;

    text-align:center;
}

.footer-copyright-text{
    color:var(--text2);

    font-size:13px;
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none !important;
    }

    #nav{
        padding:0 20px;
    }

    #nav-links{
        display:none;
    }

    #menuicon{
        display:block;
        font-size:22px;
    }

    .page-title{
        font-size:72px;
    }

    .form-container{
        margin:0 20px;

        padding:30px 22px;

        border-radius:28px;
    }

    .section-title{
        font-size:28px;
    }

    .time-row{
        grid-template-columns:1fr;
    }

    .checkbox-group{
        gap:10px;
    }

    .checkbox-group label{
        width:100%;
    }

    .footer-content{
        grid-template-columns:1fr;

        padding:50px 20px;
    }
}
  </style>
</head>

<body>
  <div id="cur"></div>
  <div id="cur-ring"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <!-- Mobile Menu -->
  <div id="fixediv">
    <button class="close-btn" id="closeMenu">
      <i class="ri-close-line"></i>
    </button>
    <div class="links-fixed">
      <a href="/home">HOME</a>
      <a href="/about">ABOUT</a>
      <a href="/pricing">PRICING</a>
      <a href="/profile">PROFILE</a>
      <a href="/bookings">BOOKINGS</a>
      <a href="/logout">Logout</a>
    </div>
  </div>

  <!-- Navigation -->
  <div id="nav">
    <div class="logo">
      <a href="/home" class="logo-link">
         <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
      </a>
    </div>
    <div id="navPart2">
      <div id="nav-links">
        <a href="/home">Home</a>
        <a href="/about">About</a>
        <a href="/pricing">Pricing</a>
        <a href="/profile">Profile</a>
        <a href="/bookings">Bookings</a>
        <a href="/logout">Logout</a>
      </div>
      <div id="icon">
        <i id="menuicon" class="ri-menu-line"></i>
        <i class="ri-shopping-cart-2-line"></i>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="content-wrapper">
    <div class="page-header">
      <div class="page-badge"><span></span>AI Bot Builder</div>
      <h1 class="page-title">Create Booking<br>Agent</h1>
      <p class="page-subtitle">Set up your AI calling agent in minutes. Let it handle bookings, reminders, and customer inquiries automatically.</p>
    </div>

    <div class="form-container">
      <form action="/create-booking-agent" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">

        <!-- Business Info Section -->
        <div class="form-section">
          <h2 class="section-title"><i class="ri-building-line"></i> Business Information</h2>

          <div class="form-group">
            <label for="businessName">Business Name <span class="required-star">*</span></label>
            <input type="text" id="businessName" name="businessName" placeholder="Enter your company name" required autocomplete="off">
          </div>

          <div class="form-group">
            <label for="category">Category <span class="required-star">*</span></label>
            <select id="category" name="category" required>
              <option value="">Select Category</option>
              <option value="hospital">Hospital / Clinic</option>
              <option value="salon">Salon / Spa</option>
              <option value="gym">Gym / Fitness</option>
              <option value="restaurant">Restaurant</option>
              <option value="hotel">Hotel</option>
              <option value="clinic">Dental Clinic</option>
              <option value="education">Education</option>
              <option value="legal">Legal Services</option>
            </select>
          </div>

          <div class="form-group">
            <label for="customerNumber">Vapi Phone Number <span class="required-star">*</span></label>
            <input type="text" id="customerNumber" name="customerNumber" placeholder="+1234567890" required autocomplete="off">
            <p style="font-size: 12px; color: var(--muted); margin-top: 6px;">
              <i class="ri-information-line"></i> Purchase a number from your Vapi dashboard and enter it here.
            </p>
          </div>
        </div>

        <!-- Schedule Section -->
        <div class="form-section">
          <h2 class="section-title"><i class="ri-calendar-line"></i> Schedule</h2>

          <div class="form-group">
            <label>Working Days</label>
            <div class="checkbox-group">
              <label>
                <input type="checkbox" name="workingDays" value="Mon"> Mon
              </label>
              <label>
                <input type="checkbox" name="workingDays" value="Tue"> Tue
              </label>
              <label>
                <input type="checkbox" name="workingDays" value="Wed"> Wed
              </label>
              <label>
                <input type="checkbox" name="workingDays" value="Thu"> Thu
              </label>
              <label>
                <input type="checkbox" name="workingDays" value="Fri"> Fri
              </label>
              <label>
                <input type="checkbox" name="workingDays" value="Sat"> Sat
              </label>
              <label>
                <input type="checkbox" name="workingDays" value="Sun"> Sun
              </label>
            </div>
          </div>

          <div class="form-group">
            <label>Working Hours</label>
            <div class="time-row">
              <input type="text" id="startTime" name="startTime" placeholder="Start time (e.g., 09:00)" autocomplete="off">
              <input type="text" id="endTime" name="endTime" placeholder="End time (e.g., 18:00)" autocomplete="off">
            </div>
          </div>

          <div class="form-group">
            <label for="slotDuration">Slot Duration</label>
            <select id="slotDuration" name="slotDuration">
              <option value="15">15 minutes</option>
              <option value="30" selected>30 minutes</option>
              <option value="60">1 hour</option>
            </select>
          </div>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn-submit">
          <span>Create Agent 🚀</span>
        </button>

        <p class="form-note">
          <i class="ri-magic-line"></i>
          Your AI assistant will handle calls, bookings, and reminders automatically.
        </p>

      </form>
    </div>
  </div>

  <!-- Footer -->
  <div class="pg-footer">
    <footer class="footer">
      <div class="footer-content">
        <div class="footer-content-column">
          <div class="footer-logo">
            <h1>Neuro<span>Assist</span></h1>
          </div>
          <p class="footer-desc">The AI platform for building smart chatbots that work for your business around the clock.</p>
        </div>

        <div class="footer-content-column">
          <div class="footer-menu">
            <h2 class="footer-menu-name">Get Started</h2>
            <ul class="footer-menu-list">
              <li><a href="/home">Home</a></li>
              <li><a href="#">Documentation</a></li>
              <li><a href="/createbot">Create Bot</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-content-column">
          <div class="footer-menu">
            <h2 class="footer-menu-name">Company</h2>
            <ul class="footer-menu-list">
              <li><a href="/contact">Contact</a></li>
              <li><a href="#">Privacy Policy</a></li>
              <li><a href="#">Terms of Service</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-content-column">
          <div class="footer-call-to-action">
            <h2 class="footer-call-to-action-title">Need Help?</h2>
            <p class="footer-call-to-action-description">Our team is here to assist you.</p>
            <a class="footer-call-to-action-button" href="/contact">Get in Touch</a>
          </div>
        </div>
      </div>

      <div class="footer-copyright">
        <p class="footer-copyright-text">
          © 2025 <a href="/home" class="footer-copyright-link">NeuroAssist Co.</a> All rights reserved.
        </p>
      </div>
    </footer>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

  <script>
    // Custom cursor
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
      });

      (function ani() {
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(ani);
      })();
    }

    // Navbar scroll effect
    window.addEventListener('scroll', () => {
      document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
    });

    // Mobile menu
    const menuBtn = document.getElementById('menuicon');
    const closeBtn = document.getElementById('closeMenu');
    const menuDiv = document.getElementById('fixediv');

    menuBtn.addEventListener('click', () => {
      menuDiv.classList.add('open');
    });

    closeBtn.addEventListener('click', () => {
      menuDiv.classList.remove('open');
    });

    menuDiv.addEventListener('click', (e) => {
      if (e.target === menuDiv) {
        menuDiv.classList.remove('open');
      }
    });

    // Scroll reveal animations for form sections
    const revealEls = document.querySelectorAll('.form-section, .page-header, .form-container');
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, index * 100);
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    revealEls.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      revealObs.observe(el);
    });

    // Form submission feedback
    const form = document.querySelector('form');
    form.addEventListener('submit', (e) => {
      const btn = document.querySelector('.btn-submit');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span>Creating...</span>';
      btn.style.pointerEvents = 'none';

      // Re-enable after 3 seconds (or you can remove this if your form submission navigates away)
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.pointerEvents = 'auto';
      }, 3000);
    });
  </script>
</body>

</html>