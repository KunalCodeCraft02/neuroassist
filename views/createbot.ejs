<!DOCTYPE html>
<html>

<head>

    <title>Bot Designer</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #ffffff;
            color: #111;
        }

        main {
            width: 100%;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* MAIN CONTAINER */

        .container {
            display: flex;
            gap: 40px;
            width: 100%;
            max-width: 1100px;
        }

        /* LEFT DESIGN PANEL */

        .left {
            width: 420px;
            background: white;
            padding: 35px;
            border-radius: 12px;
            border: 1px solid #eee;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .left h2 {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 25px;
        }

        label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            margin-top: 18px;
            margin-bottom: 6px;
        }

        input,
        select,
        textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #e3e3e3;
            border-radius: 8px;
            font-size: 14px;
            outline: none;
        }

        textarea {
            min-height: 80px;
            resize: none;
        }

        button {
            margin-top: 25px;
            width: 100%;
            padding: 14px;
            border: none;
            background: black;
            color: white;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }

        /* RIGHT PREVIEW */

        .right {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .previewTitle {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        /* CHATBOX */

        .previewBox {
            width: 340px;
            height: 520px;
            background: white;
            border-radius: 14px;
            box-shadow: 0 10px 35px rgba(0, 0, 0, 0.08);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .previewHeader {
            padding: 16px;
            font-size: 14px;
            font-weight: 600;
            color: white;
        }

        .previewMessages {
            flex: 1;
            padding: 18px;
            background: #f7f7f7;
            display: flex;
            align-items: flex-start;
        }

        .botMessage {
            background: white;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 13px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
            max-width: 75%;
        }

        .previewInput {
            display: flex;
            border-top: 1px solid #eee;
            padding: 10px;
        }

        .previewInput input {
            flex: 1;
            border: none;
            outline: none;
            font-size: 13px;
        }

        .previewInput button {
            width: 70px;
            background: black;
            color: white;
            border-radius: 6px;
            border: none;
            cursor: pointer;
        }

        /* MOBILE RESPONSIVE */

        @media(max-width:900px) {

            .container {
                flex-direction: column;
                align-items: center;
            }

            .left {
                width: 100%;
                max-width: 500px;
            }

            .right {
                margin-top: 30px;
            }

            .previewBox {
                width: 100%;
                max-width: 360px;
            }

        }
    </style>

</head>

<body>

    <main>


        <div class="container">

            <!-- DESIGN PANEL -->

            <div class="left">

                <h2>Design Your Chatbot</h2>

                <form action="/createbot" method="POST">

                    <label>Bot Name</label>
                    <input name="name" id="botName" placeholder="Support Assistant">

                    <label>Category</label>
                    <select name="category">

                        <option>Customer Support</option>

                        <option>Sales Assistant</option>

                        <option>FAQ Bot</option>

                        <option>Lead Generation</option>

                        <option>E-commerce Assistant</option>

                        <option>Technical Support</option>

                        <option>Booking Assistant</option>

                        <option>Product Advisor</option>

                        <option>Marketing Assistant</option>

                        <option>HR Assistant</option>

                        <option>Education Assistant</option>

                        <option>Healthcare Assistant</option>

                    </select>

                    <label>Primary Color</label>
                    <input type="color" id="botColor" name="color" value="#000000">

                    <label>Website URL</label>

                    <input type="url" name="websiteUrl" placeholder="https://example.com">

                    <label>Welcome Message</label>
                    <textarea name="welcomeMessage" id="welcomeMessage">
Hello 👋
How can I help you today?
</textarea>

                    <label>Training Knowledge</label>
                    <textarea name="knowledge" placeholder="Example:
Refund policy is 7 days
Delivery time is 3 days"></textarea>

                    <button>Create Bot</button>

                </form>

            </div>


            <!-- CHAT PREVIEW -->

            <div class="right">

                <h3 class="previewTitle">Live Chatbot Preview</h3>

                <div class="previewBox">

                    <div class="previewHeader" id="previewHeader">

                        <span id="previewName">Support Assistant</span>

                    </div>

                    <div class="previewMessages">

                        <div class="botMessage" id="previewMessage">

                            Hello 👋 How can I help you today?

                        </div>

                    </div>

                    <div class="previewInput">

                        <input placeholder="Type your message">

                        <button>Send</button>

                    </div>

                </div>

            </div>

        </div>

    </main>

    <script>

        const nameInput = document.getElementById("botName")
        const colorInput = document.getElementById("botColor")
        const messageInput = document.getElementById("welcomeMessage")

        const previewName = document.getElementById("previewName")
        const previewHeader = document.getElementById("previewHeader")
        const previewMessage = document.getElementById("previewMessage")

        previewHeader.style.background = "#000"

        nameInput.addEventListener("input", () => {

            previewName.innerText = nameInput.value || "Support Assistant"

        })

        colorInput.addEventListener("input", () => {

            previewHeader.style.background = colorInput.value
            document.querySelector(".previewInput button").style.background = colorInput.value

        })

        messageInput.addEventListener("input", () => {

            previewMessage.innerText = messageInput.value

        })

        

    </script>

</body>

</html>