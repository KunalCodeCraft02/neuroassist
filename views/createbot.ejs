<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Create Your Bot</title>
  <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0a0c10;
      --surface: #0f1117;
      --surface2: #14161e;
      --surface3: #1a1d28;

      --accent: #7c6af7;
      --accent2: #5bf0c0;

      --accent-dim: rgba(124, 106, 247, .14);

      --text: #e8eaf0;
      --text2: #9da3b8;
      --muted: #4a5070;

      --border: rgba(255, 255, 255, .06);
      --border2: rgba(124, 106, 247, .18);

      --font-display: 'Syne', sans-serif;
      --font-sans: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--text);

      font-family: var(--font-sans);

      overflow-x: hidden;

      position: relative;

      min-height: 100vh;

      cursor: none;
    }

    /* BACKGROUND */

    body::before {
      content: '';

      position: fixed;
      inset: 0;

      background-image:
        linear-gradient(rgba(255, 255, 255, .025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .025) 1px, transparent 1px);

      background-size: 60px 60px;

      z-index: -3;
    }

    body::after {
      content: '';

      position: fixed;
      inset: 0;

      background:
        radial-gradient(circle at top right,
          rgba(124, 106, 247, .16),
          transparent 35%),

        radial-gradient(circle at bottom left,
          rgba(91, 240, 192, .08),
          transparent 35%);

      filter: blur(20px);

      z-index: -2;
    }

    .bg-grid {
      position: fixed;
      inset: 0;

      background-image:
        linear-gradient(rgba(255, 255, 255, .02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .02) 1px, transparent 1px);

      background-size: 70px 70px;

      z-index: -1;

      pointer-events: none;
    }

    .orb {
      position: fixed;

      border-radius: 50%;

      pointer-events: none;

      filter: blur(90px);

      z-index: -1;
    }

    .orb-1 {
      width: 500px;
      height: 500px;

      top: -200px;
      right: -160px;

      background: rgba(124, 106, 247, .12);
    }

    .orb-2 {
      width: 400px;
      height: 400px;

      bottom: -120px;
      left: -120px;

      background: rgba(91, 240, 192, .08);
    }

    /* CURSOR */

    #cur {
      position: fixed;

      width: 8px;
      height: 8px;

      background: var(--accent);

      border-radius: 50%;

      pointer-events: none;

      z-index: 99999;

      transform: translate(-50%, -50%);

      transition:
        width .25s ease,
        height .25s ease,
        background .25s ease;
    }

    #cur-ring {
      position: fixed;

      width: 34px;
      height: 34px;

      border: 1px solid rgba(124, 106, 247, .45);

      border-radius: 50%;

      pointer-events: none;

      z-index: 99998;

      transform: translate(-50%, -50%);
    }

    /* ===================== */
    /* NAVBAR — FIXED        */
    /* ===================== */

    #nav {
      height: 74px;
      width: 100%;

      position: fixed;

      top: 0;
      left: 0;

      /* Raised z-index so it always sits above content */
      z-index: 10000;

      padding: 0 42px;

      display: flex;
      align-items: center;
      justify-content: space-between;

      transition: background .35s, border-color .35s;

      border-bottom: 1px solid transparent;

      /* Always-on background so it's visible on all devices */
      background: rgba(10, 12, 16, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    #nav.scrolled {
      background: rgba(10, 12, 16, .92);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-color: var(--border);
    }

    .logo {
      display: flex;
      align-items: baseline;
      gap: 4px;

      /* Prevent logo from being pushed off-screen */
      flex-shrink: 0;
    }

    .logo h3 {
      font-size: 22px;

      font-weight: 700;

      color: var(--text);
    }

    .logo h3:nth-child(2) {
      color: var(--accent);
    }

    .logo h3:nth-child(3) {
      color: var(--text2);

      font-size: 14px;
    }

    #navPart2 {
      display: flex;
      align-items: center;
      gap: 28px;
    }

    #nav-links {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    #nav-links a {
      text-decoration: none;

      color: var(--text2);

      font-size: 14px;

      transition: color .3s;
    }

    #nav-links a:hover {
      color: white;
    }

    #icon {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    #icon i {
      color: var(--text2);

      font-size: 22px;

      cursor: pointer;

      transition: color .3s;
    }

    #icon i:hover {
      color: var(--accent);
    }

    #menuicon {
      display: none;
    }

    /* ========================= */
    /* MOBILE FULLSCREEN MENU    */
    /* ========================= */

    #fixediv {
      position: fixed;

      top: -100%;
      left: 0;

      width: 100%;
      height: 100%;
      height: 100dvh; /* dynamic viewport height for mobile browsers */

      background: #07090d;

      /* Must be above navbar */
      z-index: 10001;

      transition: top .45s cubic-bezier(.4, 0, .2, 1);

      overflow: hidden;
    }

    #fixediv.open {
      top: 0;
    }

    .close-btn {
      position: absolute;

      top: 24px;
      right: 24px;

      background: none;
      border: none;

      color: white;

      font-size: 36px;

      cursor: pointer;

      z-index: 1;
    }

    .links-fixed {
      height: 100%;

      width: 100%;

      display: flex;
      flex-direction: column;

      justify-content: center;

      /* KEY FIX: center items horizontally */
      align-items: center;
      text-align: center;

      gap: 20px;

      padding: 80px 20px 40px;
    }

    .links-fixed a {
      display: block;

      width: 100%;

      text-decoration: none;

      /* Muted grey-white matching the screenshot */
      color: rgba(200, 205, 220, 0.75);

      font-size: clamp(38px, 10vw, 68px);

      /* Italic serif — matching home page style */
      font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;

      font-weight: 400;

      font-style: italic;

      line-height: 1.15;

      letter-spacing: -.01em;

      text-align: center;

      transition: color .3s, letter-spacing .3s;
    }

    .links-fixed a:hover,
    .links-fixed a:active {
      color: white;
      letter-spacing: .01em;
    }

    /* MAIN */

    .content-wrapper {
      width: 100%;

      padding-top: 120px;
    }

    /* HERO */

    .page-header {
      max-width: 1400px;

      margin: auto;

      padding: 0 42px 60px;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 10px;

      color: var(--text2);

      font-size: 11px;

      font-family: var(--font-mono);

      letter-spacing: .08em;

      text-transform: uppercase;

      margin-bottom: 28px;
    }

    .breadcrumb a {
      color: var(--text2);

      text-decoration: none;
    }

    .page-title {
      font-family: var(--font-display);

      font-size: clamp(68px, 10vw, 132px);

      line-height: .9;

      letter-spacing: -.06em;

      max-width: 900px;
    }

    .page-title span {
      background:
        linear-gradient(135deg,
          var(--accent),
          var(--accent2));

      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
      margin-top: 26px;

      max-width: 640px;

      color: var(--text2);

      line-height: 1.9;

      font-size: 16px;
    }

    /* LAYOUT */

    .form-container {
      max-width: 1400px;

      margin: auto;

      padding: 0 42px 100px;

      display: grid;

      grid-template-columns: 1.05fr .95fr;

      gap: 34px;

      align-items: start;
    }

    /* PANELS */

    .form-panel,
    .preview-card {
      background: rgba(15, 17, 23, .82);

      backdrop-filter: blur(24px);

      border: 1px solid var(--border);

      border-radius: 30px;

      position: relative;

      overflow: hidden;
    }

    .form-panel::before,
    .preview-card::before {
      content: '';

      position: absolute;

      top: 0;
      left: 0;
      right: 0;

      height: 1px;

      background:
        linear-gradient(90deg,
          transparent,
          var(--accent),
          transparent);
    }

    /* FORM */

    .form-panel {
      padding: 38px;
    }

    .form-header {
      margin-bottom: 34px;
    }

    .form-header h2 {
      font-family: var(--font-display);

      font-size: 44px;

      font-weight: 700;

      display: flex;
      align-items: center;
      gap: 12px;

      margin-bottom: 14px;
    }

    .form-header h2 i {
      color: var(--accent);
    }

    .form-header p {
      color: var(--text2);

      line-height: 1.8;
    }

    .form-group {
      margin-bottom: 24px;
    }

    .form-group label {
      display: flex;
      align-items: center;
      gap: 10px;

      margin-bottom: 12px;

      color: var(--text2);

      font-size: 11px;

      font-family: var(--font-mono);

      letter-spacing: .08em;

      text-transform: uppercase;
    }

    .form-group label i {
      color: var(--accent2);
    }

    .form-control {
      width: 100%;

      background: var(--surface2);

      border: 1px solid var(--border);

      border-radius: 16px;

      padding: 17px 18px;

      color: var(--text);

      font-size: 15px;

      transition: .3s;
    }

    .form-control:focus {
      outline: none;

      border-color: var(--border2);

      background: var(--surface3);

      box-shadow:
        0 0 0 4px rgba(124, 106, 247, .08);
    }

    .form-control::placeholder {
      color: var(--muted);
    }

    textarea.form-control {
      min-height: 130px;

      resize: vertical;
    }

    /* COLOR */

    .color-picker-wrapper {
      display: flex;
      align-items: center;
      gap: 18px;

      background: var(--surface2);

      border: 1px solid var(--border);

      border-radius: 18px;

      padding: 16px;
    }

    input[type="color"] {
      width: 58px;
      height: 58px;

      border: none;

      border-radius: 14px;

      overflow: hidden;

      background: none;

      cursor: pointer;
    }

    .color-label {
      display: block;

      color: var(--text2);

      font-size: 13px;
    }

    .color-value {
      margin-top: 6px;

      color: var(--accent);

      font-family: var(--font-mono);

      font-size: 15px;
    }

    /* BUTTON */

    .btn-create {
      width: 100%;

      height: 60px;

      border: none;

      border-radius: 18px;

      background:
        linear-gradient(135deg,
          var(--accent),
          #9c8ef7);

      color: white;

      font-size: 14px;

      font-weight: 700;

      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;

      cursor: pointer;

      transition: transform .3s, box-shadow .3s;

      box-shadow:
        0 10px 30px rgba(124, 106, 247, .25);
    }

    .btn-create:hover {
      transform: translateY(-3px);

      box-shadow:
        0 18px 40px rgba(124, 106, 247, .3);
    }

    /* PREVIEW */

    .preview-panel {
      position: sticky;

      top: 100px;
    }

    .preview-header {
      margin-bottom: 24px;
    }

    .preview-header h3 {
      font-family: var(--font-display);

      font-size: 42px;

      margin-bottom: 10px;
    }

    .preview-header p {
      color: var(--text2);

      line-height: 1.8;
    }

    .preview-card {
      padding: 24px;
    }

    .preview-tag {
      position: absolute;

      top: 20px;
      right: 20px;

      padding: 8px 14px;

      border-radius: 100px;

      background: var(--accent-dim);

      border: 1px solid var(--border2);

      color: var(--accent);

      font-size: 11px;

      font-family: var(--font-mono);

      text-transform: uppercase;
    }

    /* PHONE */

    .phone-frame {
      width: 100%;
      max-width: 340px;

      margin: auto;

      background: black;

      border: 10px solid #1a1d28;

      border-radius: 34px;

      overflow: hidden;

      box-shadow:
        0 20px 60px rgba(0, 0, 0, .45);
    }

    .phone-notch {
      width: 140px;
      height: 26px;

      background: #1a1d28;

      margin: auto;

      border-bottom-left-radius: 16px;
      border-bottom-right-radius: 16px;
    }

    .chat-header {
      padding: 18px;

      display: flex;
      align-items: center;
      gap: 12px;

      color: white;
    }

    .chat-avatar {
      width: 42px;
      height: 42px;

      border-radius: 50%;

      background: rgba(255, 255, 255, .16);

      display: flex;
      align-items: center;
      justify-content: center;
    }

    .chat-name {
      font-size: 15px;

      font-weight: 700;
    }

    .chat-status {
      font-size: 12px;

      opacity: .8;
    }

    .status-dot {
      width: 6px;
      height: 6px;

      border-radius: 50%;

      background: #5bf0c0;

      display: inline-block;
    }

    .chat-body {
      min-height: 400px;

      background: #f5f7fb;

      padding: 18px;

      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .message {
      max-width: 82%;

      padding: 14px 16px;

      border-radius: 18px;

      font-size: 14px;

      line-height: 1.6;
    }

    .message-bot {
      background: white;

      color: #111827;

      border-bottom-left-radius: 6px;
    }

    .chat-input-area {
      background: white;

      border-top: 1px solid #e5e7eb;

      padding: 14px;

      display: flex;
      gap: 10px;
    }

    .chat-input-area input {
      flex: 1;

      border: 1px solid #e5e7eb;

      border-radius: 14px;

      padding: 14px;
    }

    .send-btn {
      width: 48px;
      height: 48px;

      border: none;

      border-radius: 14px;

      color: white;

      cursor: pointer;
    }

    /* LIVE */

    .live-indicator {
      margin-top: 22px;

      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;

      color: var(--text2);

      font-size: 13px;
    }

    .live-dot {
      width: 8px;
      height: 8px;

      border-radius: 50%;

      background: var(--accent2);
    }

    /* ===================== */
    /* TABLET                */
    /* ===================== */

    @media(max-width:1100px) {

      .form-container {
        grid-template-columns: 1fr;
      }

      .preview-panel {
        position: relative;
        top: 0;

        order: -1;
      }
    }

    /* ===================== */
    /* MOBILE                */
    /* ===================== */

    @media(max-width:768px) {

      body {
        cursor: auto;
      }

      #cur,
      #cur-ring {
        display: none !important;
      }

      #menuicon {
        display: block;
        cursor: pointer;
      }

      #nav-links {
        display: none;
      }

      #nav {
        height: 64px;

        padding: 0 18px;

        /* Ensure full-width on mobile */
        left: 0;
        right: 0;
        width: 100%;
      }

      .logo h3 {
        font-size: 18px;
      }

      .logo h3:nth-child(3) {
        font-size: 13px;
      }

      .content-wrapper {
        padding-top: 90px;
      }

      .page-header {
        padding: 0 20px 42px;
      }

      .page-title {
        font-size: 58px;

        line-height: .95;
      }

      .page-subtitle {
        margin-top: 20px;

        font-size: 15px;
      }

      .form-container {
        grid-template-columns: 1fr;

        padding: 0 20px 70px;

        gap: 28px;
      }

      .form-panel {
        padding: 24px;
      }

      .form-header h2 {
        font-size: 30px;
      }

      .preview-header h3 {
        font-size: 32px;
      }

      .preview-card {
        padding: 18px;
      }

      .phone-frame {
        width: 100%;
        max-width: 100%;
      }

      .chat-body {
        min-height: 340px;
      }

      /* Mobile menu links — centered, italic serif */
      .links-fixed {
        gap: 16px;
      }

      .links-fixed a {
        font-size: clamp(36px, 10vw, 56px);
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
        text-align: center;
      }
    }

    /* ===================== */
    /* SMALL MOBILE          */
    /* ===================== */

    @media(max-width:480px) {

      .page-title {
        font-size: 46px;
      }

      .form-panel {
        padding: 20px;
      }

      .preview-card {
        padding: 14px;
      }

      .phone-frame {
        border-width: 8px;
      }

      .chat-body {
        min-height: 300px;
      }

      .color-picker-wrapper {
        flex-direction: column;
        align-items: flex-start;
      }

      .preview-tag {
        display: none;
      }

      .links-fixed a {
        font-size: 38px;
        font-family: 'Playfair Display', Georgia, serif;
        font-style: italic;
      }
    }
  </style>
</head>

<body>
  <div id="app-wrapper">
    <!-- Custom Cursor -->
    <div id="cur"></div>
    <div id="cur-ring"></div>

    <!-- Background Effects -->
    <div class="bg-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <!-- MOBILE FULLSCREEN MENU -->
    <div id="fixediv">
      <button class="close-btn" id="closeMenu" aria-label="Close menu">
        <i class="ri-close-line"></i>
      </button>
      <div class="links-fixed">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/pricing">Pricing</a>
        <a href="/profile">Profile</a>
        <a href="/bookings">Bookings</a>
        <a href="/logout">Logout</a>
      </div>
    </div>

    <!-- NAVBAR -->
    <nav id="nav" role="navigation" aria-label="Main navigation">
      <div class="logo">
        <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
      </div>
      <div id="navPart2">
        <div id="nav-links">
          <a href="/about">About</a>
          <a href="/chat">Community</a>
          <a href="/pricing">Pricing</a>
          <a href="/profile">Profile</a>
          <a href="/bookings">Bookings</a>
          <a href="/logout">Logout</a>
        </div>
        <div id="icon">
          <i id="menuicon" class="ri-menu-line" role="button" aria-label="Open menu" tabindex="0"></i>
          <i class="ri-shopping-cart-2-line"></i>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="content-wrapper">
      <!-- Page Header -->
      <div class="page-header">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span class="separator">→</span>
          <span>Create Bot</span>
        </div>
        <h1 class="page-title">Design Your <span>AI Assistant</span></h1>
        <p class="page-subtitle">Customize every detail of your chatbot. See changes in real-time as you build your
          perfect AI companion.</p>
      </div>

      <!-- Form Container -->
      <div class="form-container">
        <!-- Form Panel -->
        <div class="form-panel">
          <div class="form-header">
            <h2><i class="ri-robot-2-line"></i> Bot Configuration</h2>
            <p>Configure your chatbot's personality, appearance, and knowledge base</p>
          </div>

          <form action="/createbot" method="POST" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">

            <div class="form-group">
              <label>
                <i class="ri-robot-line"></i>
                Bot Identity
              </label>
              <input type="text" name="name" id="botName" class="form-control" placeholder="Enter your bot's name"
                value="Support Assistant" autocomplete="off" maxlength="50" required>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-price-tag-3-line"></i>
                Bot Category
              </label>
              <select name="category" class="form-control" required>
                <option value="customer-support" selected>Customer Support</option>
                <option value="sales">Sales Assistant</option>
                <option value="faq">FAQ Bot</option>
                <option value="lead-generation">Lead Generation</option>
                <option value="ecommerce">E-commerce Assistant</option>
                <option value="technical">Technical Support</option>
                <option value="booking">Booking Assistant</option>
                <option value="product-advisor">Product Advisor</option>
                <option value="marketing">Marketing Assistant</option>
                <option value="hr">HR Assistant</option>
                <option value="education">Education Assistant</option>
                <option value="healthcare">Healthcare Assistant</option>
              </select>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-palette-line"></i>
                Theme Color
              </label>
              <div class="color-picker-wrapper">
                <input type="color" id="botColor" name="color" value="#ff7518" required>
                <div class="color-info">
                  <span class="color-label">Primary accent color</span>
                  <div class="color-value" id="colorValue">#ff7518</div>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-global-line"></i>
                Website Integration
              </label>
              <input type="url" name="websiteUrl" class="form-control" placeholder="https://yourwebsite.com"
                autocomplete="url">
            </div>

            <div class="form-group">
              <label>
                <i class="ri-chat-1-line"></i>
                Welcome Message
              </label>
              <textarea name="welcomeMessage" id="welcomeMessage" class="form-control"
                placeholder="The first message your bot will greet visitors with" rows="3" maxlength="300"
                required>Hello 👋 How can I help you today?</textarea>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-brain-line"></i>
                Training Knowledge
              </label>
              <textarea name="knowledge" class="form-control"
                placeholder="Teach your bot important information about your business&#10;&#10;Example:&#10;• Refund policy: 7 days from purchase&#10;• Delivery time: 3-5 business days&#10;• Support hours: 9am - 6pm EST"
                rows="5" maxlength="2000"></textarea>
            </div>

            <button type="submit" class="btn-create" id="submitBtn">
              <i class="ri-rocket-2-line"></i>
              <span>Create Your Bot</span>
            </button>
          </form>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel">
          <div class="preview-header">
            <h3>Live Preview</h3>
            <p>Watch your chatbot come to life in real-time</p>
          </div>

          <div class="preview-card">
            <span class="preview-tag">Interactive</span>
            <div class="phone-frame">
              <div class="phone-notch"></div>
              <div class="chat-widget">
                <div class="chat-header" id="previewHeader">
                  <div class="chat-avatar">
                    <i class="ri-robot-line"></i>
                  </div>
                  <div class="chat-info">
                    <div class="chat-name" id="previewName">Support Assistant</div>
                    <div class="chat-status">
                      <span class="status-dot"></span>
                      Online
                    </div>
                  </div>
                </div>
                <div class="chat-body">
                  <div class="message message-bot" id="previewMessage">
                    Hello 👋 How can I help you today?
                  </div>
                </div>
                <div class="chat-input-area">
                  <input type="text" placeholder="Type your message..." readonly>
                  <button class="send-btn" type="button">
                    <i class="ri-send-plane-fill"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="live-indicator">
              <span class="live-dot"></span>
              Changes update instantly
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Mobile menu ──────────────────────────────────────────
    const mobileMenuBtn = document.getElementById('menuicon');
    const mobileMenu = document.getElementById('fixediv');
    const closeMobileMenuBtn = document.getElementById('closeMenu');

    function openMenu() { mobileMenu.classList.add('open'); }
    function closeMenu() { mobileMenu.classList.remove('open'); }

    if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', openMenu);
    if (mobileMenuBtn) mobileMenuBtn.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') openMenu(); });
    if (closeMobileMenuBtn) closeMobileMenuBtn.addEventListener('click', closeMenu);

    document.querySelectorAll('.links-fixed a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeMenu();
    });

    // ── Custom cursor (desktop only) ─────────────────────────
    if (window.matchMedia('(pointer: fine)').matches) {
      const cur = document.getElementById('cur');
      const ring = document.getElementById('cur-ring');
      let mx = 0, my = 0, rx = 0, ry = 0;

      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
      });

      (function animateRing() {
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(animateRing);
      })();
    }

    // ── Navbar scroll effect ─────────────────────────────────
    const nav = document.getElementById('nav');
    const handleScroll = () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // ── Live preview ─────────────────────────────────────────
    const nameInput = document.getElementById('botName');
    const colorInput = document.getElementById('botColor');
    const messageInput = document.getElementById('welcomeMessage');

    const previewName = document.getElementById('previewName');
    const previewHeader = document.getElementById('previewHeader');
    const previewMessage = document.getElementById('previewMessage');
    const colorValueDisplay = document.getElementById('colorValue');
    const sendBtn = document.querySelector('.send-btn');

    function applyColor(color) {
      previewHeader.style.background = color;
      if (sendBtn) sendBtn.style.background = color;
      colorValueDisplay.textContent = color;
    }

    applyColor(colorInput.value);

    const debounce = (fn, ms) => {
      let t;
      return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), ms); };
    };

    nameInput.addEventListener('input', debounce(() => {
      previewName.textContent = nameInput.value.trim() || 'Support Assistant';
    }, 100));

    colorInput.addEventListener('input', debounce(() => {
      applyColor(colorInput.value);
    }, 50));

    messageInput.addEventListener('input', debounce(() => {
      previewMessage.textContent = messageInput.value.trim() || 'Hello 👋 How can I help you today?';
    }, 100));

    // Send button animation
    if (sendBtn) {
      sendBtn.addEventListener('click', function () {
        this.style.transform = 'scale(0.9)';
        setTimeout(() => { this.style.transform = ''; }, 150);
      });
    }

    // Form submission feedback
    const form = document.querySelector('form');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', function () {
      const original = submitBtn.innerHTML;
      submitBtn.innerHTML = '<i class="ri-loader-4-line ri-spin"></i><span>Creating...</span>';
      submitBtn.style.pointerEvents = 'none';
      setTimeout(() => {
        if (document.body.contains(submitBtn)) {
          submitBtn.innerHTML = original;
          submitBtn.style.pointerEvents = '';
        }
      }, 5000);
    });

    // Color picker hover (desktop)
    if (window.matchMedia('(pointer: fine)').matches) {
      const colorWrapper = document.querySelector('.color-picker-wrapper');
      colorWrapper.addEventListener('mouseenter', () => { colorInput.style.transform = 'scale(1.02)'; });
      colorWrapper.addEventListener('mouseleave', () => { colorInput.style.transform = ''; });
    }

    // Prevent iOS zoom on input focus
    const viewport = document.querySelector('meta[name="viewport"]');
    const vpDefault = viewport.getAttribute('content');
    document.querySelectorAll('input, textarea, select').forEach(el => {
      el.addEventListener('focus', () => {
        if (window.innerWidth <= 768)
          viewport.setAttribute('content', 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no');
      });
      el.addEventListener('blur', () => {
        viewport.setAttribute('content', vpDefault);
      });
    });

    // Close mobile menu on resize to desktop
    window.addEventListener('resize', debounce(() => {
      if (window.innerWidth > 768) closeMenu();
    }, 250));

    // Close mobile menu on back-navigation
    window.addEventListener('pageshow', e => {
      if (e.persisted) closeMenu();
    });
  </script>
</body>

</html>
