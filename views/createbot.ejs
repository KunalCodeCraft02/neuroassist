<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Create Your Bot</title>
  <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;
  0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #0a0c10;
      --surface: #0f1117;
      --surface2: #14161e;
      --surface3: #1a1d28;

      --accent: #ff7518;
      --accent2: #7c6af7;
      --accent3: #5bf0c0;
      --blue: #4f8ef7;

      --accent-dim: rgba(255, 117, 24, .12);
      --accent2-dim: rgba(124, 106, 247, .08);

      --text: #e8eaf0;
      --text2: #9da3b8;
      --muted: #4a5070;

      --border: rgba(255, 255, 255, .06);
      --border2: rgba(255, 117, 24, .18);

      --radius: 30px;

      --font-display: 'Syne', sans-serif;
      --font-sans: 'DM Sans', sans-serif;
    }

    html {
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    body {
      background: var(--bg);
      color: var(--text);

      font-family: var(--font-sans);

      overflow-x: hidden;
      min-height: 100vh;

      position: relative;

      cursor: none;
    }

    /* GRID */

    body::before {
      content: '';

      position: fixed;
      inset: 0;

      background-image:
        linear-gradient(rgba(255, 255, 255, .025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .025) 1px, transparent 1px);

      background-size: 60px 60px;

      z-index: -2;
    }

    /* MESH */

    body::after {
      content: '';

      position: fixed;
      inset: 0;

      background:
        radial-gradient(circle at top right,
          rgba(255, 117, 24, .14),
          transparent 35%),

        radial-gradient(circle at bottom left,
          rgba(124, 106, 247, .12),
          transparent 35%);

      filter: blur(20px);

      z-index: -1;
    }

    /* CURSOR */

    #cur,
    #cur-ring {
      display: none;
    }

    @media(pointer:fine) {

      #cur,
      #cur-ring {
        display: block;
        position: fixed;
        z-index: 99999;
      }

      #cur {
        width: 8px;
        height: 8px;

        background: var(--accent);

        border-radius: 50%;

        transform: translate(-50%, -50%);

        transition:
          width .25s,
          height .25s,
          background .25s;

        mix-blend-mode: screen;

        pointer-events: none;
      }

      #cur-ring {
        width: 34px;
        height: 34px;

        border: 1px solid rgba(255, 117, 24, .35);

        border-radius: 50%;

        transform: translate(-50%, -50%);

        pointer-events: none;

        z-index: 99998;
      }

      body:has(button:hover) #cur,
      body:has(a:hover) #cur,
      body:has(input:hover) #cur {
        width: 16px;
        height: 16px;

        background: var(--accent3);
      }
    }

    /* NOISE */

    .bg-grid {
      position: fixed;
      inset: 0;

      background-image:
        linear-gradient(rgba(255, 117, 24, .03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 117, 24, .03) 1px, transparent 1px);

      background-size: 72px 72px;

      animation: gridScroll 18s linear infinite;

      pointer-events: none;

      z-index: 0;
    }

    @keyframes gridScroll {
      from {
        transform: translate(0, 0);
      }

      to {
        transform: translate(72px, 72px);
      }
    }

    /* ORBS */

    .orb {
      position: fixed;

      border-radius: 50%;

      pointer-events: none;

      z-index: 0;
    }

    .orb-1 {
      top: -200px;
      right: -140px;

      width: 520px;
      height: 520px;

      background:
        radial-gradient(circle,
          rgba(255, 117, 24, .14),
          transparent 70%);

      animation: floatA 12s ease-in-out infinite alternate;
    }

    .orb-2 {
      bottom: -100px;
      left: -100px;

      width: 420px;
      height: 420px;

      background:
        radial-gradient(circle,
          rgba(124, 106, 247, .1),
          transparent 70%);

      animation: floatB 14s ease-in-out infinite alternate;
    }

    @keyframes floatA {
      from {
        transform: translate(0, 0);
      }

      to {
        transform: translate(-30px, 30px) scale(1.08);
      }
    }

    @keyframes floatB {
      from {
        transform: translate(0, 0);
      }

      to {
        transform: translate(24px, -24px) scale(1.04);
      }
    }

    /* MOBILE MENU */

    #fixediv {
      display: none;

      height: 100vh;
      width: 100%;

      background: #0a0c10;

      position: fixed;

      z-index: 9999;

      top: -110%;

      transition: .5s cubic-bezier(.16, 1, .3, 1);

      border-bottom: 1px solid var(--border);
    }

    #fixediv.open {
      top: 0;
    }

    .links-fixed {
      height: 100%;

      display: flex;
      flex-direction: column;

      align-items: flex-end;
      justify-content: center;

      gap: 10px;

      padding-right: 40px;
    }

    .links-fixed a {
      color: var(--text);

      text-decoration: none;

      font-family: var(--font-display);

      font-weight: 800;

      font-size: clamp(38px, 8vw, 90px);

      opacity: .45;

      transition: .3s;
    }

    .links-fixed a:hover {
      opacity: 1;
      color: var(--accent);
    }

    .close-btn {
      position: absolute;

      top: 24px;
      right: 24px;

      background: none;
      border: none;

      color: var(--text2);

      font-size: 32px;
    }

    /* NAV */

    #nav {
      height: 80px;

      width: 100%;

      position: fixed;

      z-index: 1000;

      padding: 0 40px;

      display: flex;
      justify-content: space-between;
      align-items: center;

      transition: .35s;

      border-bottom: 1px solid transparent;
    }

    #nav.scrolled {
      background: rgba(10, 12, 16, .78);

      backdrop-filter: blur(24px);

      border-bottom: 1px solid var(--border);

      box-shadow:
        0 10px 40px rgba(0, 0, 0, .35);
    }

    .logo {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .logo h3 {
      font-family: var(--font-display);

      font-weight: 800;

      font-size: 20px;

      letter-spacing: -.02em;
    }

    .logo h3:nth-child(2) {
      color: var(--accent);
    }

    .logo h3:nth-child(3) {
      color: var(--text2);

      font-size: 14px;
    }

    #navPart2 {
      display: flex;
      align-items: center;
      gap: 30px;
    }

    #nav-links {
      display: flex;
      gap: 28px;
    }

    #nav-links a {
      color: var(--text2);

      text-decoration: none;

      font-size: 13px;

      letter-spacing: .08em;

      text-transform: uppercase;

      transition: .3s;
    }

    #nav-links a:hover {
      color: var(--accent);
    }

    #icon {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    #icon i {
      font-size: 20px;

      color: var(--text2);

      transition: .3s;
    }

    #icon i:hover {
      color: var(--accent);
    }

    #menuicon {
      display: none;
    }

    /* CONTENT */

    .content-wrapper {
      position: relative;
      z-index: 2;

      width: 100%;

      padding-top: 80px;
    }

    /* HERO */

    .page-header {
      padding: 140px 50px 70px;

      max-width: 1500px;

      margin: auto;

      position: relative;
    }

    .page-header::after {
      content: '';

      position: absolute;

      width: 700px;
      height: 700px;

      background:
        radial-gradient(circle,
          rgba(255, 117, 24, .12),
          transparent 70%);

      top: -280px;
      left: 50%;

      transform: translateX(-50%);

      z-index: -1;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 12px;

      font-size: 11px;

      letter-spacing: .14em;

      text-transform: uppercase;

      color: var(--text2);

      margin-bottom: 26px;
    }

    .breadcrumb a {
      color: var(--text2);

      text-decoration: none;
    }

    .breadcrumb a:hover {
      color: var(--accent);
    }

    .page-title {
      font-family: var(--font-display);

      font-weight: 800;

      font-size: clamp(60px, 10vw, 130px);

      line-height: .88;

      letter-spacing: -.06em;

      margin-bottom: 22px;
    }

    .page-title .accent {
      color: var(--accent);
    }

    .page-subtitle {
      max-width: 720px;

      color: var(--text2);

      font-size: 17px;

      line-height: 1.9;
    }

    /* FORM LAYOUT */

    .form-container {
      max-width: 1500px;

      margin: auto;

      padding: 20px 50px 100px;

      display: grid;

      grid-template-columns: 1fr 1fr;

      gap: 60px;
    }

    /* PANELS */

    .form-panel,
    .preview-panel {
      animation: fadeUp 1s ease;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* FORM PANEL */

    .form-panel {
      background: rgba(15, 17, 23, .82);

      backdrop-filter: blur(24px);

      border: 1px solid var(--border);

      border-radius: 32px;

      padding: 48px;

      position: relative;

      overflow: hidden;

      box-shadow:
        0 20px 80px rgba(0, 0, 0, .4);
    }

    .form-panel::before {
      content: '';

      position: absolute;
      inset: 0;

      background:
        linear-gradient(135deg,
          rgba(255, 117, 24, .08),
          transparent 30%,
          transparent 70%,
          rgba(124, 106, 247, .05));

      pointer-events: none;
    }

    .form-header {
      margin-bottom: 36px;
    }

    .form-header h2 {
      font-family: var(--font-display);

      font-size: 34px;

      display: flex;
      align-items: center;
      gap: 12px;

      margin-bottom: 12px;
    }

    .form-header h2 i {
      color: var(--accent);
    }

    .form-header p {
      color: var(--text2);

      line-height: 1.8;
    }

    /* FORM */

    .form-group {
      margin-bottom: 28px;
    }

    .form-group label {
      display: flex;
      align-items: center;
      gap: 10px;

      margin-bottom: 12px;

      font-size: 11px;

      letter-spacing: .12em;

      text-transform: uppercase;

      color: var(--text2);

      font-weight: 700;
    }

    .form-group label i {
      color: var(--accent);
    }

    .form-control {
      width: 100%;

      padding: 18px 20px;

      background: rgba(255, 255, 255, .03);

      border: 1px solid rgba(255, 255, 255, .06);

      border-radius: 18px;

      color: var(--text);

      font-size: 15px;

      transition: .3s;

      backdrop-filter: blur(8px);
    }

    .form-control:focus {
      outline: none;

      border-color: var(--accent);

      box-shadow:
        0 0 0 4px rgba(255, 117, 24, .12),
        0 0 40px rgba(255, 117, 24, .15);

      transform: translateY(-1px);
    }

    .form-control::placeholder {
      color: #777;
    }

    textarea.form-control {
      min-height: 140px;

      resize: vertical;
    }

    /* COLOR */

    .color-picker-wrapper {
      display: flex;
      align-items: center;
      gap: 16px;

      padding: 16px;

      background: rgba(255, 255, 255, .03);

      border: 1px solid rgba(255, 255, 255, .06);

      border-radius: 18px;
    }

    input[type="color"] {
      width: 58px;
      height: 58px;

      border: none;

      border-radius: 16px;

      background: none;
    }

    .color-value {
      font-family: var(--font-display);

      font-size: 22px;

      color: var(--accent);
    }

    /* BUTTON */

    .btn-create {
      width: 100%;

      height: 64px;

      border: none;

      border-radius: 20px;

      background:
        linear-gradient(135deg,
          #ff7518,
          #ff944d);

      color: #050505;

      font-family: var(--font-display);

      font-size: 14px;

      font-weight: 800;

      letter-spacing: .08em;

      text-transform: uppercase;

      position: relative;

      overflow: hidden;

      transition: .35s;

      box-shadow:
        0 10px 40px rgba(255, 117, 24, .25);
    }

    .btn-create:hover {
      transform: translateY(-4px);

      box-shadow:
        0 20px 60px rgba(255, 117, 24, .35);
    }

    .btn-create::before {
      content: '';

      position: absolute;

      top: 0;
      left: -100%;

      width: 100%;
      height: 100%;

      background:
        linear-gradient(90deg,
          transparent,
          rgba(255, 255, 255, .35),
          transparent);

      transition: .6s;
    }

    .btn-create:hover::before {
      left: 100%;
    }

    /* PREVIEW */

    .preview-header {
      margin-bottom: 22px;
    }

    .preview-header h3 {
      font-family: var(--font-display);

      font-size: 36px;

      margin-bottom: 10px;
    }

    .preview-header p {
      color: var(--text2);
    }

    .preview-card {
      background:
        linear-gradient(180deg,
          rgba(255, 255, 255, .03),
          rgba(255, 255, 255, .01));

      border: 1px solid rgba(255, 255, 255, .06);

      backdrop-filter: blur(24px);

      border-radius: 32px;

      padding: 40px;

      position: relative;

      overflow: hidden;

      box-shadow:
        0 20px 80px rgba(0, 0, 0, .45);
    }

    .preview-tag {
      position: absolute;

      top: 20px;
      right: 20px;

      padding: 8px 16px;

      border-radius: 100px;

      background: rgba(255, 117, 24, .12);

      border: 1px solid rgba(255, 117, 24, .18);

      color: var(--accent);

      font-size: 11px;

      letter-spacing: .08em;

      text-transform: uppercase;
    }

    /* PHONE */

    .phone-frame {
      width: 360px;
      height: 620px;

      margin: auto;

      background: #000;

      border-radius: 42px;

      border: 14px solid #1a1a2e;

      overflow: hidden;

      position: relative;

      animation: floatPhone 6s ease-in-out infinite;

      box-shadow:
        0 30px 100px rgba(0, 0, 0, .5);
    }

    @keyframes floatPhone {
      0% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-10px);
      }

      100% {
        transform: translateY(0);
      }
    }

    .phone-notch {
      position: absolute;

      top: 0;
      left: 50%;

      transform: translateX(-50%);

      width: 150px;
      height: 30px;

      background: #1a1a2e;

      border-bottom-left-radius: 18px;
      border-bottom-right-radius: 18px;

      z-index: 10;
    }

    /* CHAT */

    .chat-widget {
      height: 100%;

      display: flex;
      flex-direction: column;

      background: white;
    }

    .chat-header {
      padding: 20px 24px;

      color: white;

      display: flex;
      align-items: center;
      gap: 14px;
    }

    .chat-avatar {
      width: 46px;
      height: 46px;

      border-radius: 50%;

      background: rgba(255, 255, 255, .2);

      display: flex;
      align-items: center;
      justify-content: center;
    }

    .chat-name {
      font-family: var(--font-display);

      font-size: 16px;

      font-weight: 700;
    }

    .chat-status {
      font-size: 12px;

      opacity: .85;

      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-dot {
      width: 7px;
      height: 7px;

      border-radius: 50%;

      background: #10b981;

      animation: pulse 2s infinite;
    }

    .chat-body {
      flex: 1;

      padding: 20px;

      background: #f8fafc;

      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .message {
      max-width: 85%;

      padding: 14px 18px;

      border-radius: 20px;

      font-size: 14px;

      line-height: 1.6;
    }

    .message-bot {
      background: white;

      color: #111827;

      border-bottom-left-radius: 6px;

      box-shadow:
        0 2px 10px rgba(0, 0, 0, .06);
    }

    .chat-input-area {
      padding: 16px;

      background: white;

      border-top: 1px solid #e5e7eb;

      display: flex;
      gap: 10px;
    }

    .chat-input-area input {
      flex: 1;

      padding: 14px 18px;

      border: 1px solid #e5e7eb;

      border-radius: 20px;
    }

    .send-btn {
      width: 50px;
      height: 50px;

      border: none;

      border-radius: 50%;

      color: white;

      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* STATS */

    .ai-stats {
      display: grid;

      grid-template-columns: repeat(3, 1fr);

      gap: 16px;

      margin-top: 24px;
    }

    .stat-box {
      background: rgba(255, 255, 255, .03);

      border: 1px solid rgba(255, 255, 255, .05);

      border-radius: 20px;

      padding: 22px;

      text-align: center;

      backdrop-filter: blur(20px);
    }

    .stat-box h4 {
      font-size: 30px;

      font-family: var(--font-display);

      color: var(--accent);

      margin-bottom: 6px;
    }

    .stat-box p {
      color: var(--text2);

      font-size: 13px;
    }

    /* MOBILE */

    @media(max-width:1024px) {

      .form-container {
        grid-template-columns: 1fr;
      }

      .preview-panel {
        order: -1;
      }
    }

    @media(max-width:768px) {

      body {
        cursor: auto;
      }

      #cur,
      #cur-ring {
        display: none !important;
      }

      #nav {
        padding: 0 20px;
        height: 70px;
      }

      #nav-links {
        display: none;
      }

      #menuicon {
        display: block;
      }

      .content-wrapper {
        padding-top: 70px;
      }

      .page-header {
        padding: 110px 20px 40px;
      }

      .form-container {
        padding: 20px 20px 70px;
      }

      .form-panel {
        padding: 28px;
      }

      .preview-card {
        padding: 26px;
      }

      .phone-frame {
        width: 100%;
        max-width: 320px;
        height: 560px;
      }

      .page-title {
        font-size: 62px;
      }

      .preview-header h3,
      .form-header h2 {
        font-size: 28px;
      }
    }

    @media(max-width:480px) {

      .phone-frame {
        height: 520px;
      }

      .ai-stats {
        grid-template-columns: 1fr;
      }

      .links-fixed {
        padding-right: 24px;
      }

      .links-fixed a {
        font-size: 52px;
      }
    }
  </style>
</head>

<body>
  <div id="app-wrapper">
    <!-- Custom Cursor -->
    <div id="cur"></div>
    <div id="cur-ring"></div>

    <!-- Background Effects -->
    <div class="bg-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <!-- MOBILE FULLSCREEN MENU (from home page) -->
    <div id="fixediv">
      <button class="close-btn" id="closeMenu">
        <i class="ri-close-line"></i>
      </button>
      <div class="links-fixed">
        <a href="/">HOME</a>
        <a href="/about">ABOUT</a>
        <a href="/chat">Community</a>
        <a href="/pricing">PRICING</a>
        <a href="/profile">PROFILE</a>
        <a href="/bookings">BOOKINGS</a>
        <a href="/createbot">Create Bot</a>
        <a href="/logout">Logout</a>
      </div>
    </div>

    <!-- NAVBAR (from home page) -->
    <div id="nav">
      <div class="logo">
        <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
      </div>
      <div id="navPart2">
        <div id="nav-links">
          <a href="/about">About</a>
          <a href="/chat">Community</a>
          <a href="/pricing">Pricing</a>
          <a href="/profile">Profile</a>
          <a href="/bookings">Bookings</a>
          <a href="/logout">Logout</a>
        </div>
        <div id="icon">
          <i id="menuicon" class="ri-menu-line"></i>
          <i class="ri-shopping-cart-2-line"></i>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="content-wrapper">
      <!-- Page Header -->
      <div class="page-header">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span class="separator">→</span>
          <span>Create Bot</span>
        </div>
        <h1 class="page-title">Design Your <span class="accent">AI Assistant</span></h1>
        <p class="page-subtitle">Customize every detail of your chatbot. See changes in real-time as you build your
          perfect AI companion.</p>
      </div>

      <!-- Form Container -->
      <div class="form-container">
        <!-- Form Panel -->
        <div class="form-panel">
          <div class="form-header">
            <h2><i class="ri-robot-2-line"></i> Bot Configuration</h2>
            <p>Configure your chatbot's personality, appearance, and knowledge base</p>
          </div>

          <form action="/createbot" method="POST" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">
            <div class="form-group">
              <label>
                <i class="ri-robot-line"></i>
                Bot Identity
              </label>
              <input type="text" name="name" id="botName" class="form-control" placeholder="Enter your bot's name"
                value="Support Assistant" autocomplete="off" maxlength="50" required>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-price-tag-3-line"></i>
                Bot Category
              </label>
              <select name="category" class="form-control" required>
                <option value="customer-support" selected>Customer Support</option>
                <option value="sales">Sales Assistant</option>
                <option value="faq">FAQ Bot</option>
                <option value="lead-generation">Lead Generation</option>
                <option value="ecommerce">E-commerce Assistant</option>
                <option value="technical">Technical Support</option>
                <option value="booking">Booking Assistant</option>
                <option value="product-advisor">Product Advisor</option>
                <option value="marketing">Marketing Assistant</option>
                <option value="hr">HR Assistant</option>
                <option value="education">Education Assistant</option>
                <option value="healthcare">Healthcare Assistant</option>
              </select>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-palette-line"></i>
                Theme Color
              </label>
              <div class="color-picker-wrapper">
                <input type="color" id="botColor" name="color" value="#ff7518" required>
                <div class="color-info">
                  <span class="color-label">Primary accent color</span>
                  <div class="color-value" id="colorValue">#ff7518</div>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-global-line"></i>
                Website Integration
              </label>
              <input type="url" name="websiteUrl" class="form-control" placeholder="https://yourwebsite.com"
                autocomplete="url">
            </div>

            <div class="form-group">
              <label>
                <i class="ri-chat-1-line"></i>
                Welcome Message
              </label>
              <textarea name="welcomeMessage" id="welcomeMessage" class="form-control"
                placeholder="The first message your bot will greet visitors with" rows="3" maxlength="300"
                required>Hello 👋 How can I help you today?</textarea>
            </div>

            <div class="form-group">
              <label>
                <i class="ri-brain-line"></i>
                Training Knowledge
              </label>
              <textarea name="knowledge" class="form-control" placeholder="Teach your bot important information about your business&#10;&#10;Example:&#10;• Refund
  policy: 7 days from purchase&#10;• Delivery time: 3-5 business days&#10;• Support hours: 9am - 6pm EST" rows="5"
                maxlength="2000"></textarea>
            </div>

            <button type="submit" class="btn-create" id="submitBtn">
              <i class="ri-rocket-2-line"></i>
              <span>Create Your Bot</span>
            </button>
          </form>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel">
          <div class="preview-header">
            <h3>Live Preview</h3>
            <p>Watch your chatbot come to life in real-time</p>
          </div>

          <div class="preview-card">
            <span class="preview-tag">Interactive</span>
            <div class="phone-frame">
              <div class="phone-notch"></div>
              <div class="chat-widget">
                <div class="chat-header" id="previewHeader">
                  <div class="chat-avatar">
                    <i class="ri-robot-line"></i>
                  </div>
                  <div class="chat-info">
                    <div class="chat-name" id="previewName">Support Assistant</div>
                    <div class="chat-status">
                      <span class="status-dot"></span>
                      Online
                    </div>
                  </div>
                </div>
                <div class="chat-body">
                  <div class="message message-bot" id="previewMessage">
                    Hello 👋 How can I help you today?
                  </div>
                </div>
                <div class="chat-input-area">
                  <input type="text" placeholder="Type your message..." readonly>
                  <button class="send-btn" type="button">
                    <i class="ri-send-plane-fill"></i>
                  </button>
                </div>
              </div>
            </div>
            <div class="live-indicator">
              <span class="live-dot"></span>
              Changes update instantly
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Mobile menu toggle - from home page
    const mobileMenuBtn = document.getElementById('menuicon');
    const mobileMenu = document.getElementById('fixediv');
    const closeMobileMenuBtn = document.getElementById('closeMenu');

    if (mobileMenuBtn && mobileMenu && closeMobileMenuBtn) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.add('open');
      });

      closeMobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
      });

      // Close menu when clicking on links
      document.querySelectorAll('.links-fixed a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
        });
      });

      // Close menu on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
          mobileMenu.classList.remove('open');
        }
      });
    }

    // Custom cursor animation (only on desktop)
    if (window.matchMedia('(pointer: fine)').matches) {
      const cur = document.getElementById('cur');
      const ring = document.getElementById('cur-ring');
      let mx = 0, my = 0, rx = 0, ry = 0;

      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
      });

      (function animateRing() {
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(animateRing);
      })();
    }

    // Navbar scroll effect
    const nav = document.getElementById('nav');
    const handleScroll = () => {
      if (window.scrollY > 60) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Form inputs - live preview updates with debouncing
    const nameInput = document.getElementById('botName');
    const colorInput = document.getElementById('botColor');
    const messageInput = document.getElementById('welcomeMessage');

    const previewName = document.getElementById('previewName');
    const previewHeader = document.getElementById('previewHeader');
    const previewMessage = document.getElementById('previewMessage');
    const colorValueDisplay = document.getElementById('colorValue');
    const sendBtn = document.querySelector('.send-btn');

    // Initialize with default color
    const defaultColor = colorInput.value;
    previewHeader.style.background = defaultColor;
    if (sendBtn) {
      sendBtn.style.background = defaultColor;
    }
    colorValueDisplay.textContent = defaultColor;

    // Debounced update functions
    const debounce = (func, wait) => {
      let timeout;
      return function executedFunction(...args) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    };

    const updateName = debounce(() => {
      const name = nameInput.value.trim() || 'Support Assistant';
      previewName.textContent = name;
    }, 100);

    const updateColor = debounce(() => {
      const color = colorInput.value;
      previewHeader.style.background = color;
      if (sendBtn) {
        sendBtn.style.background = color;
      }
      colorValueDisplay.textContent = color;
    }, 100);

    const updateMessage = debounce(() => {
      const message = messageInput.value.trim() || 'Hello 👋 How can I help you today?';
      previewMessage.textContent = message;
    }, 100);

    nameInput.addEventListener('input', updateName);
    colorInput.addEventListener('input', updateColor);
    messageInput.addEventListener('input', updateMessage);

    // Send button animation
    const sendButton = document.querySelector('.send-btn');
    if (sendButton) {
      sendButton.addEventListener('click', function () {
        this.style.transform = 'scale(0.9)';
        setTimeout(() => {
          this.style.transform = 'scale(1)';
        }, 150);
      });
    }

    // Form submission enhancement
    const form = document.querySelector('form');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', function (e) {
      const originalContent = submitBtn.innerHTML;
      submitBtn.innerHTML = '<i class="ri-loader-4-line ri-spin"></i><span>Creating...</span>';
      submitBtn.style.pointerEvents = 'none';

      // Form will submit normally, but button stays disabled temporarily
      setTimeout(() => {
        if (document.body.contains(submitBtn)) {
          submitBtn.innerHTML = originalContent;
          submitBtn.style.pointerEvents = '';
        }
      }, 5000);
    });

    // Color picker hover effect (desktop only)
    if (window.matchMedia('(pointer: fine)').matches) {
      const colorWrapper = document.querySelector('.color-picker-wrapper');
      colorWrapper.addEventListener('mouseenter', () => {
        colorInput.style.transform = 'scale(1.02)';
      });
      colorWrapper.addEventListener('mouseleave', () => {
        colorInput.style.transform = 'scale(1)';
      });
    }

    // Prevent zoom on input focus in iOS
    let viewport = document.querySelector('meta[name="viewport"]');
    const originalViewportContent = viewport.getAttribute('content');

    document.querySelectorAll('input, textarea, select').forEach(element => {
      element.addEventListener('focus', () => {
        if (window.innerWidth <= 768) {
          viewport.setAttribute('content', 'width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no');
        }
      });

      element.addEventListener('blur', () => {
        viewport.setAttribute('content', originalViewportContent);
      });
    });

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      if (mobileMenu && mobileMenu.classList.contains('open')) {
        mobileMenu.classList.remove('open');
      }
    });

    // Resize handler
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        // Close mobile menu on resize to desktop
        if (window.innerWidth > 768 && mobileMenu.classList.contains('open')) {
          mobileMenu.classList.remove('open');
        }
      }, 250);
    });

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      // Close mobile menu if navigating back
      window.addEventListener('pageshow', (event) => {
        if (event.persisted) {
          mobileMenu.classList.remove('open');
        }
      });

      // Set initial viewport for mobile
      if (window.innerWidth <= 768) {
        const vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty('--vh', `${vh}px`);
      }
    });
  </script>
</body>

</html>