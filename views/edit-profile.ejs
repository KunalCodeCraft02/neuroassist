<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">
    <title>Edit Profile — NeuroAssist Co</title>
    <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">
    <style>
        :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:28px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
    overflow-x:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow-x:hidden;
    min-height:100vh;

    cursor:none;

    position:relative;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.16),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur{
    position:fixed;

    width:8px;
    height:8px;

    background:var(--accent);

    border-radius:50%;

    pointer-events:none;

    z-index:99999;

    transform:translate(-50%,-50%);

    transition:
        width .25s,
        height .25s,
        background .25s;

    mix-blend-mode:screen;
}

#cur-ring{
    position:fixed;

    width:34px;
    height:34px;

    border:1px solid rgba(124,106,247,.4);

    border-radius:50%;

    pointer-events:none;

    z-index:99998;

    transform:translate(-50%,-50%);
}

body:has(a:hover) #cur,
body:has(button:hover) #cur,
body:has(input:hover) #cur,
body:has(select:hover) #cur,
body:has(textarea:hover) #cur{
    width:16px;
    height:16px;

    background:var(--accent2);
}

/* NAVBAR */

#nav{
    height:78px;

    position:fixed;
    inset:0 0 auto 0;

    z-index:1000;

    display:flex;
    align-items:center;
    justify-content:space-between;

    padding:0 40px;

    background:rgba(10,12,16,.82);

    backdrop-filter:blur(22px);

    border-bottom:1px solid var(--border);
}

.logo{
    display:flex;
    align-items:baseline;
    gap:4px;

    text-decoration:none;
}

.logo h3{
    font-size:22px;
    font-weight:700;
    letter-spacing:-.02em;
}

.logo h3:nth-child(2){
    color:var(--accent);
}

.logo h3:nth-child(3){
    color:var(--text2);
    font-size:14px;
}

#nav-links{
    display:flex;
    align-items:center;
    gap:24px;
}

#nav-links a{
    color:var(--text2);

    text-decoration:none;

    font-size:13px;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.3s;
}

#nav-links a:hover{
    color:var(--accent);
}

/* MAIN */

#main{
    padding:130px 20px 80px;

    position:relative;
    z-index:2;
}

.container{
    max-width:760px;
    margin:auto;
}

/* BACK */

.back-btn{
    display:inline-flex;
    align-items:center;
    gap:8px;

    color:var(--text2);

    text-decoration:none;

    margin-bottom:28px;

    transition:.3s;
}

.back-btn:hover{
    color:var(--accent);
}

/* HEADER */

.page-header{
    margin-bottom:40px;
}

.page-title{
    font-family:var(--font-display);

    font-size:clamp(58px,8vw,110px);

    line-height:.9;

    letter-spacing:-.05em;

    font-weight:400;

    margin-bottom:16px;
}

.page-subtitle{
    color:var(--text2);

    font-size:16px;

    line-height:1.9;

    max-width:580px;
}

/* FORM CARD */

.form-card{
    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:34px;

    padding:44px;

    position:relative;
    overflow:hidden;

    box-shadow:
        0 20px 80px rgba(124,106,247,.08);
}

.form-card::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );
}

/* PROFILE SECTION */

.profile-section{
    text-align:center;

    padding-bottom:34px;

    margin-bottom:34px;

    border-bottom:1px solid var(--border);
}

.profile-img-wrapper{
    position:relative;

    display:inline-block;
}

.profile-img{
    width:130px;
    height:130px;

    object-fit:cover;

    border-radius:50%;

    border:3px solid var(--accent);

    box-shadow:
        0 0 40px rgba(124,106,247,.25);

    transition:.35s;
}

.profile-img:hover{
    transform:scale(1.04);
}

.upload-label{
    margin-top:18px;

    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:10px;

    padding:12px 22px;

    border-radius:100px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    color:var(--accent);

    font-size:12px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;
}

.upload-label:hover{
    transform:translateY(-2px);

    background:rgba(124,106,247,.2);
}

#photo{
    display:none;
}

/* FORM */

.form-group{
    margin-bottom:24px;
}

.form-group label{
    display:block;

    margin-bottom:10px;

    color:var(--text2);

    font-size:11px;

    letter-spacing:.08em;

    text-transform:uppercase;

    font-family:var(--font-mono);
}

.form-group input,
.form-group textarea,
.form-group select{
    width:100%;

    padding:16px 18px;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:18px;

    color:var(--text);

    font-size:14px;

    font-family:var(--font-sans);

    transition:.3s;

    outline:none;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus{
    border-color:var(--border2);

    box-shadow:
        0 0 0 4px rgba(124,106,247,.08);
}

.form-group textarea{
    min-height:140px;

    resize:vertical;

    line-height:1.8;
}

.form-group input::placeholder,
.form-group textarea::placeholder{
    color:var(--muted);
}

.form-group select{
    appearance:none;

    background-image:
        linear-gradient(45deg, transparent 50%, var(--accent) 50%),
        linear-gradient(135deg, var(--accent) 50%, transparent 50%);

    background-position:
        calc(100% - 20px) calc(50% - 3px),
        calc(100% - 14px) calc(50% - 3px);

    background-size:6px 6px;

    background-repeat:no-repeat;
}

/* BUTTON */

.submit-btn{
    width:100%;

    margin-top:20px;

    padding:18px;

    border:none;

    border-radius:20px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.28);
}

.submit-btn:hover{
    transform:translateY(-4px);

    box-shadow:
        0 16px 40px rgba(124,106,247,.38);
}

/* FOOTER */

.footer{
    border-top:1px solid var(--border);

    background:rgba(15,17,23,.35);

    backdrop-filter:blur(18px);
}

.footer-content{
    max-width:1300px;

    margin:auto;

    padding:70px 40px;

    display:grid;

    grid-template-columns:
        1.4fr 1fr 1fr 1fr;

    gap:40px;
}

.footer-logo h1{
    font-family:var(--font-display);

    font-size:40px;

    font-weight:400;
}

.footer-logo span{
    color:var(--accent);
}

.footer-desc{
    color:var(--text2);

    line-height:1.9;

    margin-top:16px;

    max-width:320px;
}

.footer-menu-name,
.footer-call-to-action-title{
    font-size:11px;

    letter-spacing:.12em;

    text-transform:uppercase;

    color:var(--text2);

    margin-bottom:20px;
}

.footer-menu-list{
    list-style:none;

    display:flex;
    flex-direction:column;
    gap:14px;
}

.footer-menu-list a{
    color:var(--text);

    opacity:.7;

    text-decoration:none;

    transition:.3s;
}

.footer-menu-list a:hover{
    opacity:1;

    color:var(--accent);
}

.footer-call-to-action-button{
    display:inline-flex;
    align-items:center;
    justify-content:center;

    padding:14px 24px;

    border-radius:100px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    text-decoration:none;

    font-size:12px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.3s;
}

.footer-call-to-action-button:hover{
    transform:translateY(-3px);
}

.footer-copyright{
    border-top:1px solid var(--border);

    padding:22px;

    text-align:center;
}

.footer-copyright-text{
    color:var(--text2);

    font-size:13px;
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none;
    }

    #nav{
        padding:0 20px;
    }

    #nav-links{
        display:none;
    }

    #menuicon{
        display:block;
        font-size:22px;
    }

    .form-card{
        padding:30px 22px;
        border-radius:28px;
    }

    .page-title{
        font-size:66px;
    }

    .profile-img{
        width:110px;
        height:110px;
    }

    .footer-content{
        grid-template-columns:1fr;

        padding:50px 20px;
    }
}
    </style>
</head>

<body>
    <!-- Custom Cursor -->
    <div id="cur"></div>
    <div id="cur-ring"></div>

    <!-- NAVBAR -->
    <div id="nav">
        <a href="/" class="logo">
             <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
        </a>
        <div id="navPart2">
            <div id="nav-links">
                <a href="/about">About</a>
                <a href="/chat">Community</a>
                <a href="/profile">Profile</a>
                <a href="/bookings">Bookings</a>
                <a href="/logout">Logout</a>
            </div>
            <div id="icon">
                <i id="menuicon" class="ri-menu-line"></i>
                <i class="ri-shopping-cart-2-line"></i>
            </div>
        </div>
    </div>

    <!-- MOBILE MENU -->
    <div id="fixediv">
        <button class="close-btn" id="closeMenu">
            <i class="ri-close-line"></i>
        </button>
        <div class="links-fixed">
            <a href="/">HOME</a>
            <a href="/about">ABOUT</a>
            <a href="/profile">PROFILE</a>
            <a href="/contact">CONTACT</a>
            <a href="/bookings">BOOKINGS</a>
            <a href="/logout">Logout</a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div id="main">
        <div class="container">
            <!-- Back Button -->
            <a href="/profile" class="back-btn">
                <i class="ri-arrow-left-line"></i>
                Back to Profile
            </a>

            <!-- Page Header -->
            <div class="page-header">
                <h1 class="page-title">Edit Profile</h1>
                <p class="page-subtitle">Customize your profile information and preferences</p>
            </div>

            <!-- Form Card -->
            <div class="form-card">
                <form action="/update-profile" method="POST" enctype="multipart/form-data">
                  <input type="hidden" name="_csrf" value="<%= csrfToken ? csrfToken() : '' %>">
                    <!-- Profile Image -->
                    <div class="profile-section">
                        <div class="profile-img-wrapper">
                            <img src="<%= user.photo || 'https://via.placeholder.com/120/ff7518/04040a?text=N' %>"
                                alt="Profile" class="profile-img">
                        </div>
                        <label for="photo" class="upload-label">
                            <i class="ri-camera-line"></i>
                            Change Photo
                        </label>
                        <input type="file" name="photo" id="photo" accept="image/*">
                    </div>

                    <!-- Role -->
                    <div class="form-group">
                        <label for="role">Role</label>
                        <select name="role" id="role" onchange="toggleLinkedin()">
                            <option value="" disabled <%=!user.role ? 'selected' : '' %>>Select Role</option>
                            <option value="Student" <%=user.role==="Student" ? "selected" : "" %>>Student</option>
                            <option value="Developer" <%=user.role==="Developer" ? "selected" : "" %>>Developer</option>
                            <option value="Business" <%=user.role==="Business" ? "selected" : "" %>>Business</option>
                        </select>
                    </div>

                    <!-- Bio -->
                    <div class="form-group">
                        <label for="bio">Bio</label>
                        <textarea name="bio" id="bio"
                            placeholder="Tell us about yourself..."><%= user.bio || "" %></textarea>
                    </div>

                    <!-- Skills -->
                    <div class="form-group">
                        <label for="skills">Skills</label>
                        <input type="text" name="skills" id="skills"
                            placeholder="e.g. React, Node.js, AI, Machine Learning" value="<%= user.skills || "" %>">
                    </div>

                    <!-- GitHub -->
                    <div class="form-group">
                        <label for="github">GitHub</label>
                        <input type="text" name="github" id="github" placeholder="https://github.com/username"
                            value="<%=user.github || "" %>">
                    </div>
                    <% const showLinkedIn=user && user.role==='Business' ; %>

                        <div class="form-group" id="linkedinBox" style="<%= showLinkedIn ? '' : 'display: none;' %>">
                            <label for="linkedin">LinkedIn</label>
                            <input type="text" name="linkedin" id="linkedin"
                                placeholder="https://linkedin.com/in/username"
                                value="<%= user && user.linkedin ? user.linkedin : '' %>">
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="submit-btn">Save Changes</button>
                </form>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="pg-footer">
        <footer class="footer">
            <div class="footer-content">
                <div class="footer-content-column">
                    <div class="footer-logo">
                        <a class="footer-logo-link" href="/">
                            <span class="hidden-link-text">LOGO</span>
                            <h1>Neuro<span>Assist</span></h1>
                        </a>
                    </div>
                    <p class="footer-desc">The AI platform for building smart chatbots that work for your business
                        around the
                        clock.</p>
                </div>

                <div class="footer-content-column">
                    <div class="footer-menu">
                        <h2 class="footer-menu-name">Get Started</h2>
                        <ul class="footer-menu-list">
                            <li><a href="/about">About</a></li>
                            <li><a href="/profile">Profile</a></li>
                            <li><a href="/bookings">Bookings</a></li>
                        </ul>
                    </div>
                </div>

                <div class="footer-content-column">
                    <div class="footer-menu">
                        <h2 class="footer-menu-name">Legal</h2>
                        <ul class="footer-menu-list">
                            <li><a href="#">Privacy Policy</a></li>
                            <li><a href="#">Terms of Service</a></li>
                        </ul>
                    </div>
                </div>

                <div class="footer-content-column">
                    <div class="footer-call-to-action">
                        <h2 class="footer-call-to-action-title">Let's Chat</h2>
                        <p class="footer-call-to-action-description">Have a support question?</p>
                        <a class="footer-call-to-action-button" href="/contact">Get in Touch</a>
                    </div>
                    <div class="footer-call-to-action" style="margin-top:28px">
                        <h2 class="footer-call-to-action-title">You Call Us</h2>
                        <p class="footer-call-to-action-link-wrapper">
                            <a class="footer-call-to-action-link" href="tel:0124-64XXXX">0124-64XXXX</a>
                        </p>
                    </div>
                </div>
            </div>

            <div class="footer-copyright">
                <p class="footer-copyright-text">
                    ©2025 NeuroAssist Co. All rights reserved.
                </p>
            </div>
        </footer>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

    <script>
        // ── Custom cursor ──
        const cur = document.getElementById('cur');
        const ring = document.getElementById('cur-ring');
        let mx = 0, my = 0, rx = 0, ry = 0;
        document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
        (function ani() {
            cur.style.left = mx + 'px'; cur.style.top = my + 'px';
            rx += (mx - rx) * .13; ry += (my - ry) * .13;
            ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
            requestAnimationFrame(ani);
        })();

        // ── Navbar scroll ──
        window.addEventListener('scroll', () => {
            document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
        });

        // ── Mobile menu ──
        const menuBtn = document.getElementById('menuicon');
        const closeBtn = document.getElementById('closeMenu');
        const menuDiv = document.getElementById('fixediv');

        menuBtn.addEventListener('click', () => {
            menuDiv.classList.add('open');
        });

        closeBtn.addEventListener('click', () => {
            menuDiv.classList.remove('open');
        });

        menuDiv.addEventListener('click', (e) => {
            if (e.target === menuDiv) {
                menuDiv.classList.remove('open');
            }
        });

        // ── LinkedIn field toggle ──
        function toggleLinkedin() {
            const role = document.getElementById("role").value;
            const linkedinBox = document.getElementById("linkedinBox");
            if (role === "Business") {
                linkedinBox.style.display = "block";
            } else {
                linkedinBox.style.display = "none";
            }
        }

        // Run on load
        toggleLinkedin();

        // ── File input preview ──
        document.getElementById('photo').addEventListener('change', function (e) {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.querySelector('.profile-img').src = e.target.result;
                }
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
</body>

</html>