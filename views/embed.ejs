<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Embed Your Bot</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
    rel="stylesheet" />
  <style>
    :root{
    --bg:#0a0c10;
    --surface:#0f1117;
    --surface2:#14161e;
    --surface3:#1a1d28;

    --accent:#7c6af7;
    --accent2:#5bf0c0;

    --accent-dim:rgba(124,106,247,.14);
    --accent2-dim:rgba(91,240,192,.08);

    --text:#e8eaf0;
    --text2:#9da3b8;
    --muted:#4a5070;

    --green:#10b981;
    --red:#ef4444;
    --yellow:#f59e0b;
    --blue:#4f8ef7;

    --border:rgba(255,255,255,.06);
    --border2:rgba(124,106,247,.22);

    --radius:28px;

    --font-display:'Instrument Serif', serif;
    --font-sans:'Outfit', sans-serif;
    --font-mono:'JetBrains Mono', monospace;
}

*,
*::before,
*::after{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
    overflow-x:hidden;
}

body{
    background:var(--bg);
    color:var(--text);

    font-family:var(--font-sans);

    overflow-x:hidden;
    min-height:100vh;

    cursor:none;

    position:relative;
}

/* GRID */

body::before{
    content:'';

    position:fixed;
    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

    background-size:60px 60px;

    z-index:-2;
}

/* MESH */

body::after{
    content:'';

    position:fixed;
    inset:0;

    background:
        radial-gradient(circle at top right,
        rgba(124,106,247,.16),
        transparent 35%),

        radial-gradient(circle at bottom left,
        rgba(91,240,192,.08),
        transparent 35%);

    filter:blur(20px);

    z-index:-1;
}

/* CURSOR */

#cur{
    position:fixed;

    width:8px;
    height:8px;

    background:var(--accent);

    border-radius:50%;

    pointer-events:none;

    z-index:99999;

    transform:translate(-50%,-50%);

    transition:
        width .25s,
        height .25s,
        background .25s;

    mix-blend-mode:screen;
}

#cur-ring{
    position:fixed;

    width:34px;
    height:34px;

    border:1px solid rgba(124,106,247,.4);

    border-radius:50%;

    pointer-events:none;

    z-index:99998;

    transform:translate(-50%,-50%);
}

body:has(a:hover) #cur,
body:has(button:hover) #cur{
    width:16px;
    height:16px;

    background:var(--accent2);
}

/* NAVBAR */

#nav{
    height:78px;

    position:fixed;
    inset:0 0 auto 0;

    z-index:1000;

    display:flex;
    align-items:center;
    justify-content:space-between;

    padding:0 40px;

    background:rgba(10,12,16,.82);

    backdrop-filter:blur(22px);

    border-bottom:1px solid var(--border);
}

.logo{
    display:flex;
    align-items:baseline;
    gap:4px;

    text-decoration:none;
}

.logo h3{
    font-size:22px;
    font-weight:700;
    letter-spacing:-.02em;
}

.logo h3:nth-child(2){
    color:var(--accent);
}

.logo h3:nth-child(3){
    color:var(--text2);
    font-size:14px;
}

#navPart2{
    display:flex;
    align-items:center;
    gap:28px;
}

#nav-links{
    display:flex;
    align-items:center;
    gap:24px;
}

#nav-links a{
    color:var(--text2);

    text-decoration:none;

    font-size:13px;

    letter-spacing:.08em;

    text-transform:uppercase;

    transition:.3s;
}

#nav-links a:hover{
    color:var(--accent);
}

/* CONTENT */

.content-wrapper{
    min-height:100vh;

    display:flex;
    align-items:center;
    justify-content:center;

    padding:120px 20px 60px;

    position:relative;
    z-index:2;
}

.container{
    width:100%;
    max-width:980px;
}

/* CARD */

.embed-card{
    background:rgba(15,17,23,.82);

    backdrop-filter:blur(24px);

    border:1px solid var(--border);

    border-radius:34px;

    padding:52px;

    position:relative;
    overflow:hidden;

    box-shadow:
        0 20px 80px rgba(124,106,247,.08);
}

.embed-card::before{
    content:'';

    position:absolute;
    top:0;
    left:0;
    right:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            var(--accent),
            transparent
        );
}

/* SUCCESS */

.success-badge{
    display:inline-flex;
    align-items:center;
    gap:10px;

    padding:10px 16px;

    border-radius:100px;

    background:rgba(16,185,129,.12);

    border:1px solid rgba(16,185,129,.22);

    color:var(--green);

    font-size:12px;
    font-weight:700;

    letter-spacing:.06em;

    margin-bottom:26px;
}

/* ICON */

.embed-icon{
    width:110px;
    height:110px;

    border-radius:28px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    display:flex;
    align-items:center;
    justify-content:center;

    margin-bottom:30px;
}

.embed-icon i{
    font-size:54px;
    color:var(--accent);
}

/* TITLE */

.embed-card h1{
    font-family:var(--font-display);

    font-size:clamp(54px,8vw,110px);

    line-height:.9;

    letter-spacing:-.05em;

    font-weight:400;

    margin-bottom:20px;
}

.embed-card > p{
    color:var(--text2);

    line-height:1.9;

    font-size:16px;

    max-width:680px;

    margin-bottom:36px;
}

/* CODE */

.code-container{
    position:relative;

    margin-bottom:34px;
}

.code-box{
    background:#0d1117;

    border:1px solid var(--border);

    border-radius:22px;

    padding:30px;

    padding-top:58px;

    overflow-x:auto;

    font-family:var(--font-mono);

    color:#5bf0c0;

    line-height:1.8;

    font-size:14px;

    position:relative;
}

.code-box::before{
    content:'Embed Script';

    position:absolute;
    top:18px;
    left:20px;

    background:var(--accent-dim);

    border:1px solid var(--border2);

    color:var(--accent);

    padding:7px 12px;

    border-radius:100px;

    font-size:10px;

    letter-spacing:.08em;

    text-transform:uppercase;
}

/* BUTTON */

.copy-btn{
    margin-top:20px;

    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:10px;

    border:none;

    border-radius:18px;

    padding:16px 28px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            #9c8ef7
        );

    color:white;

    font-size:13px;
    font-weight:700;

    letter-spacing:.08em;

    text-transform:uppercase;

    cursor:pointer;

    transition:.3s;

    box-shadow:
        0 10px 30px rgba(124,106,247,.28);
}

.copy-btn:hover{
    transform:translateY(-4px);

    box-shadow:
        0 16px 40px rgba(124,106,247,.38);
}

.copy-btn.copied{
    background:linear-gradient(135deg,var(--green),#34d399);
}

/* BOT INFO */

.bot-info{
    display:flex;
    align-items:center;
    gap:18px;

    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:24px;

    padding:24px;

    margin-bottom:30px;
}

.bot-icon{
    width:72px;
    height:72px;

    border-radius:20px;

    background:
        linear-gradient(
            135deg,
            var(--accent),
            var(--blue)
        );

    display:flex;
    align-items:center;
    justify-content:center;

    color:white;

    font-size:32px;

    flex-shrink:0;
}

.bot-name{
    font-size:24px;
    font-weight:700;

    margin-bottom:6px;
}

.bot-id{
    color:var(--text2);

    font-family:var(--font-mono);

    font-size:13px;
}

/* INSTRUCTIONS */

.instructions{
    background:var(--surface2);

    border:1px solid var(--border);

    border-radius:24px;

    padding:28px;
}

.instructions h3{
    display:flex;
    align-items:center;
    gap:10px;

    font-size:24px;

    margin-bottom:20px;

    font-family:var(--font-display);

    font-weight:400;
}

.instructions h3 i{
    color:var(--accent);
}

.instructions ol{
    padding-left:20px;

    color:var(--text2);

    line-height:2;
}

.instructions li{
    margin-bottom:10px;
}

.instructions code{
    background:var(--bg);

    border:1px solid var(--border);

    padding:3px 8px;

    border-radius:8px;

    color:var(--accent);

    font-family:var(--font-mono);
}

/* SECURITY */

.security-note,
.security-warning,
.api-key-notification{
    border-radius:24px !important;

    backdrop-filter:blur(16px);
}

/* MOBILE */

@media(max-width:768px){

    body{
        cursor:auto;
    }

    #cur,
    #cur-ring{
        display:none;
    }

    #nav{
        padding:0 20px;
    }

    #nav-links{
        display:none;
    }

    .embed-card{
        padding:34px 24px;
        border-radius:28px;
    }

    .embed-card h1{
        font-size:64px;
    }

    .embed-icon{
        width:88px;
        height:88px;
    }

    .embed-icon i{
        font-size:42px;
    }

    .bot-info{
        flex-direction:column;
        text-align:center;
    }

    .copy-btn{
        width:100%;
    }

    .code-box{
        padding:22px;
        padding-top:54px;

        font-size:13px;
    }
}
  </style>
</head>

<body>
  <div id="app-wrapper">
    <!-- Custom Cursor -->
    <div id="cur"></div>
    <div id="cur-ring"></div>

    <!-- Background Effects -->
    <div class="bg-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <!-- MOBILE FULLSCREEN MENU -->
    <div id="fixediv">
      <button class="close-btn" id="closeMenu">
        <i class="ri-close-line"></i>
      </button>
      <div class="links-fixed">
        <a href="/home">HOME</a>
        <a href="/about">ABOUT</a>
        <a href="/chat">Community</a>
        <a href="/profile">PROFILE</a>
        <a href="/contact">CONTACT</a>
        <a href="/bookings">BOOKINGS</a>
        <a href="/createbot">Create Bot</a>
        <a href="/logout">Logout</a>
      </div>
    </div>

    <!-- NAVBAR -->
    <div id="nav">
      <div class="logo">
        <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
      </div>
      <div id="navPart2">
        <div id="nav-links">
          <a href="/home">Home</a>
          <a href="/about">About</a>
          <a href="/profile">Profile</a>
          <a href="/bookings">Bookings</a>
          <a href="/logout">Logout</a>
        </div>
        <div id="icon">
          <i id="menuicon" class="ri-menu-line"></i>
          <i class="ri-shopping-cart-2-line"></i>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="content-wrapper">
      <div class="container">
        <div class="embed-card">
          <div class="success-badge" id="successBadge">
            <i class="ri-checkbox-circle-fill"></i>
            Copied successfully!
          </div>

          <div class="embed-icon">
            <i class="ri-embed-line"></i>
          </div>

          <h1>Your Bot Is Ready</h1>
          <p>Copy the script below and paste it into your website before the closing <code>&lt;/body&gt;</code> tag.</p>

          <div class="code-container">
           <div class="code-box" id="scriptCode">
&lt;script
src="<%= appUrl || 'https://bemybot.in' %>/js/bot.js"
data-api="<%= appUrl || 'https://bemybot.in' %>"
data-token="<%= embedToken %>"
data-bot="<%= bot.botId %>"
data-name="<%= bot.name %>"&gt;
&lt;/script&gt;
</div>
            <button class="copy-btn" onclick="copyScript()">
              <i class="ri-file-copy-line"></i>
              <span>Copy Script</span>
            </button>
          </div>

          <% if (newlyGeneratedApiKey) { %>
            <div class="api-key-notification"
              style="background: rgba(255, 117, 24, 0.1); border: 1px solid var(--accent); border-radius: 12px; padding: 20px; margin-bottom: 24px; text-align: left;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <i class="ri-key-line" style="color: var(--accent); font-size: 24px;"></i>
                <div style="font-weight: 700; color: var(--text); font-size: 16px;">Your API Key Has Been Generated
                </div>
              </div>
              <p style="color: var(--muted); font-size: 14px; margin-bottom: 12px; line-height: 1.6;">
                Use this API key to access your bots programmatically. Save it securely — you won't see it again!
              </p>
              <div class="code-box"
                style="margin-bottom: 12px; word-break: break-all; background: #0a0a0f; border: 1px solid var(--border); padding: 16px; border-radius: 8px; font-family: 'DM Mono', monospace; color: #00ff9d; text-align: left;">
                <%= newlyGeneratedApiKey %>
              </div>
              <p style="color: var(--muted); font-size: 13px; line-height: 1.6; margin-bottom: 0;">
                <i class="ri-information-line" style="color: var(--accent);"></i>
                You can regenerate or revoke your API key anytime from your <a href="/profile"
                  style="color: var(--accent); text-decoration: none;">Account Settings</a>.
              </p>
            </div>
            <% } %>

              <div class="bot-info">
                <div class="bot-icon">
                  <i class="ri-robot-line"></i>
                </div>
                <div class="bot-details">
                  <div class="bot-name">
                    <%= bot.name %>
                  </div>
                  <div class="bot-id">Bot ID: <%= bot.botId %>
                  </div>
                  <% if (bot.authorizedDomain) { %>
                    <div class="bot-domain"
                      style="margin-top: 6px; font-size: 12px; color: #10b981; display: flex; align-items: center; gap: 4px;">
                      <i class="ri-checkbox-circle-fill"></i>
                      Active only on <%= bot.authorizedDomain %>
                    </div>
                    <% } %>
                </div>
              </div>

              <div class="instructions">
                <h3><i class="ri-information-line"></i> How to Install</h3>
                <ol>
                  <li>Copy the script above using the <strong>Copy Script</strong> button</li>
                  <li>Open your website's HTML file in a text editor</li>
                  <li>Paste the script just before the closing <code>&lt;/body&gt;</code> tag</li>
                  <li>Save the file and refresh your website</li>
                  <li>Your chatbot will appear automatically!</li>
                </ol>
              </div>

              <% if (bot.authorizedDomain) { %>
                <div class="security-note"
                  style="margin-top: 24px; padding: 16px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 12px; font-size: 14px; color: #10b981; line-height: 1.6;">
                  <i class="ri-shield-check-line"
                    style="font-size: 18px; vertical-align: middle; margin-right: 6px;"></i>
                  <strong>Domain Lock:</strong> This bot will only work on <code
                    style="background: rgba(4,4,10,0.3); padding: 2px 6px; border-radius: 4px;"><%= bot.authorizedDomain %></code>.
                  It is securely restricted and cannot be used on any other website.
                </div>
                <% } else { %>
                  <div class="security-warning"
                    style="margin-top: 24px; padding: 16px; background: rgba(255, 117, 24, 0.1); border: 1px solid var(--accent); border-radius: 12px; font-size: 14px; color: var(--accent); line-height: 1.6;">
                    <i class="ri-alert-line" style="font-size: 18px; vertical-align: middle; margin-right: 6px;"></i>
                    <strong>Notice:</strong> No domain restriction is set for this bot. For security, it's recommended
                    to specify a website URL when creating the bot. Without it, the bot can be embedded on any site.
                  </div>
                  <% } %>
        </div>
      </div>
    </div>

    <script>
      // Copy script functionality
      function copyScript() {
        const codeElement = document.getElementById("scriptCode");
        const text = codeElement.innerText.trim();

        navigator.clipboard.writeText(text).then(() => {
          const btn = document.querySelector('.copy-btn');
          const originalContent = btn.innerHTML;

          // Change button state
          btn.classList.add('copied');
          btn.innerHTML = '<i class="ri-check-line"></i><span>Copied!</span>';

          // Show success badge
          const badge = document.getElementById('successBadge');
          badge.classList.add('show');

          // Reset after 3 seconds
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = originalContent;
            badge.classList.remove('show');
          }, 3000);
        }).catch(err => {
          // Fallback for older browsers
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.left = "-9999px";
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand("copy");
          document.body.removeChild(textArea);

          // Show success message
          const btn = document.querySelector('.copy-btn');
          btn.classList.add('copied');
          btn.innerHTML = '<i class="ri-check-line"></i><span>Copied!</span>';

          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = '<i class="ri-file-copy-line"></i><span>Copy Script</span>';
          }, 3000);
        });
      }

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('menuicon');
      const mobileMenu = document.getElementById('fixediv');
      const closeMobileMenuBtn = document.getElementById('closeMenu');

      if (mobileMenuBtn && mobileMenu && closeMobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.add('open');
        });

        closeMobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
        });

        document.querySelectorAll('.links-fixed a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
          });
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
            mobileMenu.classList.remove('open');
          }
        });
      }

      // Custom cursor animation (desktop only)
      if (window.matchMedia('(pointer: fine)').matches) {
        const cur = document.getElementById('cur');
        const ring = document.getElementById('cur-ring');
        let mx = 0, my = 0, rx = 0, ry = 0;

        document.addEventListener('mousemove', e => {
          mx = e.clientX;
          my = e.clientY;
          cur.style.left = mx + 'px';
          cur.style.top = my + 'px';
        });

        (function animateRing() {
          rx += (mx - rx) * 0.13;
          ry += (my - ry) * 0.13;
          ring.style.left = rx + 'px';
          ring.style.top = ry + 'px';
          requestAnimationFrame(animateRing);
        })();
      }

      // Navbar scroll effect
      const nav = document.getElementById('nav');
      const handleScroll = () => {
        if (window.scrollY > 60) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      };

      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();

      // Initialize
      document.addEventListener('DOMContentLoaded', () => {
        window.addEventListener('pageshow', (event) => {
          if (event.persisted) {
            mobileMenu.classList.remove('open');
          }
        });
      });

      // Handle window resize
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          if (window.innerWidth > 768 && mobileMenu.classList.contains('open')) {
            mobileMenu.classList.remove('open');
          }
        }, 250);
      });
    </script>
</body>

</html>