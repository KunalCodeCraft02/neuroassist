    .footer-social-link:hover .footer-social-icon-path { fill: var(--accent); }

    .footer-copyright {
      border-top: 1px solid var(--border);
      padding: 18px 48px;
      text-align: center;
    }
    .footer-copyright-text { color: var(--muted); font-size: 12px; font-weight: 300; }
    .footer-copyright-link { color: var(--muted); text-decoration: none; }

    /* ── STACKING ── */
    #main { position: relative; z-index: 1; }
    section, .ticker, .service-section, .short-feature, .feature,
    .how-it-works, .cta-band, .pg-footer { position: relative; z-index: 1; }
    #nav { z-index: 1000; }
    .card, .container, .feature-container, .services { position: relative; z-index: 2; }

    /* ── RESPONSIVE ── */
    @media(max-width:1024px) {
      .services { grid-template-columns: 1fr 1fr; }
      .footer-content { grid-template-columns: 1fr 1fr; }
      .hero-stats { gap: 32px; }
    }
    @media(max-width:768px) {
      #nav { padding: 0 20px; }
      #nav-links { display: none; }
      #menuicon { display: block; font-size: 20px; cursor: none; }
      #page1 { padding: 0 20px; padding-top: 120px; }
      section, .short-feature, .feature, .how-it-works, .cta-band { padding: 64px 20px; }
      .services { grid-template-columns: 1fr; }
      .cards { flex-direction: column; }
      .short-feature .short-line { flex-direction: column; }
      .short-box { border-right: none !important; border-bottom: 1px solid var(--border); }
      .short-box:last-child { border-bottom: none; }
      .footer-content { grid-template-columns: 1fr 1fr; padding: 44px 20px 52px; gap: 28px; }
      .footer-copyright { padding: 18px 20px; }
      .hero-stats { flex-wrap: wrap; gap: 24px; }
    }
    @media(max-width:480px) {
      .footer-content { grid-template-columns: 1fr; }
      .hero-actions { flex-direction: column; align-items: flex-start; }
      .hero-stats { gap: 20px; }
    }
  </style>
</head>

