<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400&display=swap"
    rel="stylesheet" />
  <title>Bemybot — Build Your Bot</title>
  <style>
    /* =========================
   RESET
========================= */

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* =========================
   ROOT
========================= */

    :root {

      --bg: #07080d;
      --surface: #0f1117;
      --surface2: #141720;
      --surface3: #191d27;

      --accent: #7c6af7;
      --accent2: #5bf0c0;

      --accent-dim: rgba(124, 106, 247, .14);

      --text: #eef1ff;
      --text2: #9da3b8;
      --muted: #5f6783;

      --border: rgba(255, 255, 255, .06);
      --border2: rgba(124, 106, 247, .22);

      --font-display: 'Instrument Serif', serif;
      --font-sans: 'Outfit', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    /* =========================
   BODY
========================= */

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--text);

      font-family: var(--font-sans);

      overflow-x: hidden;

      cursor: none;
    }

    /* =========================
   CUSTOM CURSOR
========================= */

    #cur {
      position: fixed;

      width: 8px;
      height: 8px;

      border-radius: 50%;

      background: var(--accent);

      pointer-events: none;

      z-index: 99999;

      transform: translate(-50%, -50%);

      transition: .2s;

      mix-blend-mode: screen;
    }

    #cur-ring {
      position: fixed;

      width: 34px;
      height: 34px;

      border-radius: 50%;

      border: 1px solid rgba(124, 106, 247, .4);

      pointer-events: none;

      z-index: 99998;

      transform: translate(-50%, -50%);
    }

    body:has(a:hover) #cur,
    body:has(button:hover) #cur {
      width: 14px;
      height: 14px;

      background: var(--accent2);
    }

    /* =========================
   NAVBAR
========================= */

    #nav {
      position: fixed;

      top: 0;
      left: 0;

      width: 100%;
      height: 78px;

      padding: 0 48px;

      display: flex;
      align-items: center;
      justify-content: space-between;

      z-index: 9999;

      transition: .35s;

      border-bottom: 1px solid transparent;
    }

    #nav.scrolled {
      background: rgba(10, 12, 16, .86);

      backdrop-filter: blur(20px);

      border-color: var(--border);
    }

    .logo {
      display: flex;
      align-items: center;

      gap: 12px;
    }

    .logo-mark {
      width: 32px;
      height: 32px;

      border-radius: 10px;

      background:
        linear-gradient(135deg,
          var(--accent),
          var(--accent2));

      display: flex;
      align-items: center;
      justify-content: center;

      font-size: 12px;

      color: #000;

      font-family: var(--font-mono);
    }

    .logo-text {
      font-size: 24px;

      font-weight: 700;

      color: white;
    }

    .logo-text span {
      color: var(--accent);
    }

    #navPart2 {
      display: flex;
      align-items: center;

      gap: 34px;
    }

    #nav-links {
      display: flex;
      align-items: center;

      gap: 28px;
    }

    #nav-links a {
      text-decoration: none;

      color: var(--text2);

      font-size: 14px;
      font-weight: 500;

      transition: .3s;
    }

    #nav-links a:hover {
      color: white;
    }

    #icon {
      display: flex;
      align-items: center;

      gap: 18px;
    }

    #icon i {
      font-size: 20px;

      color: var(--text2);

      transition: .3s;
    }

    #icon i:hover {
      color: white;
    }

    #menuicon {
      display: none;
    }

    /* =========================
   MOBILE MENU
========================= */

    #fixediv {
      position: fixed;

      inset: 0;

      width: 100%;
      height: 100vh;

      background: rgba(8, 10, 15, .98);

      backdrop-filter: blur(22px);

      z-index: 100000;

      top: -110%;

      transition: .5s;
    }

    #fixediv.open {
      top: 0;
    }

    .links-fixed {
      height: 100%;

      display: flex;
      flex-direction: column;

      justify-content: center;
      align-items: center;

      gap: 22px;

      text-align: center;
    }

    .links-fixed a {
      text-decoration: none;

      color: white;

      font-family: var(--font-display);

      font-size:
        clamp(46px, 8vw, 82px);

      line-height: 1;

      transition: .3s;
    }

    .links-fixed a:hover {
      color: var(--accent);
    }

    .close-btn {
      position: absolute;

      top: 24px;
      right: 24px;

      background: none;
      border: none;

      color: white;

      font-size: 34px;
    }

    /* =========================
   HERO SECTION
========================= */

    #page1 {
      min-height: 100vh;

      width: 100%;

      padding:
        150px 48px 90px;

      display: grid;

      grid-template-columns:
        minmax(0, 620px) minmax(0, 1fr);

      align-items: center;

      gap: 60px;

      position: relative;

      overflow: hidden;
    }

    /* GRID */

    .grid-bg {
      position: absolute;
      inset: 0;

      background-image:
        linear-gradient(rgba(255, 255, 255, .03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .03) 1px, transparent 1px);

      background-size: 60px 60px;

      pointer-events: none;

      z-index: 0;
    }

    /* LEFT */

    .hero-content {
      position: relative;
      z-index: 2;
    }

    /* BADGE */

    .hero-badge {
      display: inline-flex;
      align-items: center;

      gap: 8px;

      border: 1px solid var(--border2);

      background: var(--accent-dim);

      padding: 7px 16px;

      border-radius: 100px;

      color: var(--accent);

      font-size: 11px;

      font-family: var(--font-mono);

      margin-bottom: 34px;
    }

    .badge-dot {
      width: 6px;
      height: 6px;

      border-radius: 50%;

      background: var(--accent2);
    }

    /* HEADING */

    #page1 h1 {
      font-family: var(--font-display);

      font-size:
        clamp(74px, 10vw, 132px);

      line-height: .88;

      letter-spacing: -.04em;
    }

    .italic-h {
      font-style: italic;

      color: var(--text2);
    }

    .grad-h {
      background:
        linear-gradient(135deg,
          var(--accent),
          var(--accent2));

      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* SUBTEXT */

    .hero-sub {
      max-width: 540px;

      margin-top: 28px;

      color: var(--text2);

      font-size: 17px;

      line-height: 1.9;
    }

    /* BUTTONS */

    .hero-actions {
      display: flex;
      align-items: center;

      gap: 16px;

      margin-top: 42px;
    }

    .btn-hero {
      text-decoration: none;

      color: white;

      padding: 15px 30px;

      border-radius: 14px;

      background:
        linear-gradient(135deg,
          var(--accent),
          #9a8af9);

      display: flex;
      align-items: center;

      gap: 10px;

      font-weight: 600;

      transition: .3s;

      box-shadow:
        0 10px 30px rgba(124, 106, 247, .28);
    }

    .btn-hero:hover {
      transform: translateY(-3px);
    }

    .btn-outline {
      text-decoration: none;

      border: 1px solid var(--border);

      color: var(--text2);

      padding: 15px 26px;

      border-radius: 14px;

      display: flex;
      align-items: center;

      gap: 10px;

      transition: .3s;
    }

    .btn-outline:hover {
      background: var(--accent-dim);

      color: white;

      border-color: var(--border2);
    }

    /* STATS */

    .hero-stats {
      display: flex;

      gap: 48px;

      margin-top: 60px;

      padding-top: 34px;

      border-top: 1px solid var(--border);
    }

    .stat-num {
      font-family: var(--font-display);

      font-size: 40px;
    }

    .stat-num span {
      color: var(--accent);
    }

    .stat-label {
      margin-top: 8px;

      color: var(--muted);

      font-size: 12px;

      font-family: var(--font-mono);
    }

    /* RIGHT SIDE */

    .hero-visual {
      position: relative;

      width: 100%;

      display: flex;
      align-items: center;
      justify-content: center;

      min-height: 700px;
    }

    .hero-image-wrap {
      width: 100%;
      max-width: 580px;

      position: relative;

      z-index: 2;
    }

    .hero-ai-image {
      width: 100%;
      height: 700px;

      object-fit: cover;

      border-radius: 34px;

      border: 1px solid var(--border);

      box-shadow:
        0 20px 80px rgba(0, 0, 0, .45),
        0 0 80px rgba(124, 106, 247, .12);

      filter:
        brightness(.88) saturate(.82);
    }

    /* GLOW */

    .hero-glow {
      position: absolute;

      width: 540px;
      height: 540px;

      border-radius: 50%;

      background:
        radial-gradient(circle,
          rgba(124, 106, 247, .22),
          transparent 70%);

      filter: blur(70px);
    }

    /* FLOATING */

    .floating-card {
      position: absolute;

      display: flex;
      align-items: center;

      gap: 14px;

      padding: 14px 18px;

      border-radius: 18px;

      background:
        rgba(15, 17, 23, .85);

      backdrop-filter: blur(18px);

      border: 1px solid var(--border);
    }

    .card-one {
      top: 40px;
      left: -40px;
    }

    .card-two {
      bottom: 40px;
      right: -30px;
    }

    .floating-card i {
      width: 42px;
      height: 42px;

      border-radius: 12px;

      background: var(--accent-dim);

      display: flex;
      align-items: center;
      justify-content: center;

      color: var(--accent);
    }

    /* =========================
   FOOTER FIX
========================= */

    .footer-content {
      max-width: 1200px;

      margin: auto;

      padding: 70px 48px;

      display: grid;

      grid-template-columns:
        1.4fr 1fr 1fr 1fr;

      gap: 48px;
    }

    .footer-menu-list {
      list-style: none;

      display: flex;
      flex-direction: column;

      gap: 12px;
    }

    .footer-menu-list a {
      text-decoration: none;

      color: var(--text2);

      transition: .3s;
    }

    .footer-menu-list a:hover {
      color: white;
    }

    /* =========================
   RESPONSIVE
========================= */

    @media(max-width:1150px) {

      #page1 {
        grid-template-columns: 1fr;

        gap: 70px;
      }

      .hero-visual {
        order: -1;
      }
    }

    @media(max-width:768px) {

      body {
        cursor: auto;
      }

      #cur,
      #cur-ring {
        display: none !important;
      }

      #nav {
        padding: 0 18px;
      }

      #nav-links {
        display: none;
      }

      #menuicon {
        display: block;
      }

      #page1 {
        grid-template-columns: 1fr;

        padding:
          120px 20px 70px;

        gap: 50px;
      }

      #page1 h1 {
        font-size: 66px;
      }

      .hero-sub {
        font-size: 15px;
      }

      .hero-actions {
        flex-direction: column;

        align-items: flex-start;
      }

      .btn-hero,
      .btn-outline {
        width: 100%;

        justify-content: center;
      }

      .hero-stats {
        flex-wrap: wrap;

        gap: 24px;
      }

      .hero-ai-image {
        height: 440px;
      }

      .footer-content {
        grid-template-columns: 1fr 1fr;

        padding: 50px 20px;
      }

      .links-fixed a {
        font-size: 58px;
      }
    }

    @media(max-width:480px) {

      #page1 {
        padding:
          110px 16px 60px;
      }

      #page1 h1 {
        font-size: 54px;
      }

      .hero-ai-image {
        height: 360px;

        border-radius: 24px;
      }

      .footer-content {
        grid-template-columns: 1fr;
      }

      .links-fixed a {
        font-size: 48px;
      }

      .hero-stats {
        gap: 18px;
      }
    }
  </style>
</head>

<body>

  <div id="cur"></div>
  <div id="cur-ring"></div>

  <!-- MOBILE MENU -->
  <div id="fixediv">
    <button class="close-btn" id="closeMenu"><i class="ri-close-line"></i></button>
    <div class="links-fixed">
      <a href="/home">HOME</a>
      <a href="/about">ABOUT</a>
      <a href="/pricing">PRICING</a>
      <a href="/profile">PROFILE</a>
      <a href="/bookings">BOOKINGS</a>
      <a href="/logout">Logout</a>
    </div>
  </div>

  <main>
    <!-- NAVBAR -->
    <div id="nav">
      <div class="logo">
        <div class="logo-mark">B/</div>
        <div class="logo-text">Bemy<span>Bot</span></div>
      </div>
      <div id="navPart2">
        <div id="nav-links">
          <a href="/home">HOME</a>
          <a href="/about">ABOUT</a>
          <a href="/pricing">PRICING</a>
          <a href="/profile">PROFILE</a>
          <a href="/bookings">BOOKINGS</a>
          <a href="/logout">LOGOUT</a>
        </div>
        <div id="icon">
          <i id="menuicon" class="ri-menu-line"></i>
          <i class="ri-shopping-cart-2-line"></i>
        </div>
      </div>
    </div>

    <div id="main">

      <!-- HERO -->
      <div id="page1">
        <div class="mesh-bg">
          <div class="mesh-blob mesh-blob-1"></div>
          <div class="mesh-blob mesh-blob-2"></div>
          <div class="mesh-blob mesh-blob-3"></div>
        </div>
        <div class="grid-bg"></div>

        <div class="hero-badge">
          <div class="badge-dot"></div>AI Bot Builder 2.0 — Now Live
        </div>

        <h1>
          <div class="line"><span>Build</span></div>
          <div class="line"><span><em class="italic-h">your</em> <span class="grad-h">Bot.</span></span></div>
        </h1>

        <p class="hero-sub">Deploy intelligent AI chatbots trained on your data — no code required. Automate support,
          leads, and bookings around the clock.</p>

        <div class="hero-actions">
          <a href="/createbot" class="btn-hero">Start Building <i class="ri-arrow-right-line"></i></a>
          <a href="/chat" class="btn-outline"><i class="ri-community-line"></i> Community</a>
        </div>

        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-num">10<span>k</span>+</div>
            <div class="stat-label">Bots deployed</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">98<span>%</span></div>
            <div class="stat-label">Uptime SLA</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">10<span>+</span></div>
            <div class="stat-label">Categories</div>
          </div>
        </div>

        <div id="videoContainer">
          <div id="play"><i class="ri-play-fill"></i></div>
          <video autoplay muted loop src="/assets/image/herovideo.mp4"></video>
        </div>

        <div class="scroll-hint">
          <div class="scroll-line"></div>
          Scroll
        </div>
      </div>

      <!-- TICKER -->
      <div class="ticker">
        <div class="ticker-track">
          <div class="ticker-item">AI Bot Builder <em>◆</em> Marketplace <em>◆</em> Lead Automation <em>◆</em> ChatGPT
            Compatible <em>◆</em> One-Line Embed <em>◆</em> 10+ Categories <em>◆</em></div>
          <div class="ticker-item">AI Bot Builder <em>◆</em> Marketplace <em>◆</em> Lead Automation <em>◆</em> ChatGPT
            Compatible <em>◆</em> One-Line Embed <em>◆</em> 10+ Categories <em>◆</em></div>
        </div>
      </div>

      <!-- SERVICES -->
      <section class="service-section reveal">
        <div class="container">
          <div style="text-align:center;">
            <div class="sec-label">What We Offer</div>
          </div>
          <h2 class="section-title" style="text-align:center; margin-bottom:60px;">
            A complete platform, built for<br><em style="font-style:italic;color:var(--text2);">human and AI
              alignment</em>
          </h2>
          <div class="services">

            <div class="card">
              <span class="card-num">01</span>
              <div class="card-img-wrap">
                <img src="https://images.unsplash.com/photo-1677094310947-c8ffdc3d3355?q=80&w=880&auto=format&fit=crop"
                  alt="AI Bot Builder" loading="lazy">
              </div>
              <h3>AI Bot Builder</h3>
              <p>Create powerful AI chatbots trained on your business data in minutes. No coding skills needed.</p>
              <a href="/createbot" class="btn">Build Your Bot <i class="ri-arrow-right-line"></i></a>
            </div>

            <div class="card">
              <span class="card-num">02</span>
              <div class="card-img-wrap">
                <img src="https://images.unsplash.com/photo-1586880244406-556ebe35f282?q=80&w=687&auto=format&fit=crop"
                  alt="AI Marketplace" loading="lazy">
              </div>
