              </div>
              <h3>Automate Calls, Leads & Bookings</h3>
              <p>Let AI handle calls, qualify leads and book appointments — even when you're offline.</p>
              <a href="/create-booking-bot" class="btn">Automate Now <i class="ri-arrow-right-line"></i></a>
            </div>

          </div>
        </div>
      </section>

      <!-- SHORT FEATURES -->
      <section class="short-feature reveal">
        <div class="short-line">
          <div class="short-box">
            <div class="short-box-icon"><i class="ri-openai-fill"></i></div>
            <h2>ChatGPT Compatible</h2>
          </div>
          <div class="short-box">
            <div class="short-box-icon"><i class="ri-settings-5-line"></i></div>
            <h2>Highly Customizable</h2>
          </div>
          <div class="short-box">
            <div class="short-box-icon"><i class="ri-book-fill"></i></div>
            <h2>10+ Categories</h2>
          </div>
        </div>
      </section>

      <!-- FEATURES TIMELINE -->
      <section class="feature reveal">
        <div class="feature-container">
          <div style="text-align:center;">
            <div class="sec-label">Capabilities</div>
          </div>
          <h2 class="feature-title">Powerful Features</h2>
          <p class="feature-subtitle">Everything you need to build and deploy AI chatbots</p>
          <div class="feature-timeline">
            <div class="feature-item">
              <div class="feature-icon"><i class="ri-window-line"></i></div>
              <div class="feature-content">
                <h3>One-Line Website Integration</h3>
                <p>Just copy and paste one script and your chatbot instantly appears on your website.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-icon"><i class="ri-brush-ai-line"></i></div>
              <div class="feature-content">
                <h3>Match Your Brand</h3>
                <p>Customize colors, theme, chatbot icon and style without writing any code.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-icon"><i class="ri-openai-line"></i></div>
              <div class="feature-content">
                <h3>Smart AI Bots</h3>
                <p>Choose from Agriculture, Finance, Education, E-commerce or create your own custom AI bot.</p>
              </div>
            </div>
            <div class="feature-item">
              <div class="feature-icon"><i class="ri-customer-service-line"></i></div>
              <div class="feature-content">
                <h3>Instant Replies</h3>
                <p>Answer customer questions, capture leads and guide visitors automatically — even when offline.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- HOW IT WORKS -->
      <section class="how-it-works reveal">
        <div class="container">
          <div class="sec-label" style="justify-content:center;">Process</div>
          <h2 class="section-title">How It Works</h2>
          <p class="section-subtitle">Building powerful chatbots has never been easier</p>
          <div class="cards">
            <div class="card">
              <div class="step-circle">01</div>
              <h3>Create Your Bot</h3>
              <p>Set up your bot in minutes with our intuitive dashboard. No coding required.</p>
            </div>
            <div class="card">
              <div class="step-circle">02</div>
              <h3>Train & Customize</h3>
              <p>Upload your content and customize your bot's behavior to match your specific needs.</p>
            </div>
            <div class="card">
              <div class="step-circle">03</div>
              <h3>Deploy & Scale</h3>
              <p>Integrate with your existing apps or websites using our API or embed script.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA BAND -->
      <div class="cta-band reveal">
        <h2>Ready to build<br><em>your first bot?</em></h2>
        <a href="/createbot" class="btn-hero">Get Started Free <i class="ri-arrow-right-line"></i></a>
      </div>

      <!-- FOOTER -->
      <div class="pg-footer">
        <footer class="footer">
          <svg class="footer-wave-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 100"
            preserveAspectRatio="none">
            <path class="footer-wave-path"
              d="M851.8,100c125,0,288.3-45,348.2-64V0H0v44c3.7-1,7.3-1.9,11-2.9C80.7,22,151.7,10.8,223.5,6.3C276.7,2.9,330,4,383,9.8 c52.2,5.7,103.3,16.2,153.4,32.8C623.9,71.3,726.8,100,851.8,100z">
            </path>
          </svg>
          <div class="footer-content">
