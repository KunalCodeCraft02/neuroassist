      padding: 80px 48px;
      text-align: center;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
      z-index: 1;
    }
    .cta-band::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 600px;
      height: 400px;
      background: radial-gradient(ellipse, rgba(124, 106, 247, 0.08) 0%, transparent 65%);
      border-radius: 50%;
      pointer-events: none;
