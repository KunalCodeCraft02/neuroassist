      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 20px;
    }

    .footer-menu-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .footer-menu-list li a {
      color: var(--text);
      text-decoration: none;
      font-size: 14px;
