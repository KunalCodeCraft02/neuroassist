      background: var(--accent-glow);
    }

    .footer-social-icon-svg {
      width: 16px;
      height: 16px;
    }

    .footer-social-icon-path {
      fill: var(--muted);
      transition: fill .3s;
    }

    .footer-social-link:hover .footer-social-icon-path {
      fill: var(--accent);
    }

