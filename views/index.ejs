<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
    rel="stylesheet" />
  <title>NeuroAssist Co — Build Your Bot</title>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #04040a;
      --surface: #09090f;
      --surface2: #0e0e18;
      --accent: #ff7518;
      --accent-glow: rgba(255, 117, 24, 0.2);
      --blue: #4f8ef7;
      --text: #eeeef5;
      --muted: #5a5a78;
      --border: rgba(255, 255, 255, 0.07);
      --radius: 16px;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
      cursor: none;
    }

    /* CURSOR */
    #cur {
      position: fixed;
      width: 10px;
      height: 10px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99999;
      transform: translate(-50%, -50%);
      transition: width .3s, height .3s;
      mix-blend-mode: difference;
    }

    #cur-ring {
      position: fixed;
      width: 38px;
      height: 38px;
      border: 1px solid rgba(255, 117, 24, .35);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99998;
      transform: translate(-50%, -50%);
      transition: transform .13s ease-out;
    }

    body:has(a:hover) #cur,
    body:has(button:hover) #cur {
      width: 18px;
      height: 18px;
    }

    /* NOISE */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: .35;
    }

    /* ─────── MOBILE FULLSCREEN MENU ─────── */
    #fixediv {
      display: none;
      height: 100vh;
      width: 100%;
      background: #04040a;
      position: fixed;
      z-index: 9999;
      top: -110%;
      transition: top 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      border-bottom: 1px solid var(--border);
    }

    #fixediv.open {
      top: 0;
    }

    .links-fixed {
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      justify-content: center;
      gap: 8px;
      padding-right: 40px;
    }

    .links-fixed a {
      color: var(--text);
      text-decoration: none;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 36px;
      letter-spacing: -0.02em;
      opacity: 0.5;
      transition: opacity .3s, color .3s;
      cursor: none;
    }

    .links-fixed a:hover {
      opacity: 1;
      color: var(--accent);
    }

    #fixediv .close-btn {
      position: absolute;
      top: 28px;
      right: 28px;
      background: none;
      border: none;
      color: var(--muted);
      font-size: 28px;
      cursor: none;
      transition: color .3s;
    }

    #fixediv .close-btn:hover {
      color: var(--text);
    }

    /* ─────── NAVBAR ─────── */
    #nav {
      height: 80px;
      width: 100%;
      position: fixed;
      z-index: 1000;
      padding: 0 50px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background .4s, border-color .4s, backdrop-filter .4s;
      border-bottom: 1px solid transparent;
    }

    #nav.scrolled {
      background: rgba(4, 4, 10, 0.88);
      backdrop-filter: blur(20px);
      border-color: var(--border);
    }

    .logo {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .logo h3 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 20px;
      letter-spacing: -0.02em;
      line-height: 1;
      color: var(--text);
    }

    .logo h3:nth-child(2) {
      color: var(--accent);
    }

    .logo h3:nth-child(3) {
      color: var(--muted);
      font-weight: 600;
      font-size: 14px;
    }

    #navPart2 {
      display: flex;
      align-items: center;
      gap: 32px;
    }

    #nav-links {
      display: flex;
      gap: 28px;
    }

    #nav-links a {
      font-size: 13px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--muted);
      transition: color .3s;
      cursor: none;
    }

    #nav-links a:hover {
      color: var(--text);
    }

    #icon {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    #icon i {
      font-size: 20px;
      color: var(--muted);
      cursor: none;
      transition: color .3s;
    }

    #icon i:hover {
      color: var(--text);
    }

    #menuicon {
      display: none;
    }

    .nav-cta-btn {
      background: var(--accent);
      color: #04040a;
      border: none;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 10px 22px;
      border-radius: 8px;
      cursor: none;
      transition: background .3s, transform .2s;
      display: none;
    }

    .nav-cta-btn:hover {
      background: #ff8c3d;
      transform: translateY(-1px);
    }

    /* ─────── PAGE 1 / HERO ─────── */
    #main {}

    #page1 {
      min-height: 100vh;
      width: 100%;
      position: relative;
      padding: 0 50px;
      padding-top: 160px;
      overflow: hidden;
    }

    /* BG grid */
    #page1::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 117, 24, .04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 117, 24, .04) 1px, transparent 1px);
      background-size: 72px 72px;
      animation: gridScroll 18s linear infinite;
    }

    @keyframes gridScroll {
      from {
        transform: translate(0, 0)
      }

      to {
        transform: translate(72px, 72px)
      }
    }

    /* Orbs */
    .orb1 {
      position: absolute;
      top: -150px;
      right: -180px;
      width: 650px;
      height: 650px;
      background: radial-gradient(circle, rgba(255, 117, 24, .12) 0%, transparent 65%);
      border-radius: 50%;
      animation: orbA 9s ease-in-out infinite alternate;
      pointer-events: none;
    }

    .orb2 {
      position: absolute;
      bottom: -80px;
      left: -120px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(79, 142, 247, .08) 0%, transparent 65%);
      border-radius: 50%;
      animation: orbB 11s ease-in-out infinite alternate;
      pointer-events: none;
    }

    @keyframes orbA {
      0% {
        transform: translate(0, 0)
      }

      100% {
        transform: translate(-40px, 40px) scale(1.08)
      }
    }

    @keyframes orbB {
      0% {
        transform: translate(0, 0)
      }

      100% {
        transform: translate(30px, -30px)
      }
    }

    /* Badge */
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border);
      background: rgba(255, 117, 24, .06);
      padding: 7px 16px;
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      border-radius: 100px;
      margin-bottom: 32px;
      animation: fadeUp .8s ease both;
    }

    .hero-badge span {
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1)
      }

      50% {
        opacity: .4;
        transform: scale(.8)
      }
    }

    #page1 h1 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(60px, 11vw, 136px);
      line-height: 0.92;
      letter-spacing: -0.04em;
      position: relative;
      z-index: 1;
    }

    #page1 h1 .line {
      overflow: hidden;
    }

    #page1 h1 .line span {
      display: inline-block;
      animation: slideUp .9s cubic-bezier(.16, 1, .3, 1) both;
    }

    #page1 h1 .line:nth-child(2) span {
      animation-delay: .12s;
    }

    .accent-h {
      color: var(--accent);
    }

    .outline-h {
      -webkit-text-stroke: 1px rgba(238, 238, 245, .25);
      color: transparent;
    }

    @keyframes slideUp {
      from {
        transform: translateY(110%);
        opacity: 0
      }

      to {
        transform: translateY(0);
        opacity: 1
      }
    }

    @keyframes fadeUp {
      from {
        transform: translateY(20px);
        opacity: 0
      }

      to {
        transform: translateY(0);
        opacity: 1
      }
    }

    .hero-sub {
      max-width: 480px;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.7;
      margin-top: 32px;
      position: relative;
      z-index: 1;
      animation: fadeUp .9s .25s ease both;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-top: 40px;
      position: relative;
      z-index: 1;
      animation: fadeUp .9s .4s ease both;
    }

    .btn-hero {
      background: var(--accent);
      color: #04040a;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: .08em;
      text-transform: uppercase;
      border: none;
      padding: 16px 32px;
      border-radius: 10px;
      cursor: none;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      position: relative;
      overflow: hidden;
      transition: transform .2s;
    }

    .btn-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #fff;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .4s ease;
    }

    .btn-hero:hover::before {
      transform: scaleX(1);
    }

    .btn-hero span {
      position: relative;
      z-index: 1;
      color: #04040a;
    }

    .btn-hero:hover {
      transform: translateY(-2px);
    }

    .btn-outline {
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 13px;
      letter-spacing: .06em;
      padding: 15px 28px;
      border-radius: 10px;
      cursor: none;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: border-color .3s, color .3s;
    }

    .btn-outline:hover {
      border-color: var(--text);
      color: var(--text);
    }

    /* VIDEO CONTAINER */
    #videoContainer {
      width: 100%;
      margin-top: 60px;
      border-radius: 20px;
      overflow: hidden;
      position: relative;
      border: 1px solid var(--border);
      animation: fadeUp .9s .55s ease both;
    }

    #videoContainer video {
      width: 100%;
      display: block;
      max-height: 480px;
      object-fit: cover;
      filter: brightness(.7) saturate(.8);
    }

    /* Video gradient overlay */
    #videoContainer::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(4, 4, 10, .7) 0%, transparent 50%);
      pointer-events: none;
    }

    #play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 72px;
      height: 72px;
      background: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #04040a;
      cursor: none;
      z-index: 10;
      opacity: 0;
      transition: opacity .3s, transform .3s;
      box-shadow: 0 0 40px rgba(255, 117, 24, .4);
    }

    #videoContainer:hover #play {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.08);
    }

    /* SCROLL INDICATOR */
    .scroll-hint {
      position: absolute;
      bottom: 40px;
      right: 50px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 10px;
      letter-spacing: .15em;
      text-transform: uppercase;
      z-index: 10;
    }

    .scroll-line {
      width: 1px;
      height: 60px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      animation: scrl 2s ease-in-out infinite;
    }

    @keyframes scrl {

      0%,
      100% {
        transform: scaleY(1);
        opacity: 1
      }

      50% {
        transform: scaleY(.5);
        opacity: .4
      }
    }

    /* ─────── TICKER ─────── */
    .ticker {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      overflow: hidden;
      padding: 14px 0;
      background: var(--surface);
    }

    .ticker-track {
      display: flex;
      gap: 48px;
      animation: tickerMove 22s linear infinite;
      white-space: nowrap;
    }

    @keyframes tickerMove {
      from {
        transform: translateX(0)
      }

      to {
        transform: translateX(-50%)
      }
    }

    .ticker-item {
      display: flex;
      align-items: center;
      gap: 48px;
      font-family: 'Syne', sans-serif;
      font-size: 12px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      flex-shrink: 0;
    }

    .ticker-item em {
      color: var(--accent);
      font-style: normal;
      font-size: 16px;
    }

    /* ─────── SECTION COMMONS ─────── */
    section {
      padding: 100px 50px;
    }

    .sec-label {
      font-size: 11px;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .sec-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: clamp(32px, 4.5vw, 58px);
      line-height: 1.05;
      letter-spacing: -.025em;
    }

    /* REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .7s ease, transform .7s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: none;
    }

    /* ─────── SERVICES ─────── */
    .service-section {
      background: var(--surface);
    }

    .service-section .container {
      max-width: 1200px;
      margin: auto;
    }

    .service-section .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: clamp(26px, 3vw, 42px);
      text-align: center;
      letter-spacing: -.02em;
      color: var(--text);
      margin-bottom: 64px;
    }

    .services {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
    }

    .card {
      background: var(--surface);
      padding: 40px 36px;
      position: relative;
      overflow: hidden;
      transition: background .4s;
      cursor: none;
    }

    .card::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .45s ease;
    }

    .card:hover {
      background: #0d0d16;
    }

    .card:hover::before {
      transform: scaleX(1);
    }

    .card-img-wrap {
      width: 100%;
      height: 180px;
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 28px;
      border: 1px solid var(--border);
    }

    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(.5) brightness(.75);
      transition: filter .5s, transform .5s;
    }

    .card:hover .card-img-wrap img {
      filter: saturate(.8) brightness(.9);
      transform: scale(1.05);
    }

    .card h3 {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 20px;
      margin-bottom: 14px;
      color: var(--text);
    }

    .card p {
      font-size: 14px;
      line-height: 1.75;
      color: var(--muted);
      margin-bottom: 28px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: none;
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 12px;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-family: 'Syne', sans-serif;
      font-weight: 600;
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      cursor: none;
      transition: border-color .3s, color .3s, background .3s;
    }

    .btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-glow);
    }

    .card-num {
      position: absolute;
      top: 24px;
      right: 28px;
      font-family: 'Syne', sans-serif;
      font-size: 11px;
      letter-spacing: .15em;
      color: var(--muted);
    }

    /* ─────── SHORT FEATURES ─────── */
    .short-feature {
      background: var(--bg);
      padding: 80px 50px;
    }

    .short-feature .short-line {
      max-width: 900px;
      margin: auto;
      display: flex;
      align-items: stretch;
      justify-content: center;
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
    }

    .short-line .short-box {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 32px;
      border-right: 1px solid var(--border);
      transition: background .3s;
      cursor: none;
    }

    .short-box:last-child {
      border-right: none;
    }

    .short-box:hover {
      background: var(--surface2);
    }

    .short-box i {
      font-size: 36px;
      color: var(--accent);
    }

    .short-box h2 {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 15px;
      text-align: center;
      margin-top: 16px;
      color: var(--text);
      letter-spacing: .02em;
    }

    /* ─────── FEATURES TIMELINE ─────── */
    .feature {
      background: var(--surface);
      padding: 100px 50px;
    }

    .feature-container {
      max-width: 900px;
      margin: auto;
    }

    .feature-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: clamp(32px, 4vw, 52px);
      text-align: center;
      letter-spacing: -.025em;
      color: var(--text);
    }

    .feature-subtitle {
      text-align: center;
      color: var(--muted);
      margin-top: 12px;
      margin-bottom: 72px;
      font-size: 16px;
    }

    .feature-timeline {
      position: relative;
      padding-left: 44px;
    }

    .feature-timeline::before {
      content: '';
      position: absolute;
      left: 19px;
      top: 0;
      height: 100%;
      width: 1px;
      background: var(--border);
    }

    .feature-item {
      display: flex;
      gap: 32px;
      margin-bottom: 56px;
      position: relative;
      cursor: none;
    }

    .feature-icon {
      width: 60px;
      height: 60px;
      min-width: 60px;
      border-radius: 50%;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      color: #04040a;
      position: relative;
      z-index: 2;
      box-shadow: 0 0 30px var(--accent-glow);
      transition: transform .3s, box-shadow .3s;
    }

    .feature-item:hover .feature-icon {
      transform: scale(1.12);
      box-shadow: 0 0 45px rgba(255, 117, 24, .35);
    }

    .feature-content {
      padding-top: 8px;
    }

    .feature-content h3 {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--text);
      margin-bottom: 8px;
      transition: color .3s;
    }

    .feature-item:hover .feature-content h3 {
      color: var(--accent);
    }

    .feature-content p {
      color: var(--muted);
      line-height: 1.75;
      font-size: 14px;
      max-width: 480px;
    }

    /* ─────── HOW IT WORKS ─────── */
    .how-it-works {
      background: var(--bg);
    }

    .how-it-works .container {
      max-width: 1100px;
      margin: auto;
      text-align: center;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: clamp(28px, 3.5vw, 46px);
      letter-spacing: -.02em;
      color: var(--text);
    }

    .section-subtitle {
      font-size: 16px;
      color: var(--muted);
      margin: 12px auto 56px;
    }

    .cards {
      display: flex;
      gap: 1px;
      background: var(--border);
      border-radius: 16px;
      overflow: hidden;
    }

    .how-it-works .card {
      flex: 1;
      border-radius: 0;
      background: var(--surface2);
      padding: 48px 36px;
    }

    .how-it-works .card::before {
      display: none;
    }

    .how-it-works .card:hover {
      background: #0f0f1a;
    }

    .step-circle {
      width: 52px;
      height: 52px;
      border: 1px solid var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 18px;
      color: var(--accent);
      margin-bottom: 24px;
      transition: background .3s, color .3s;
    }

    .how-it-works .card:hover .step-circle {
      background: var(--accent);
      color: #04040a;
    }

    .how-it-works .card h3 {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--text);
      margin-bottom: 12px;
    }

    .how-it-works .card p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.75;
    }

    /* ─────── CTA BAND ─────── */
    .cta-band {
      background: var(--surface);
      padding: 80px 50px;
      text-align: center;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .cta-band::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(255, 117, 24, .1) 0%, transparent 60%);
      border-radius: 50%;
      pointer-events: none;
    }

    .cta-band h2 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(36px, 5vw, 68px);
      letter-spacing: -.03em;
      line-height: .95;
      position: relative;
      z-index: 1;
      margin-bottom: 32px;
    }

    .cta-band h2 em {
      font-style: italic;
      -webkit-text-stroke: 1px rgba(238, 238, 245, .2);
      color: transparent;
    }

    .cta-band .btn-hero {
      position: relative;
      z-index: 1;
    }

    /* ─────── FOOTER ─────── */
    .pg-footer {
      font-family: 'DM Sans', sans-serif;
    }

    .footer {
      background: #04040a;
      color: var(--text);
      border-top: 1px solid var(--border);
    }

    .footer-wave-svg {
      display: none;
    }

    .footer-content {
      max-width: 1200px;
      margin: auto;
      padding: 72px 50px 80px;
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
      gap: 48px;
      position: relative;
    }

    /* Remove float layout */
    .footer-content-column {
      float: none;
      width: auto;
      padding: 0;
    }

    .footer-logo {
      margin-bottom: 16px;
    }

    .footer-logo h1 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 24px;
      letter-spacing: -.02em;
      color: var(--text);
    }

    .footer-logo h1 span {
      color: var(--accent);
    }

    .footer-logo-link {
      text-decoration: none;
    }

    .hidden-link-text {
      display: none;
    }

    .footer-desc {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
      margin-top: 12px;
    }

    .footer-menu {
