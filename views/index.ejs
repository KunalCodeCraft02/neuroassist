      margin-bottom: 24px;
    }

    .footer-call-to-action-link-wrapper a {
      color: var(--muted);
      font-size: 14px;
      text-decoration: none;
      transition: color .3s;
    }

    .footer-call-to-action-link-wrapper a:hover {
      color: var(--accent);
    }

    /* Social — override absolute positioning */
    .footer-social-links {
      position: static !important;
      width: auto !important;
      height: auto !important;
      display: flex;
      align-items: center;
      gap: 12px;
