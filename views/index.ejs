<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <title>Bemybot — Build Your Bot</title>
 <style>
  *, *::before, *::after{
  box-sizing:border-box;
  margin:0;
  padding:0;
}

:root{

  --bg:#0a0c10;
  --surface:#0f1117;
  --surface2:#14161e;
  --surface3:#1a1d28;

  --accent:#7c6af7;
  --accent2:#5bf0c0;

  --accent-dim:rgba(124,106,247,.15);
  --accent2-dim:rgba(91,240,192,.1);

  --text:#e8eaf0;
  --text2:#9da3b8;
  --muted:#4a5070;

  --border:rgba(255,255,255,.06);
  --border2:rgba(124,106,247,.2);

  --radius:18px;

  --font-display:'Instrument Serif', Georgia, serif;
  --font-sans:'Outfit', sans-serif;
  --font-mono:'JetBrains Mono', monospace;
}

html{
  scroll-behavior:smooth;
}

body{
  background:var(--bg);
  color:var(--text);

  font-family:var(--font-sans);

  font-weight:300;

  overflow-x:hidden;

  cursor:none;
}

/* CURSOR */

#cur{
  position:fixed;

  width:8px;
  height:8px;

  background:var(--accent);

  border-radius:50%;

  pointer-events:none;

  z-index:99999;

  transform:translate(-50%,-50%);

  transition:
    width .25s,
    height .25s,
    background .25s;

  mix-blend-mode:screen;
}

#cur-ring{
  position:fixed;

  width:34px;
  height:34px;

  border:1px solid rgba(124,106,247,.4);

  border-radius:50%;

  pointer-events:none;

  z-index:99998;

  transform:translate(-50%,-50%);
}

body:has(a:hover) #cur,
body:has(button:hover) #cur{
  width:14px;
  height:14px;

  background:var(--accent2);
}

/* GRAIN */

body::after{
  content:'';

  position:fixed;

  inset:0;

  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");

  pointer-events:none;

  z-index:-1;

  opacity:.5;
}

/* MOBILE MENU */

#fixediv{
  position:fixed;

  top:-110%;
  left:0;

  width:100%;
  height:100vh;

  background:rgba(10,12,16,.98);

  backdrop-filter:blur(24px);

  z-index:100000;

  transition:.5s cubic-bezier(.16,1,.3,1);

  overflow-y:auto;

  border-bottom:1px solid var(--border2);
}

#fixediv.open{
  top:0;
}

.links-fixed{
  height:100%;

  display:flex;
  flex-direction:column;

  align-items:center;
  justify-content:center;

  gap:24px;

  text-align:center;
}

.links-fixed a{
  font-family:var(--font-display);

  font-size:
    clamp(44px,8vw,80px);

  font-style:italic;

  color:var(--text2);

  text-decoration:none;

  transition:.3s;
}

.links-fixed a:hover{
  color:var(--accent);
}

.close-btn{
  position:absolute;

  top:24px;
  right:24px;

  font-size:28px;

  color:var(--text2);

  background:none;
  border:none;
}

/* NAVBAR */

#nav{
  height:74px;
  width:100%;

  position:fixed;

  z-index:1000;

  padding:0 48px;

  display:flex;
  justify-content:space-between;
  align-items:center;

  transition:.4s;

  border-bottom:1px solid transparent;
}

#nav.scrolled{
  background:rgba(10,12,16,.86);

  backdrop-filter:blur(24px);

  border-color:var(--border);
}

.logo{
  display:flex;
  align-items:center;

  gap:10px;
}

.logo-mark{
  width:30px;
  height:30px;

  background:
    linear-gradient(
      135deg,
      var(--accent),
      var(--accent2)
    );

  border-radius:8px;

  display:flex;
  align-items:center;
  justify-content:center;

  font-family:var(--font-mono);

  font-size:12px;

  color:#000;
}

.logo-text{
  font-size:20px;

  font-weight:700;

  color:var(--text);
}

.logo-text span{
  color:var(--accent);
}

#navPart2{
  display:flex;
  align-items:center;

  gap:30px;
}

#nav-links{
  display:flex;
  gap:24px;
}

#nav-links a{
  text-decoration:none;

  color:var(--text2);

  font-size:13px;

  transition:.3s;
}

#nav-links a:hover{
  color:white;
}

#icon{
  display:flex;
  align-items:center;

  gap:16px;
}

#icon i{
  font-size:20px;

  color:var(--muted);

  transition:.3s;
}

#icon i:hover{
  color:white;
}

#menuicon{
  display:none;
}

/* HERO */

#page1{
  min-height:100vh;
  width:100%;

  padding:
    140px 48px 80px;

  display:grid;

  grid-template-columns:
    1.1fr
    .9fr;

  align-items:center;

  gap:70px;

  position:relative;

  overflow:hidden;
}

/* BACKGROUND */

.mesh-bg{
  position:absolute;
  inset:0;

  z-index:0;

  pointer-events:none;
}

.mesh-blob{
  position:absolute;

  border-radius:50%;

  filter:blur(80px);
}

.mesh-blob-1{
  width:600px;
  height:600px;

  top:-200px;
  right:-150px;

  background:
    radial-gradient(
      circle,
      rgba(124,106,247,.12),
      transparent 70%
    );
}

.mesh-blob-2{
  width:450px;
  height:450px;

  bottom:-100px;
  left:-80px;

  background:
    radial-gradient(
      circle,
      rgba(91,240,192,.07),
      transparent 70%
    );
}

.grid-bg{
  position:absolute;

  inset:0;

  background-image:
    linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);

  background-size:60px 60px;

  z-index:0;
}

/* LEFT */

.hero-content{
  position:relative;

  z-index:5;

  max-width:650px;
}

.hero-badge{
  display:inline-flex;
  align-items:center;

  gap:8px;

  border:1px solid var(--border2);

  background:var(--accent-dim);

  padding:7px 16px;

  border-radius:100px;

  font-size:11px;

  font-family:var(--font-mono);

  color:var(--accent);

  margin-bottom:34px;
}

.badge-dot{
  width:6px;
  height:6px;

  border-radius:50%;

  background:var(--accent2);
}

#page1 h1{
  font-family:var(--font-display);

  font-size:
    clamp(72px,10vw,132px);

  line-height:.88;

  letter-spacing:-.05em;

  margin-bottom:24px;
}

.italic-h{
  font-style:italic;

  color:var(--text2);
}

.grad-h{
  background:
    linear-gradient(
      135deg,
      var(--accent),
      var(--accent2)
    );

  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero-sub{
  font-size:17px;

  line-height:1.9;

  color:var(--text2);

  max-width:520px;

  margin-top:20px;
}

.hero-actions{
  display:flex;
  align-items:center;

  gap:18px;

  margin-top:42px;
}

.btn-hero{
  background:
    linear-gradient(
      135deg,
      var(--accent),
      #9c8ef7
    );

  color:white;

  text-decoration:none;

  padding:15px 30px;

  border-radius:12px;

  font-weight:600;

  display:flex;
  align-items:center;

  gap:10px;

  box-shadow:
    0 8px 30px rgba(124,106,247,.35);

  transition:.3s;
}

.btn-hero:hover{
  transform:translateY(-4px);
}

.btn-outline{
  border:1px solid var(--border);

  color:var(--text2);

  text-decoration:none;

  padding:15px 26px;

  border-radius:12px;

  display:flex;
  align-items:center;

  gap:10px;

  transition:.3s;
}

.btn-outline:hover{
  background:var(--accent-dim);

  border-color:var(--border2);

  color:white;
}

/* STATS */

.hero-stats{
  display:flex;

  gap:50px;

  margin-top:60px;

  padding-top:36px;

  border-top:1px solid var(--border);
}

.stat-num{
  font-family:var(--font-display);

  font-size:38px;
}

.stat-num span{
  color:var(--accent);
}

.stat-label{
  margin-top:8px;

  color:var(--muted);

  font-size:12px;

  font-family:var(--font-mono);

  letter-spacing:.06em;
}

/* RIGHT */

.hero-visual{
  position:relative;

  width:100%;

  display:flex;
  align-items:center;
  justify-content:center;

  min-height:650px;
}

.hero-image-wrap{
  position:relative;

  width:100%;
  max-width:520px;

  z-index:3;
}

.hero-ai-image{
  width:100%;
  height:650px;

  object-fit:cover;

  border-radius:32px;

  border:1px solid var(--border);

  box-shadow:
    0 25px 80px rgba(0,0,0,.45),
    0 0 80px rgba(124,106,247,.18);

  filter:
    brightness(.82)
    saturate(.88);

  transition:.4s;
}

.hero-ai-image:hover{
  transform:translateY(-6px);
}

.hero-glow{
  position:absolute;

  width:540px;
  height:540px;

  border-radius:50%;

  background:
    radial-gradient(
      circle,
      rgba(124,106,247,.25),
      transparent 70%
    );

  filter:blur(80px);

  z-index:1;
}

/* FLOATING */

.floating-card{
  position:absolute;

  display:flex;
  align-items:center;

  gap:14px;

  background:
    rgba(15,17,23,.82);

  border:1px solid var(--border);

  backdrop-filter:blur(18px);

  padding:16px 18px;

  border-radius:18px;

  z-index:4;

  box-shadow:
    0 10px 30px rgba(0,0,0,.25);
}

.floating-card i{
  width:46px;
  height:46px;

  border-radius:14px;

  background:var(--accent-dim);

  display:flex;
  align-items:center;
  justify-content:center;

  color:var(--accent);

  font-size:22px;
}

.floating-card h4{
  font-size:18px;

  font-weight:600;

  color:white;

  margin-bottom:4px;
}

.floating-card p{
  font-size:14px;

  color:var(--text2);
}

.card-one{
  top:40px;
  left:-40px;
}

.card-two{
  bottom:40px;
  right:-30px;
}

/* TICKER */

.ticker{
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);

  overflow:hidden;

  padding:12px 0;

  background:var(--surface);
}

.ticker-track{
  display:flex;

  animation:tickerMove 24s linear infinite;
}

.ticker-item{
  display:inline-flex;
  align-items:center;

  gap:32px;

  white-space:nowrap;

  font-family:var(--font-mono);

  font-size:11px;

  color:var(--muted);

  padding-right:32px;
}

.ticker-item em{
  color:var(--accent);

  font-style:normal;
}

@keyframes tickerMove{
  from{
    transform:translateX(0);
  }

  to{
    transform:translateX(-50%);
  }
}

/* RESPONSIVE */

@media(max-width:1150px){

  #page1{
    grid-template-columns:1fr;

    gap:60px;
  }

  .hero-visual{
    order:-1;
  }

  .hero-image-wrap{
    max-width:700px;
  }

  .hero-ai-image{
    height:520px;
  }

  .card-one{
    left:0;
  }

  .card-two{
    right:0;
  }
}

@media(max-width:768px){

  body{
    cursor:auto;
  }

  #cur,
  #cur-ring{
    display:none;
  }

  #nav{
    padding:0 20px;
  }

  #nav-links{
    display:none;
  }

  #menuicon{
    display:block;
  }

  #page1{
    padding:
      120px 20px 70px;

    grid-template-columns:1fr;
  }

  .hero-actions{
    flex-direction:column;

    align-items:flex-start;
  }

  .btn-hero,
  .btn-outline{
    width:100%;

    justify-content:center;
  }

  .hero-ai-image{
    height:420px;
  }

  .floating-card{
    transform:scale(.9);
  }

  .hero-stats{
    flex-wrap:wrap;

    gap:24px;
  }

  .links-fixed a{
    font-size:58px;
  }
}

@media(max-width:480px){

  #page1{
    padding:
      110px 16px 60px;
  }

  #page1 h1{
    font-size:58px;
  }

  .hero-ai-image{
    height:340px;

    border-radius:24px;
  }

  .floating-card{
    position:relative;

    margin-top:14px;
  }

  .card-one,
  .card-two{
    top:auto;
    left:auto;
    right:auto;
    bottom:auto;
  }

  .hero-stats{
    gap:18px;
  }

  .links-fixed a{
    font-size:48px;
  }
}
 </style>
</head>

