
<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>BemyBot — Sign In</title>

    <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">

    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />

    <link
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400&display=swap"
        rel="stylesheet" />

    <style>

        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #0a0c10;
            --surface: #0f1117;
            --surface2: #14161e;
            --surface3: #1a1d28;
            --accent: #7c6af7;
            --accent2: #5bf0c0;
            --accent-dim: rgba(124, 106, 247, 0.14);
            --accent2-dim: rgba(91, 240, 192, 0.08);
            --text: #e8eaf0;
            --text2: #9da3b8;
            --muted: #4a5070;
            --border: rgba(255, 255, 255, 0.06);
            --border2: rgba(124, 106, 247, 0.2);
            --radius: 24px;
            --font-display: 'Instrument Serif', serif;
            --font-sans: 'Outfit', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-sans);
            min-height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 20px;
            position: relative;
            cursor: none;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: -1;
            opacity: .5;
        }

        /* CURSOR */
        #cur {
            position: fixed;
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            pointer-events: none;
            z-index: 99999;
            transform: translate(-50%, -50%);
            transition: width .25s, height .25s, background .25s;
            mix-blend-mode: screen;
        }

        #cur-ring {
            position: fixed;
            width: 34px;
            height: 34px;
            border: 1px solid rgba(124, 106, 247, 0.4);
            border-radius: 50%;
            pointer-events: none;
            z-index: 99998;
            transform: translate(-50%, -50%);
            transition: transform .12s ease-out;
        }

        body:has(button:hover) #cur,
        body:has(input:hover) #cur,
        body:has(a:hover) #cur {
            width: 14px;
            height: 14px;
            background: var(--accent2);
        }

        /* BACKGROUND */
        .mesh-bg {
            position: fixed;
            inset: 0;
            overflow: hidden;
            z-index: -2;
            pointer-events: none;
        }

        .mesh-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
        }

        .mesh-blob-1 {
            width: 650px;
            height: 650px;
            top: -240px;
            right: -180px;
            background: radial-gradient(circle, rgba(124,106,247,.14) 0%, transparent 70%);
        }

        .mesh-blob-2 {
            width: 500px;
            height: 500px;
            bottom: -120px;
            left: -120px;
            background: radial-gradient(circle, rgba(91,240,192,.08) 0%, transparent 70%);
        }

        .grid-bg {
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
            z-index: -1;
        }

        /* CARD */
        .container {
            width: 100%;
            max-width: 520px;
            background: rgba(15,17,23,.78);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 32px;
            padding: 42px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 80px rgba(124,106,247,.08);
        }

        .container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
        }

        /* BADGE */
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--border2);
            background: var(--accent-dim);
            padding: 6px 14px 6px 10px;
            font-size: 11px;
            font-family: var(--font-mono);
            letter-spacing: .08em;
            color: var(--accent);
            border-radius: 100px;
            margin-bottom: 26px;
        }

        .badge-dot {
            width: 6px;
            height: 6px;
            background: var(--accent2);
            border-radius: 50%;
            animation: pulse 2.2s infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: .3;
                transform: scale(.7);
            }
        }

        /* TITLE */
        h1 {
            font-family: var(--font-display);
            font-weight: 400;
            font-size: clamp(42px, 6vw, 64px);
            line-height: .95;
            letter-spacing: -.03em;
            margin-bottom: 14px;
        }

        h1 span {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtext {
            color: var(--text2);
            line-height: 1.8;
            font-size: 14px;
            margin-bottom: 36px;
        }

        /* FORM */
        .input-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 10px;
            color: var(--text2);
            font-size: 11px;
            letter-spacing: .08em;
            text-transform: uppercase;
            font-family: var(--font-mono);
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 18px;
        }

        input {
            width: 100%;
            padding: 16px 18px 16px 52px;
            border-radius: 16px;
            border: 1px solid var(--border);
            background: var(--surface2);
            color: var(--text);
            font-size: 14px;
            font-family: var(--font-sans);
            outline: none;
            transition: .3s;
        }

        input:focus {
            border-color: var(--border2);
            background: var(--surface3);
            box-shadow: 0 0 0 4px rgba(124,106,247,.08);
        }

        input::placeholder {
            color: var(--muted);
        }

        /* BUTTONS */
        .btn-primary {
            width: 100%;
            border: none;
            padding: 16px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--accent), #9c8ef7);
            color: white;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            cursor: pointer;
            transition: .3s;
            box-shadow: 0 4px 24px rgba(124,106,247,.3);
            margin-top: 10px;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(124,106,247,.4);
        }

        .google-btn {
            width: 100%;
            margin-top: 14px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text2);
            padding: 15px;
            border-radius: 16px;
            cursor: pointer;
            transition: .3s;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
        }

        .google-btn:hover {
            border-color: var(--border2);
            background: var(--accent-dim);
            color: var(--text);
        }

        /* TEXT */
        .bottomText {
            margin-top: 28px;
            text-align: center;
            color: var(--text2);
            font-size: 14px;
        }

        .bottomText a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }

        /* TOAST */
        #toast {
            position: fixed;
            top: 30px;
            right: 30px;
            z-index: 999999;
        }

        .toast {
            background: var(--surface);
            color: var(--text);
            padding: 14px 20px;
            border-radius: 14px;
            margin-top: 10px;
            font-size: 14px;
            border: 1px solid var(--border);
            opacity: 0;
            transform: translateY(-20px);
            transition: .3s;
            backdrop-filter: blur(10px);
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast.error {
            background: rgba(255,80,80,.15);
            border-color: rgba(255,80,80,.25);
            color: #ff9c9c;
        }

        /* MOBILE */
        @media(max-width:768px) {

            body {
                cursor: auto;
            }

            #cur,
            #cur-ring {
                display: none;
            }

            .container {
                padding: 30px 24px;
                border-radius: 26px;
            }

            h1 {
                font-size: 46px;
            }
        }

    </style>

</head>

<body>

    <div id="cur"></div>
    <div id="cur-ring"></div>

    <div class="mesh-bg">
        <div class="mesh-blob mesh-blob-1"></div>
        <div class="mesh-blob mesh-blob-2"></div>
    </div>

    <div class="grid-bg"></div>


    <div class="container">

        <div class="hero-badge">
            <div class="badge-dot"></div>
            SECURE ACCESS
        </div>

        <h1>Welcome <span>Back</span></h1>

        <p class="subtext">
            Sign in to access your AI dashboard, manage bots, analytics, conversations and automation workflows.
        </p>


        <form id="loginForm">

            <div class="input-group">
                <label>Email Address</label>
                <div class="input-wrap">
                    <i class="ri-mail-line"></i>
                    <input id="loginEmail" type="email" placeholder="you@example.com">
                </div>
            </div>

            <div class="input-group">
                <label>Password</label>
                <div class="input-wrap">
                    <i class="ri-lock-password-line"></i>
                    <input id="loginPassword" type="password" placeholder="Enter password">
                </div>
            </div>

            <button type="submit" class="btn-primary">
                Sign In
            </button>

        </form>


        <a href="/auth/google" class="google-btn">
            <i class="ri-google-fill"></i>
            Continue with Google
        </a>


        <div class="bottomText">
            Don't have an account?
            <a href="/signup">Create account</a>
        </div>

    </div>


    <div id="toast"></div>


    <script>

        // CURSOR
        const cur = document.getElementById('cur');
        const ring = document.getElementById('cur-ring');

        window.addEventListener('mousemove', (e) => {
            cur.style.left = e.clientX + 'px';
            cur.style.top = e.clientY + 'px';

            ring.style.left = e.clientX + 'px';
            ring.style.top = e.clientY + 'px';
        });


        const form = document.getElementById("loginForm")


        form.addEventListener("submit", async function (e) {

            e.preventDefault()

            const email = document.getElementById("loginEmail").value.trim()
            const password = document.getElementById("loginPassword").value.trim()

            if (!email || !password) {
                showToast("Please fill all fields", "error")
                return
            }

            try {

                const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || ''

                const res = await fetch("/login", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        email,
                        password,
                        _csrf: csrfToken
                    })
                })

                const result = await res.json()

                if (result.success) {

                    showToast(result.message, "success")

                    setTimeout(() => {
                        window.location = result.redirect
                    }, 1200)

                } else {

                    showToast(result.message, "error")

                }

            } catch (err) {

                showToast("Server error", "error")

            }

        })


        function showToast(message, type) {

            const toastContainer = document.getElementById("toast")

            const existingToasts = toastContainer.querySelectorAll('.toast')
            existingToasts.forEach(t => t.remove())

            const toast = document.createElement("div")

            toast.classList.add("toast", type)
            toast.innerText = message

            toastContainer.appendChild(toast)

            setTimeout(() => toast.classList.add("show"), 100)

            setTimeout(() => toast.remove(), 3000)

        }

    </script>

</body>

</html>
