<!DOCTYPE html>
<html>

<head>

	<title>Sign In</title>

	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
			font-family: 'Inter', sans-serif;
		}

		body {
			background: #ffffff;
			color: #111;
			display: flex;
			align-items: center;
			justify-content: center;
			min-height: 100vh;
			padding: 20px;
		}

		.container {
			width: 100%;
			max-width: 420px;
			background: white;
			padding: 40px;
			border-radius: 12px;
			border: 1px solid #eee;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
		}

		.logo {
			font-size: 20px;
			font-weight: 600;
			margin-bottom: 20px;
		}

		.logo img {
			/* height: 100%; */
			width: 70px;
			object-fit: cover;
			border-radius: 50%;
		}

		h2 {
			font-size: 22px;
			font-weight: 600;
			margin-bottom: 25px;
		}

		label {
			font-size: 13px;
			font-weight: 500;
			display: block;
			margin-top: 15px;
			margin-bottom: 6px;
		}

		input {
			width: 100%;
			padding: 12px;
			border: 1px solid #e3e3e3;
			border-radius: 8px;
			font-size: 14px;
			outline: none;
		}

		input:focus {
			border-color: #000;
		}

		button {
			margin-top: 20px;
			width: 100%;
			padding: 13px;
			background: black;
			color: white;
			border: none;
			border-radius: 8px;
			font-size: 14px;
			font-weight: 500;
			cursor: pointer;
		}

		button:hover {
			opacity: 0.85;
		}

		.bottomText {
			margin-top: 20px;
			font-size: 13px;
			text-align: center;
		}

		.bottomText a {
			color: black;
			font-weight: 500;
			text-decoration: none;
		}

		#toast {
			position: fixed;
			top: 30px;
			right: 30px;
			z-index: 1000;
		}

		.toast {
			background: #111;
			color: white;
			padding: 14px 20px;
			border-radius: 8px;
			margin-top: 10px;
			font-size: 14px;
			box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
			opacity: 0;
			transform: translateY(-20px);
			transition: .3s;
		}

		.toast.show {
			opacity: 1;
			transform: translateY(0);
		}

		.toast.error {
			background: #ff3b3b;
		}
	</style>

</head>

<body>

	<div class="container">

		<div class="logo"><img src="/assets/image/Neuro Assist.png" alt="Neuro Assist"></div>

		<h2>Sign in to your account</h2>

		<form id="loginForm">

			<label>Email</label>
			<input id="loginEmail" type="email" placeholder="you@example.com">

			<label>Password</label>
			<input id="loginPassword" type="password" placeholder="Enter password">

			<button type="submit">Sign In</button>

		</form>

		<a href="/auth/google">
			<button style="background:#fff;color:#000;border:1px solid #ddd;margin-top:10px;">
				Continue with Google
			</button>
		</a>

		<div class="bottomText">
			Don't have an account? <a href="/signup">Create account</a>
		</div>

	</div>

	<div id="toast"></div>

	<script>

		const form = document.getElementById("loginForm")

		form.addEventListener("submit", async function (e) {

			e.preventDefault()

			const email = document.getElementById("loginEmail").value.trim()
			const password = document.getElementById("loginPassword").value.trim()

			if (!email || !password) {
				showToast("Please fill all fields", "error")
				return
			}

			try {

				const res = await fetch("/login", {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({ email, password })
				})

				const result = await res.json()

				if (result.success) {

					showToast(result.message, "success")

					setTimeout(() => {
						window.location = result.redirect
					}, 1200)

				} else {

					showToast(result.message, "error")

				}

			} catch (err) {

				showToast("Server error", "error")

			}

		})

		function showToast(message, type) {

			const toastContainer = document.getElementById("toast")

			const toast = document.createElement("div")

			toast.classList.add("toast", type)

			toast.innerText = message

			toastContainer.appendChild(toast)

			setTimeout(() => toast.classList.add("show"), 100)

			setTimeout(() => toast.remove(), 3000)

		}

	</script>

</body>

</html>