<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Pricing</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0a0c10;
      --surface: #0f1117;
      --surface2: #14161e;
      --surface3: #1a1d28;

      --accent: #7c6af7;
      --accent2: #5bf0c0;

      --accent-dim: rgba(124, 106, 247, .14);
      --accent2-dim: rgba(91, 240, 192, .08);

      --text: #e8eaf0;
      --text2: #9da3b8;
      --muted: #4a5070;

      --border: rgba(255, 255, 255, .06);
      --border2: rgba(124, 106, 247, .2);

      --radius: 28px;

      --font-display: 'Syne', sans-serif;
      --font-sans: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--text);

      font-family: var(--font-sans);

      overflow-x: hidden;

      cursor: none;

      min-height: 100vh;

      position: relative;
    }

    /* BACKGROUND */

    .grid-bg {
      position: fixed;
      inset: 0;

      background-image:
        linear-gradient(rgba(255, 255, 255, .025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .025) 1px, transparent 1px);

      background-size: 60px 60px;

      z-index: -3;

      pointer-events: none;
    }

    .mesh-bg {
      position: fixed;
      inset: 0;

      z-index: -2;

      pointer-events: none;
    }

    .mesh-blob {
      position: absolute;

      border-radius: 50%;

      filter: blur(100px);
    }

    .mesh-blob-1 {
      width: 700px;
      height: 700px;

      top: -240px;
      right: -180px;

      background:
        radial-gradient(circle,
          rgba(124, 106, 247, .14),
          transparent 70%);
    }

    .mesh-blob-2 {
      width: 500px;
      height: 500px;

      bottom: -120px;
      left: -120px;

      background:
        radial-gradient(circle,
          rgba(91, 240, 192, .08),
          transparent 70%);
    }

    /* ORBS */

    .orb {
      position: fixed;

      border-radius: 50%;

      pointer-events: none;

      z-index: -1;
    }

    .orb-1 {
      width: 600px;
      height: 600px;

      top: -250px;
      right: -200px;

      background:
        radial-gradient(circle,
          rgba(124, 106, 247, .14),
          transparent 70%);
    }

    .orb-2 {
      width: 450px;
      height: 450px;

      bottom: -150px;
      left: -150px;

      background:
        radial-gradient(circle,
          rgba(91, 240, 192, .08),
          transparent 70%);
    }

    /* CURSOR */

    #cur {
      position: fixed;

      width: 8px;
      height: 8px;

      background: var(--accent);

      border-radius: 50%;

      pointer-events: none;

      z-index: 99999;

      transform: translate(-50%, -50%);

      transition:
        width .25s ease,
        height .25s ease,
        background .25s ease;
    }

    #cur-ring {
      position: fixed;

      width: 34px;
      height: 34px;

      border: 1px solid rgba(124, 106, 247, .45);

      border-radius: 50%;

      pointer-events: none;

      z-index: 99998;

      transform: translate(-50%, -50%);
    }

    a:hover~#cur,
    button:hover~#cur {
      width: 16px;
      height: 16px;

      background: var(--accent2);
    }

    /* NAVBAR */

    #nav {
      height: 78px;
      width: 100%;

      position: fixed;

      top: 0;
      left: 0;

      z-index: 1000;

      padding: 0 42px;

      display: flex;
      align-items: center;
      justify-content: space-between;

      transition: .35s;

      border-bottom: 1px solid transparent;
    }

    #nav.scrolled {
      background: rgba(10, 12, 16, .82);

      backdrop-filter: blur(20px);

      border-color: var(--border);
    }

    .logo-link {
      text-decoration: none;

      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .logo-link h3 {
      font-size: 20px;

      font-weight: 700;

      color: var(--text);
    }

    .logo-link h3:nth-child(2) {
      color: var(--accent);
    }

    .logo-link h3:nth-child(3) {
      color: var(--text2);

      font-size: 14px;
    }

    #navPart2 {
      display: flex;
      align-items: center;
      gap: 30px;
    }

    #nav-links {
      display: flex;
      align-items: center;
      gap: 24px;
    }

    #nav-links a {
      text-decoration: none;

      color: var(--text2);

      font-size: 13px;

      transition: .3s;
    }

    #nav-links a:hover {
      color: white;
    }

    #icon {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    #icon i {
      font-size: 20px;

      color: var(--text2);

      transition: .3s;
    }

    #icon i:hover {
      color: var(--accent2);
    }

    #menuicon {
      display: none;
    }

    /* MOBILE MENU */

    #fixediv {
      position: fixed;

      top: -100%;
      left: 0;

      width: 100%;
      height: 100vh;

      background: #0a0c10;

      z-index: 9999;

      transition: .5s ease;
    }

    #fixediv.open {
      top: 0;
    }

    .links-fixed {
      height: 100%;

      display: flex;
      flex-direction: column;

      align-items: flex-end;
      justify-content: center;

      gap: 14px;

      padding-right: 40px;
    }

    .links-fixed a {
      text-decoration: none;

      color: white;

      font-size: 54px;

      font-family: var(--font-display);

      font-weight: 700;
    }

    .close-btn {
      position: absolute;

      top: 24px;
      right: 24px;

      background: none;
      border: none;

      color: white;

      font-size: 34px;
    }

    /* CONTENT */

    .content-wrapper {
      width: 100%;

      padding-top: 120px;
    }

    /* HERO */

    .page-header {
      text-align: center;

      padding: 40px 20px 80px;
    }

    .page-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;

      padding: 8px 18px;

      border-radius: 100px;

      background: var(--accent-dim);

      border: 1px solid var(--border2);

      color: var(--accent);

      font-size: 11px;

      letter-spacing: .08em;

      font-family: var(--font-mono);

      margin-bottom: 28px;
    }

    .page-title {
      font-family: var(--font-display);

      font-size: clamp(64px, 9vw, 130px);

      line-height: .9;

      letter-spacing: -.05em;

      margin-bottom: 24px;
    }

    .page-title span {
      background:
        linear-gradient(135deg,
          var(--accent),
          var(--accent2));

      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
      max-width: 700px;

      margin: auto;

      color: var(--text2);

      line-height: 1.8;

      font-size: 16px;
    }

    /* PRICING */

    .pricing-container {
      max-width: 1300px;

      margin: auto;

      padding: 0 40px 100px;

      display: grid;

      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));

      gap: 28px;
    }

    .pricing-card {
      background: rgba(15, 17, 23, .78);

      backdrop-filter: blur(24px);

      border: 1px solid var(--border);

      border-radius: 32px;

      padding: 40px;

      position: relative;

      overflow: hidden;

      transition: .35s;
    }

    .pricing-card::before {
      content: '';

      position: absolute;

      top: 0;
      left: 0;
      right: 0;

      height: 1px;

      background:
        linear-gradient(90deg,
          transparent,
          var(--accent),
          transparent);
    }

    .pricing-card:hover {
      transform: translateY(-8px);

      border-color: var(--border2);

      box-shadow:
        0 20px 60px rgba(124, 106, 247, .18);
    }

    .pricing-card.popular {
      border-color: rgba(124, 106, 247, .3);

      background:
        linear-gradient(180deg,
          rgba(124, 106, 247, .08),
          rgba(15, 17, 23, .92));
    }

    .popular-badge {
      position: absolute;

      top: 20px;
      right: 20px;

      padding: 8px 16px;

      border-radius: 100px;

      background:
        linear-gradient(135deg,
          var(--accent),
          #9c8ef7);

      color: white;

      font-size: 11px;

      font-family: var(--font-mono);
    }

    .plan-name {
      font-size: 36px;

      font-weight: 700;

      margin-bottom: 10px;
    }

    .price {
      font-family: var(--font-display);

      font-size: 74px;

      line-height: 1;

      margin: 20px 0;
    }

    .price span {
      font-size: 16px;

      color: var(--text2);

      font-family: var(--font-sans);
    }

    .plan-description {
      color: var(--text2);

      line-height: 1.8;

      margin-bottom: 26px;
    }

    .features {
      list-style: none;

      margin: 30px 0 40px;
    }

    .features li {
      display: flex;
      align-items: center;

      gap: 14px;

      margin-bottom: 18px;

      color: var(--text2);
    }

    .features li i {
      color: var(--accent2);
    }

    /* BUTTON */

    .btn {
      width: 100%;

      padding: 16px;

      border: none;

      border-radius: 18px;

      font-size: 13px;

      font-weight: 700;

      letter-spacing: .08em;

      text-transform: uppercase;

      transition: .3s;
    }

    .btn-primary {
      background:
        linear-gradient(135deg,
          var(--accent),
          #9c8ef7);

      color: white;

      box-shadow:
        0 10px 30px rgba(124, 106, 247, .25);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
    }

    .btn-secondary,
    .btn-disabled {
      background: transparent;

      border: 1px solid var(--border);

      color: var(--text2);
    }

    /* FOOTER */

    .pg-footer {
      position: relative;

      margin-top: 80px;

      border-top: 1px solid var(--border);

      background:
        linear-gradient(180deg,
          rgba(15, 17, 23, .55),
          rgba(10, 12, 16, .9));

      backdrop-filter: blur(20px);

      overflow: hidden;
    }

    .pg-footer::before {
      content: '';

      position: absolute;

      top: -200px;
      right: -200px;

      width: 500px;
      height: 500px;

      border-radius: 50%;

      background:
        radial-gradient(circle,
          rgba(124, 106, 247, .12),
          transparent 70%);

      pointer-events: none;
    }

    .footer {
      width: 100%;
    }

    .footer-content {
      max-width: 1300px;

      margin: auto;

      padding: 90px 40px 60px;

      display: grid;

      grid-template-columns:
        1.5fr 1fr 1fr 1.2fr;

      gap: 60px;

      position: relative;

      z-index: 2;
    }

    /* COLUMN */

    .footer-content-column {
      display: flex;
      flex-direction: column;
    }

    /* LOGO */

    .footer-logo h1 {
      font-size: 52px;

      font-family: var(--font-display);

      font-weight: 700;

      letter-spacing: -.04em;

      margin-bottom: 20px;
    }

    .footer-logo span {
      background:
        linear-gradient(135deg,
          var(--accent),
          var(--accent2));

      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .footer-desc {
      color: var(--text2);

      line-height: 1.9;

      font-size: 15px;

      max-width: 420px;
    }

    /* MENU */

    .footer-menu-name,
    .footer-call-to-action-title {
      font-size: 15px;

      font-weight: 700;

      color: var(--text);

      margin-bottom: 22px;

      letter-spacing: .02em;
    }

    .footer-menu-list {
      list-style: none;

      display: flex;
      flex-direction: column;

      gap: 16px;
    }

    .footer-menu-list li a {
      text-decoration: none;

      color: var(--text2);

      transition: .3s;

      font-size: 15px;
    }

    .footer-menu-list li a:hover {
      color: var(--accent2);

      transform: translateX(4px);
    }

    /* CTA */

    .footer-call-to-action-description {
      color: var(--text2);

      line-height: 1.8;

      margin-bottom: 24px;

      font-size: 15px;
    }

    .footer-call-to-action-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;

      width: fit-content;

      padding: 15px 26px;

      border-radius: 16px;

      text-decoration: none;

      background:
        linear-gradient(135deg,
          var(--accent),
          #9c8ef7);

      color: white;

      font-size: 13px;

      font-weight: 700;

      letter-spacing: .08em;

      text-transform: uppercase;

      transition: .3s;

      box-shadow:
        0 10px 30px rgba(124, 106, 247, .24);
    }

    .footer-call-to-action-button:hover {
      transform: translateY(-3px);

      box-shadow:
        0 18px 40px rgba(124, 106, 247, .3);
    }

    /* COPYRIGHT */

    .footer-copyright {
      border-top: 1px solid var(--border);

      padding: 24px 20px;

      text-align: center;

      position: relative;

      z-index: 2;
    }

    .footer-copyright-text {
      color: var(--text2);

      font-size: 14px;
    }

    .footer-copyright-link {
      color: var(--accent);

      text-decoration: none;

      transition: .3s;
    }

    .footer-copyright-link:hover {
      color: var(--accent2);
    }

    /* RESPONSIVE */

    @media(max-width:1100px) {

      .footer-content {
        grid-template-columns:
          1fr 1fr;

        gap: 50px;
      }
    }

    @media(max-width:768px) {

      .footer-content {
        grid-template-columns: 1fr;

        padding: 70px 20px 50px;

        gap: 42px;
      }

      .footer-logo h1 {
        font-size: 42px;
      }

      .footer-desc {
        max-width: 100%;
      }

      .footer-call-to-action-button {
        width: 100%;
      }
    }

    /* MOBILE */

    @media(max-width:768px) {

      body {
        cursor: auto;
      }

      #cur,
      #cur-ring {
        display: none !important;
      }

      #menuicon {
        display: block;
      }

      #nav-links {
        display: none;
      }

      #nav {
        padding: 0 20px;
      }

      .page-title {
        font-size: 68px;
      }

      .pricing-container {
        padding: 0 20px 70px;
      }

      .pricing-card {
        padding: 30px;
      }

      .price {
        font-size: 58px;
      }
    }
  </style>


</head>

