<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>NeuroAssist Co — Pricing</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }



    :root {
      --bg: #0a0c10;
      --surface: #0f1117;
      --surface2: #14161e;
      --surface3: #1a1d28;
      --accent: #7c6af7;
      --accent2: #5bf0c0;
      --accent-dim: rgba(124, 106, 247, 0.14);
      --accent2-dim: rgba(91, 240, 192, 0.08);
      --text: #e8eaf0;
      --text2: #9da3b8;
      --muted: #4a5070;
      --border: rgba(255, 255, 255, 0.06);
      --border2: rgba(124, 106, 247, 0.2);
      --radius: 24px;
      --font-display: 'Instrument Serif', serif;
      --font-sans: 'Outfit', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      overflow-x: hidden;
      cursor: none;
    }

    /* PREMIUM BACKGROUND */
    .mesh-bg {
      position: fixed;
      inset: 0;
      overflow: hidden;
      z-index: -2;
      pointer-events: none;
    }

    .mesh-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
    }

    .mesh-blob-1 {
      width: 700px;
      height: 700px;
      top: -240px;
      right: -180px;
      background: radial-gradient(circle, rgba(124, 106, 247, .14) 0%, transparent 70%);
    }

    .mesh-blob-2 {
      width: 500px;
      height: 500px;
      bottom: -120px;
      left: -120px;
      background: radial-gradient(circle, rgba(91, 240, 192, .08) 0%, transparent 70%);
    }

    .grid-bg {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, .025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .025) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: -1;
    }

    /* NAVBAR */
    #nav {
      height: 78px;
      backdrop-filter: blur(20px);
      background: rgba(10, 12, 16, .78);
      border-bottom: 1px solid var(--border);
    }

    /* HERO */
    .page-header {
      padding: 150px 30px 80px;
      text-align: center;
    }

    .page-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border2);
      background: var(--accent-dim);
      padding: 7px 16px;
      border-radius: 100px;
      font-size: 11px;
      letter-spacing: .08em;
      color: var(--accent);
      font-family: var(--font-mono);
      margin-bottom: 24px;
    }

    .page-title {
      font-family: var(--font-display);
      font-size: clamp(60px, 9vw, 120px);
      line-height: .9;
      font-weight: 400;
      letter-spacing: -.05em;
      margin-bottom: 20px;
    }

    .page-title span {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
      max-width: 680px;
      margin: auto;
      color: var(--text2);
      font-size: 16px;
      line-height: 1.8;
    }

    /* PRICING GRID */
    .pricing-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 28px;
      max-width: 1300px;
      margin: auto;
      padding: 0 40px 100px;
    }

    /* CARD */
    .pricing-card {
      background: rgba(15, 17, 23, .78);
      backdrop-filter: blur(24px);
      border: 1px solid var(--border);
      border-radius: 32px;
      padding: 40px;
      position: relative;
      overflow: hidden;
      transition: .4s cubic-bezier(.16, 1, .3, 1);
    }

    .pricing-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .pricing-card:hover {
      transform: translateY(-10px);
      border-color: var(--border2);
      box-shadow: 0 20px 60px rgba(124, 106, 247, .18);
    }

    /* POPULAR */
    .pricing-card.popular {
      border: 1px solid rgba(124, 106, 247, .35);
      background: linear-gradient(180deg,
          rgba(124, 106, 247, .08),
          rgba(15, 17, 23, .92));
    }

    .popular-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      background: linear-gradient(135deg, var(--accent), #9c8ef7);
      color: white;
      padding: 8px 16px;
      border-radius: 100px;
      font-size: 11px;
      font-family: var(--font-mono);
      letter-spacing: .08em;
    }

    /* PLAN NAME */
    .plan-name {
      font-size: 30px;
      font-weight: 700;
      margin-bottom: 10px;
    }

    /* PRICE */
    .price {
      font-family: var(--font-display);
      font-size: 74px;
      line-height: 1;
      margin: 18px 0;
      letter-spacing: -.04em;
    }

    .price span {
      font-size: 16px;
      color: var(--text2);
      font-family: var(--font-sans);
    }

    .plan-description {
      color: var(--text2);
      line-height: 1.8;
      margin-bottom: 30px;
    }

    /* FEATURES */
    .features {
      list-style: none;
      margin: 30px 0 40px;
    }

    .features li {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
      color: var(--text2);
      font-size: 15px;
    }

    .features li i {
      color: var(--accent2);
      font-size: 18px;
    }

    /* BUTTONS */
    .btn {
      width: 100%;
      padding: 16px;
      border-radius: 18px;
      border: none;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      transition: .3s;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent), #9c8ef7);
      color: white;
      box-shadow: 0 8px 28px rgba(124, 106, 247, .28);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
    }

    .btn-secondary,
    .btn-disabled {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text2);
    }

    .btn-secondary:hover {
      border-color: var(--border2);
      background: var(--accent-dim);
      color: var(--text);
    }

    /* FOOTER */
    .footer {
      border-top: 1px solid var(--border);
      background: rgba(15, 17, 23, .4);
      backdrop-filter: blur(18px);
    }

    .footer-content {
      max-width: 1300px;
      margin: auto;
      padding: 80px 40px;
    }

    .footer-logo h1 {
      font-size: 38px;
      font-family: var(--font-display);
      font-weight: 400;
    }

    .footer-logo span {
      color: var(--accent);
    }

    .footer-desc {
      color: var(--text2);
      line-height: 1.8;
      margin-top: 18px;
    }

    /* MOBILE */
    @media(max-width:768px) {

      body {
        cursor: auto;
      }

      #cur,
      #cur-ring {
        display: none !important;
      }

      .page-header {
        padding: 120px 20px 60px;
      }

      .page-title {
        font-size: 64px;
      }

      .pricing-container {
        padding: 0 20px 70px;
      }

      .pricing-card {
        padding: 30px;
        border-radius: 28px;
      }

      .price {
        font-size: 58px;
      }
    }
  </style>


</head>

<body>
  <div id="cur"></div>
  <div id="cur-ring"></div>
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>

  <!-- Mobile Menu -->
  <div id="fixediv">
    <button class="close-btn" id="closeMenu">
      <i class="ri-close-line"></i>
    </button>
    <div class="links-fixed">
      <a href="/home">HOME</a>
      <a href="/about">ABOUT</a>
      <a href="/profile">PROFILE</a>
      <a href="/contact">CONTACT</a>
      <a href="/bookings">BOOKINGS</a>
      <a href="/logout">Logout</a>
    </div>
  </div>

  <!-- Navigation -->
  <div id="nav">
    <div class="logo">
      <a href="/home" class="logo-link">
        <h3>Bemy</h3>
        <h3>Bot</h3>
        <h3>In</h3>
      </a>
    </div>
    <div id="navPart2">
      <div id="nav-links">
        <a href="/home">Home</a>
        <a href="/about">About</a>
        <a href="/profile">Profile</a>
        <a href="/bookings">Bookings</a>
        <a href="/logout">Logout</a>
      </div>
      <div id="icon">
        <i id="menuicon" class="ri-menu-line"></i>
        <i class="ri-shopping-cart-2-line"></i>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="content-wrapper">
    <div class="page-header">
      <div class="page-badge"><span></span>Pricing Plans</div>
      <h1 class="page-title">Choose Your<br>Perfect Plan</h1>
      <p class="page-subtitle">Simple, transparent pricing. No hidden fees. Start free and scale as you grow.</p>
    </div>

    <div class="pricing-wrapper">
      <div class="pricing-container">

        <!-- FREE PLAN -->
        <div class="pricing-card">
          <div class="plan-name">Free</div>
          <div class="price">₹0 <span>/ forever</span></div>
          <p class="plan-description">Perfect for trying out NeuroAssist and small projects</p>
          <ul class="features">
            <li><i class="ri-checkbox-circle-fill"></i> 2 Chatbots</li>
            <li><i class="ri-checkbox-circle-fill"></i> Basic AI replies</li>
            <li><i class="ri-checkbox-circle-fill"></i> Website embedding</li>
            <li><i class="ri-checkbox-circle-fill"></i> Community support</li>
          </ul>
          <button class="btn btn-disabled" disabled>
            Current Plan
          </button>
        </div>

        <!-- PRO PLAN -->
        <div class="pricing-card popular">
          <div class="popular-badge">Most Popular</div>
          <div class="plan-name">Pro</div>
          <div class="price">₹499 <span>/ month</span></div>
          <p class="plan-description">Best for growing businesses that need more power</p>
          <ul class="features">
            <li><i class="ri-checkbox-circle-fill"></i> 10 Chatbots</li>
            <li><i class="ri-checkbox-circle-fill"></i> Website AI training</li>
            <li><i class="ri-checkbox-circle-fill"></i> Conversation analytics</li>
            <li><i class="ri-checkbox-circle-fill"></i> Priority support</li>
          </ul>
          <button class="btn btn-primary" onclick="pay(499, 'pro')">
            <span>Upgrade</span>
          </button>
        </div>

        <!-- BUSINESS PLAN -->
        <div class="pricing-card">
          <div class="plan-name">Business</div>
          <div class="price">₹999 <span>/ month</span></div>
          <p class="plan-description">For large teams requiring enterprise-grade features</p>
          <ul class="features">
            <li><i class="ri-checkbox-circle-fill"></i> Unlimited chatbots</li>
            <li><i class="ri-checkbox-circle-fill"></i> Advanced AI responses</li>
            <li><i class="ri-checkbox-circle-fill"></i> Full analytics dashboard</li>
            <li><i class="ri-checkbox-circle-fill"></i> Dedicated account manager</li>
          </ul>
          <button class="btn btn-primary" onclick="pay(999, 'business')">
            <span>Upgrade</span>
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="pg-footer">
    <footer class="footer">
      <div class="footer-content">
        <div class="footer-content-column">
          <div class="footer-logo">
            <h1>Neuro<span>Assist</span></h1>
          </div>
          <p class="footer-desc">The AI platform for building smart chatbots that work for your business around the
            clock.</p>
        </div>

        <div class="footer-content-column">
          <div class="footer-menu">
            <h2 class="footer-menu-name">Get Started</h2>
            <ul class="footer-menu-list">
              <li><a href="/home">Home</a></li>
              <li><a href="#">Documentation</a></li>
              <li><a href="/createbot">Create Bot</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-content-column">
          <div class="footer-menu">
            <h2 class="footer-menu-name">Company</h2>
            <ul class="footer-menu-list">
              <li><a href="/contact">Contact</a></li>
              <li><a href="#">Privacy Policy</a></li>
              <li><a href="#">Terms of Service</a></li>
            </ul>
          </div>
        </div>

        <div class="footer-content-column">
          <div class="footer-call-to-action">
            <h2 class="footer-call-to-action-title">Need Help?</h2>
            <p class="footer-call-to-action-description">Our team is here to assist you.</p>
            <a class="footer-call-to-action-button" href="/contact">Get in Touch</a>
          </div>
        </div>
      </div>

      <div class="footer-copyright">
        <p class="footer-copyright-text">
          © 2025 <a href="/home" class="footer-copyright-link">NeuroAssist Co.</a> All rights reserved.
        </p>
      </div>
    </footer>
  </div>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

  <script>
    // Custom cursor
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', e => {
        mx = e.clientX;
        my = e.clientY;
      });

      (function ani() {
        cur.style.left = mx + 'px';
        cur.style.top = my + 'px';
        rx += (mx - rx) * 0.13;
        ry += (my - ry) * 0.13;
        ring.style.left = rx + 'px';
        ring.style.top = ry + 'px';
        requestAnimationFrame(ani);
      })();
    }

    // Navbar scroll effect
    window.addEventListener('scroll', () => {
      document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
    });

    // Mobile menu
    const menuBtn = document.getElementById('menuicon');
    const closeBtn = document.getElementById('closeMenu');
    const menuDiv = document.getElementById('fixediv');

    menuBtn.addEventListener('click', () => {
      menuDiv.classList.add('open');
    });

    closeBtn.addEventListener('click', () => {
      menuDiv.classList.remove('open');
    });

    menuDiv.addEventListener('click', (e) => {
      if (e.target === menuDiv) {
        menuDiv.classList.remove('open');
      }
    });

    // Scroll reveal animations
    const revealEls = document.querySelectorAll('.page-header, .pricing-wrapper, .pricing-card');
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }, index * 100);
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    revealEls.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      revealObs.observe(el);
    });

    // Payment function
    async function pay(amount, planType = 'pro') {
      try {
        const res = await fetch("/create-order", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ amount })
        });

        const order = await res.json();

        const options = {
          key: "<%= process.env.RAZORPAY_KEY_ID %>",
          amount: order.amount,
          currency: "INR",
          name: "Neuro Assist",
          description: "Subscription Plan",
          order_id: order.id,
          handler: async function (response) {
            await fetch("/verify-payment", {
              method: "POST",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({
                ...response,
                planType: planType
              })
            });

            alert("Payment Successful!");
            location.reload();
          }
        };

        const rzp = new Razorpay(options);
        rzp.open();
      } catch (error) {
        console.error("Payment error:", error);
        alert("Payment failed. Please try again.");
      }
    }
  </script>
</body>

</html>