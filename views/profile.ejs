<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <title>Profile</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Poppins;
        }

        body {
            background: #f6f7fb;
            color: #111;
        }

        /* NAVBAR */

        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 40px;
        }

        nav ul {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        nav ul a {
            text-decoration: none;
            color: black;
            font-weight: 600;
        }

        nav button {
            padding: 8px 14px;
            border: none;
            background: #FF7518;
            color: white;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }

        /* PROFILE CONTAINER */

        .profile-container {
            max-width: 1200px;
            margin: auto;
            padding: 40px 20px;
        }

        /* HEADER */

        .profile-header h1 {
            font-size: 30px;
            margin-bottom: 20px;
        }

        /* STATS */

        .stats {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .stat-box {
            background: white;
            padding: 25px;
            border-radius: 12px;
            min-width: 200px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .stat-box h2 {
            font-size: 28px;
        }

        .stat-box p {
            color: #777;
            font-size: 14px;
            margin-top: 5px;
        }

        /* PLAN CARD */

        .plan-card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .plan-info h3 {
            font-size: 20px;
        }

        .plan-info p {
            color: #666;
            font-size: 14px;
        }

        .upgrade-btn {
            background: black;
            color: white;
            border: none;
            padding: 10px 18px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* BOT GRID */

        .bots-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
        }

        .bot-card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: 0.3s;
        }

        .bot-card:hover {
            transform: translateY(-5px);
        }

        .bot-card h3 {
            margin-bottom: 10px;
        }

        .bot-card p {
            font-size: 14px;
            color: #555;
        }

        .status {
            display: inline-block;
            margin-top: 10px;
            background: #e7f7ee;
            color: #0a8a42;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
        }

        .bot-actions {
            margin-top: 15px;
        }

        .delete-btn {
            background: #ff3b3b;
            border: none;
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* MOBILE */

        @media(max-width:768px) {

            nav ul a {
                display: none;
            }

            .stats {
                flex-direction: column;
            }

            .plan-card {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

        }
    </style>

</head>

<body>

    <nav>

        <div class="logo">
            <h2>Neuro Assist</h2>
        </div>

        <ul>

            <a href="/home">Home</a>

            <button onclick="window.location='/logout'">
                Logout
            </button>

        </ul>

    </nav>


    <div class="profile-container">

        <div class="profile-header">

            <h1>Your Dashboard</h1>

        </div>


        <!-- STATS -->

        <div class="stats">

            <div class="stat-box">
                <h2>
                    <%= bots.length %>
                </h2>
                <p>Total Bots</p>
            </div>

            <div class="stat-box">
                <h2>
                    <%= user.plan %>
                </h2>
                <p>Current Plan</p>
            </div>

            <div class="stat-box">
                <h2>
                    <%= user.botsLimit %>
                </h2>
                <p>Bot Limit</p>
            </div>

        </div>


        <!-- PLAN SECTION -->

        <div class="plan-card">

            <div class="plan-info">

                <h3>Current Plan: <%= user.plan %>
                </h3>

                <p>Upgrade your plan to create more bots and unlock premium features.</p>

            </div>

            <button class="upgrade-btn" onclick="window.location='/pricing'">

                Upgrade Plan

            </button>

        </div>


        <!-- BOT LIST -->

        <h2>Your Bots</h2>

        <div class="bots-grid">

            <% if(bots.length===0){ %>

                <p>No bots created yet.</p>

                <% } %>

                    <% bots.forEach(bot=>{ %>

                        <div class="bot-card">

                            <h3>
                                <%= bot.name %>
                            </h3>

                            <p><strong>Category:</strong>
                                <%= bot.category %>
                            </p>

                            <p><strong>Bot ID:</strong>
                                <%= bot.botId %>
                            </p>

                            <p><strong>Created:</strong>
                                <%= bot.createdAt.toDateString() %>
                            </p>

                            <span class="status">Active</span>

                            <div class="bot-actions">

                                <button class="delete-btn" onclick="deleteBot('<%= bot.botId %>')">

                                    Delete Bot

                                </button>

                            </div>

                        </div>

                        <% }) %>

        </div>

    </div>


    <script>

        async function deleteBot(botId) {

            const confirmDelete = confirm("Delete this bot?")

            if (!confirmDelete) return

            try {

                const res = await fetch("/deletebot/" + botId, {
                    method: "DELETE"
                })

                const data = await res.json()

                if (data.success) {
                    location.reload()
                } else {
                    alert("Failed to delete")
                }

            } catch (err) {

                alert("Server error")

            }

        }

    </script>

</body>

</html>