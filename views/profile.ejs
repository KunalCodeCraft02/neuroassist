<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;500;600&display=swap"
        rel="stylesheet">

    <title>Dashboard</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f8f8f8;
            padding-top: 110px;
            /* FIX FOR NAVBAR OVERLAP */
        }

        /* NAVBAR */

        #nav {
            height: 100px;
            width: 100%;
            background: white;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 99;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        }

        .logo {
            line-height: 1.2;
        }

        .logo h3 {
            font-family: Anton;
            letter-spacing: 3px;
            font-size: 18px;
            font-weight: 400;
        }

        #navPart2 {
            display: flex;
            align-items: center;
            gap: 40px;
        }

        #nav-links {
            display: flex;
            gap: 35px;
        }

        #nav-links a {
            text-decoration: none;
            color: black;
            font-size: 15px;
            text-transform: uppercase;
            font-weight: 500;
        }

        #icon {
            font-size: 22px;
            cursor: pointer;
        }

        /* CONTAINER */

        .profile-container {
            max-width: 1200px;
            margin: auto;
            padding: 20px;
        }

        .profile-header h1 {
            font-size: 32px;
            margin-bottom: 30px;
        }

        /* STATS */

        .stats {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .stat-box {
            background: white;
            padding: 25px;
            border-radius: 12px;
            min-width: 220px;
            flex: 1;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .stat-box h2 {
            font-size: 28px;
        }

        .stat-box p {
            color: #777;
            font-size: 14px;
            margin-top: 6px;
        }

        /* PLAN CARD */

        .plan-card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .plan-info h3 {
            font-size: 20px;
            margin-bottom: 5px;
        }

        .plan-info p {
            font-size: 14px;
            color: #666;
        }

        .upgrade-btn {
            background: black;
            color: white;
            border: none;
            padding: 10px 18px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* BOT GRID */

        .bots-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .bot-card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: 0.3s;
        }

        .bot-card:hover {
            transform: translateY(-5px);
        }

        .bot-card h3 {
            margin-bottom: 10px;
        }

        .bot-card p {
            font-size: 14px;
            color: #555;
            margin: 3px 0;
        }

        .status {
            display: inline-block;
            margin-top: 10px;
            background: #e7f7ee;
            color: #0a8a42;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
        }

        .bot-actions {
            margin-top: 15px;
        }

        .delete-btn {
            background: #ff3b3b;
            border: none;
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            cursor: pointer;
        }

        /* MOBILE */

        @media(max-width:768px) {

            #nav {
                padding: 0 20px;
            }

            #nav-links {
                display: none;
            }

            .profile-header h1 {
                font-size: 26px;
            }

            .stats {
                flex-direction: column;
            }

            .plan-card {
                flex-direction: column;
                align-items: flex-start;
            }

        }
    </style>

</head>

<body>


    <!-- NAVBAR -->

    <div id="nav">

        <div class="logo">
            <h3>Neuro</h3>
            <h3>Assist</h3>
            <h3>Co</h3>
        </div>

        <div id="navPart2">

            <div id="nav-links">
                <a href="#">About</a>
                <a href="/profile">Profile</a>
                <a href="/logout">Logout</a>
            </div>

            <div id="icon">
                <i class="ri-shopping-cart-2-line"></i>
            </div>

        </div>

    </div>


    <!-- DASHBOARD -->

    <div class="profile-container">

        <div class="profile-header">
            <h1>Your Dashboard</h1>
        </div>


        <!-- STATS -->

        <div class="stats">

            <div class="stat-box">
                <h2>
                    <%= bots.length %>
                </h2>
                <p>Total Bots</p>
            </div>

            <div class="stat-box">
                <h2>
                    <%= user.plan %>
                </h2>
                <p>Current Plan</p>
            </div>

            <div class="stat-box">
                <h2>
                    <%= user.botsLimit %>
                </h2>
                <p>Bot Limit</p>
            </div>

        </div>


        <!-- PLAN -->

        <div class="plan-card">

            <div class="plan-info">
                <h3>Current Plan: <%= user.plan %>
                </h3>
                <p>Upgrade your plan to create more bots and unlock premium features.</p>
            </div>

            <button class="upgrade-btn" onclick="window.location='/pricing'">
                Upgrade Plan
            </button>

        </div>


        <!-- BOTS -->

        <h2>Your Bots</h2>

        <div class="bots-grid">

            <% if(bots.length===0){ %>
                <p>No bots created yet.</p>
                <% } %>

                    <% bots.forEach(bot=>{ %>

                        <div class="bot-card">

                            <h3>
                                <%= bot.name %>
                            </h3>

                            <p><strong>Category:</strong>
                                <%= bot.category %>
                            </p>

                            <p><strong>Bot ID:</strong>
                                <%= bot.botId %>
                            </p>

                            <p><strong>Created:</strong>
                                <%= bot.createdAt.toDateString() %>
                            </p>

                            <span class="status">Active</span>

                            <div class="bot-actions">

                                <button class="delete-btn" onclick="deleteBot('<%= bot.botId %>')">
                                    Delete Bot
                                </button>

                            </div>

                        </div>

                        <% }) %>

        </div>

    </div>


    <script>

        async function deleteBot(botId) {

            const confirmDelete = confirm("Delete this bot?")

            if (!confirmDelete) return

            try {

                const res = await fetch("/deletebot/" + botId, { method: "DELETE" })
                const data = await res.json()

                if (data.success) {
                    location.reload()
                } else {
                    alert("Failed to delete")
                }

            } catch (err) {

                alert("Server error")

            }

        }

    </script>

</body>

</html>