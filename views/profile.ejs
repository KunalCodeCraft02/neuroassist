
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BemyBot — Profile Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />

  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400&display=swap"
    rel="stylesheet" />

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0a0c10;
      --surface: #0f1117;
      --surface2: #14161e;
      --surface3: #1a1d28;
      --accent: #7c6af7;
      --accent2: #5bf0c0;
      --accent-dim: rgba(124, 106, 247, 0.14);
      --text: #e8eaf0;
      --text2: #9da3b8;
      --muted: #4a5070;
      --border: rgba(255, 255, 255, 0.06);
      --border2: rgba(124, 106, 247, 0.2);
      --radius: 18px;
      --font-display: 'Instrument Serif', serif;
      --font-sans: 'Outfit', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      overflow-x: hidden;
      cursor: none;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: -1;
      opacity: .5;
    }

    #cur {
      position: fixed;
      width: 8px;
      height: 8px;
      background: var(--accent);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99999;
      transform: translate(-50%, -50%);
      transition: width .25s, height .25s, background .25s;
      mix-blend-mode: screen;
    }

    #cur-ring {
      position: fixed;
      width: 34px;
      height: 34px;
      border: 1px solid rgba(124, 106, 247, 0.4);
      border-radius: 50%;
      pointer-events: none;
      z-index: 99998;
      transform: translate(-50%, -50%);
      transition: transform .12s ease-out;
    }

    body:has(a:hover) #cur,
    body:has(button:hover) #cur {
      width: 14px;
      height: 14px;
      background: var(--accent2);
    }

    .mesh-bg {
      position: fixed;
      inset: 0;
      overflow: hidden;
      z-index: -2;
      pointer-events: none;
    }

    .mesh-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
    }

    .mesh-blob-1 {
      width: 600px;
      height: 600px;
      top: -200px;
      right: -120px;
      background: radial-gradient(circle, rgba(124, 106, 247, .12) 0%, transparent 70%);
      animation: floatA 12s ease-in-out infinite alternate;
    }

    .mesh-blob-2 {
      width: 450px;
      height: 450px;
      bottom: -120px;
      left: -100px;
      background: radial-gradient(circle, rgba(91, 240, 192, .08) 0%, transparent 70%);
      animation: floatB 15s ease-in-out infinite alternate;
    }

    @keyframes floatA {
      from {
        transform: translate(0, 0);
      }

      to {
        transform: translate(-40px, 50px);
      }
    }

    @keyframes floatB {
      from {
        transform: translate(0, 0);
      }

      to {
        transform: translate(40px, -40px);
      }
    }

    .grid-bg {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, .025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, .025) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 30%, transparent 100%);
      pointer-events: none;
      z-index: -1;
    }

    #fixediv {
      position: fixed;
      top: -110%;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(10, 12, 16, 0.98);
      backdrop-filter: blur(24px);
      z-index: 100000;
      transition: top .5s cubic-bezier(.16, 1, .3, 1);
      border-bottom: 1px solid var(--border2);
    }

    #fixediv.open {
      top: 0;
    }

    .links-fixed {
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 24px;
    }

    .links-fixed a {
      text-decoration: none;
      color: var(--text2);
      font-size: 40px;
      font-family: var(--font-display);
      font-style: italic;
      transition: .3s;
    }

    .links-fixed a:hover {
      color: var(--accent);
    }

    .close-btn {
      position: absolute;
      top: 24px;
      right: 24px;
      border: none;
      background: transparent;
      color: var(--text2);
      font-size: 24px;
      cursor: pointer;
    }

    #nav {
      height: 72px;
      width: 100%;
      position: fixed;
      top: 0;
      z-index: 1000;
      padding: 0 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid transparent;
      transition: .4s;
    }

    #nav.scrolled {
      background: rgba(10, 12, 16, .88);
      backdrop-filter: blur(24px);
      border-color: var(--border);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logo-mark {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 12px;
      color: #000;
    }

    .logo-text {
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
    }

    .logo-text span {
      color: var(--accent);
    }

    #navPart2 {
      display: flex;
      align-items: center;
      gap: 28px;
    }

    #nav-links {
      display: flex;
      gap: 24px;
    }

    #nav-links a {
      text-decoration: none;
      color: var(--text2);
      font-size: 13px;
      transition: .3s;
    }

    #nav-links a:hover {
      color: var(--text);
    }

    #icon {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    #icon i {
      color: var(--muted);
      font-size: 18px;
      transition: .3s;
    }

    #icon i:hover {
      color: var(--text);
    }

    #menuicon {
      display: none;
    }

    .main {
      position: relative;
      z-index: 2;
      padding: 140px 48px 80px;
    }

    .hero-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 30px;
      margin-bottom: 50px;
      flex-wrap: wrap;
    }

    .hero-title h1 {
      font-family: var(--font-display);
      font-size: clamp(54px, 8vw, 96px);
      line-height: .9;
      font-weight: 400;
      letter-spacing: -.03em;
    }

    .hero-title h1 span {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-title p {
      margin-top: 20px;
      color: var(--text2);
      max-width: 500px;
      line-height: 1.8;
      font-size: 15px;
    }

    .edit-btn {
      background: linear-gradient(135deg, var(--accent), #9c8ef7);
      color: white;
      text-decoration: none;
      padding: 14px 24px;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 600;
      box-shadow: 0 4px 24px rgba(124, 106, 247, .35);
      transition: .3s;
    }

    .edit-btn:hover {
      transform: translateY(-3px);
    }

    .profile-card {
      background: rgba(15, 17, 23, .8);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
      margin-bottom: 40px;
      overflow: hidden;
      position: relative;
    }

    .profile-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .profile-left {
      display: flex;
      align-items: center;
      gap: 28px;
      flex-wrap: wrap;
    }

    .profile-dp {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid rgba(124, 106, 247, .3);
      box-shadow: 0 0 40px rgba(124, 106, 247, .2);
      flex-shrink: 0;
    }

    .profile-dp img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .profile-info h2 {
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 700;
      margin-bottom: 8px;
    }

    .role {
      color: var(--accent2);
      font-size: 14px;
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 12px;
      font-family: var(--font-mono);
    }

    .bio {
      color: var(--text2);
      max-width: 600px;
      line-height: 1.8;
      font-size: 14px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 50px;
    }

    .stat-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 30px;
      position: relative;
      overflow: hidden;
      transition: .3s;
    }

    .stat-box:hover {
      transform: translateY(-5px);
      background: var(--surface2);
      border-color: var(--border2);
    }

    .stat-box::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      opacity: 0;
      transition: .3s;
    }

    .stat-box:hover::before {
      opacity: 1;
    }

    .stat-icon {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      background: var(--accent-dim);
      border: 1px solid var(--border2);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }

    .stat-icon i {
      color: var(--accent);
      font-size: 22px;
    }

    .stat-box h2 {
      font-size: 42px;
      margin-bottom: 8px;
      font-weight: 700;
    }

    .stat-box p {
      color: var(--text2);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .08em;
      font-family: var(--font-mono);
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(34px, 4vw, 52px);
      margin-bottom: 24px;
      font-weight: 400;
      letter-spacing: -.02em;
    }

    .section-title span {
      color: var(--accent);
      font-style: italic;
    }

    .graph-card,
    .table-box,
    .bot-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      overflow: hidden;
      position: relative;
    }

    .graph-card {
      padding: 30px;
      margin-bottom: 50px;
    }

    .graph-card::before,
    .table-box::before,
    .bot-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .graph-card h2 {
      margin-bottom: 24px;
      font-size: 28px;
    }

    .table-box {
      margin-bottom: 50px;
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 650px;
    }

    thead {
      background: var(--surface2);
    }

    thead th {
      padding: 18px;
      text-align: left;
      color: var(--text);
      font-size: 12px;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-family: var(--font-mono);
      border-bottom: 1px solid var(--border);
    }

    tbody tr {
      border-bottom: 1px solid var(--border);
      transition: .25s;
    }

    tbody tr:hover {
      background: var(--surface2);
    }

    tbody td {
      padding: 18px;
      color: var(--text2);
      font-size: 14px;
    }

    .bots-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 20px;
    }

    .bot-card {
      padding: 28px;
      transition: .3s;
    }

    .bot-card:hover {
      transform: translateY(-5px);
      background: var(--surface2);
      border-color: var(--border2);
    }

    .bot-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 20px;
    }

    .bot-top h3 {
      font-size: 24px;
      margin-bottom: 10px;
    }

    .bot-badge {
      padding: 8px 14px;
      border-radius: 100px;
      background: var(--accent-dim);
      border: 1px solid var(--border2);
      color: var(--accent);
      font-size: 11px;
      font-family: var(--font-mono);
      white-space: nowrap;
    }

    .bot-card p {
      color: var(--text2);
      margin-bottom: 10px;
      line-height: 1.7;
      font-size: 14px;
    }

    .delete-btn {
      margin-top: 18px;
      border: 1px solid rgba(255, 80, 80, .2);
      background: rgba(255, 80, 80, .08);
      color: #ff7a7a;
      padding: 12px 18px;
      border-radius: 12px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: .3s;
    }

    .delete-btn:hover {
      background: #ff4d4d;
      color: white;
      transform: translateY(-2px);
    }

    @media(max-width:768px) {
      body {
        cursor: auto;
      }

      #cur,
      #cur-ring {
        display: none;
      }

      #nav {
        padding: 0 20px;
      }

      #nav-links {
        display: none;
      }

      #menuicon {
        display: block;
      }

      .main {
        padding: 120px 20px 60px;
      }

      .profile-card {
        padding: 28px;
      }

      .profile-left {
        flex-direction: column;
        align-items: flex-start;
      }

      .profile-info h2 {
        font-size: 32px;
      }
    }
  </style>
</head>

<body>

  <div id="cur"></div>
  <div id="cur-ring"></div>

  <div class="mesh-bg">
    <div class="mesh-blob mesh-blob-1"></div>
    <div class="mesh-blob mesh-blob-2"></div>
  </div>

  <div class="grid-bg"></div>

  <!-- MOBILE MENU -->
  <div id="fixediv">
    <button class="close-btn" id="closeMenu">
      <i class="ri-close-line"></i>
    </button>

    <div class="links-fixed">
      <a href="/home">Home</a>
      <a href="/about">About</a>
      <!-- <a href="/chat">Community</a> -->
      <a href="/profile">Profile</a>
      <a href="/bookings">Bookings</a>
      <a href="/logout">Logout</a>
    </div>
  </div>

  <!-- NAV -->
  <div id="nav">
    <div class="logo">
      <div class="logo-mark">B/</div>
      <div class="logo-text">Bemy<span>Bot</span></div>
    </div>

    <div id="navPart2">
      <div id="nav-links">
        <a href="/home">Home</a>
        <a href="/about">About</a>
        <!-- <a href="/chat">Community</a> -->
        <a href="/pricing">Pricing</a>
        <a href="/profile">Profile</a>
        <a href="/leads">Leads</a>
        <a href="/bookings">Bookings</a>
        <a href="/logout">Logout</a>
      </div>

      <div id="icon">
        <i id="menuicon" class="ri-menu-line"></i>
        <i class="ri-shopping-cart-2-line"></i>
      </div>
    </div>
  </div>

  <main class="main">

    <!-- HERO -->
    <div class="hero-head">
      <div class="hero-title">
        <h1>Your <span>Dashboard</span></h1>
        <p>
          Manage your AI bots, bookings, leads and performance analytics from one modern dashboard.
        </p>
      </div>

      <a href="/edit-profile" class="edit-btn">
        <i class="ri-edit-line"></i>
        Edit Profile
      </a>
    </div>

    <!-- PROFILE CARD -->
    <div class="profile-card">
      <div class="profile-left">

        <div class="profile-dp">
          <img
            src="<%= user.photo ? user.photo : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name || 'User') + '&background=7c6af7&color=fff&size=256' %>"
            alt="profile"
            onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=User&background=7c6af7&color=fff&size=256';">
        </div>

        <div class="profile-info">
          <h2><%= user.name %></h2>
          <p class="role"><%= user.role || 'Add your role' %></p>
          <p class="bio"><%= user.bio || 'Tell people about yourself...' %></p>
        </div>
      </div>
    </div>

    <!-- STATS -->
    <div class="stats-grid">

      <div class="stat-box">
        <div class="stat-icon">
          <i class="ri-robot-2-line"></i>
        </div>
        <h2><%= bots.length %></h2>
        <p>Total Bots</p>
      </div>

      <div class="stat-box">
        <div class="stat-icon">
          <i class="ri-calendar-check-line"></i>
        </div>
        <h2><%= bookings.length %></h2>
        <p>Total Bookings</p>
      </div>

      <div class="stat-box">
        <div class="stat-icon">
          <i class="ri-fire-line"></i>
        </div>
        <h2><%= leadStats.hotLeads || 0 %></h2>
        <p>Hot Leads</p>
      </div>

      <div class="stat-box">
        <div class="stat-icon">
          <i class="ri-line-chart-line"></i>
        </div>
        <h2><%= leadStats.avgScore || 0 %>/100</h2>
        <p>Average Score</p>
      </div>

    </div>

    <!-- GRAPH -->
    <div class="graph-card">
      <h2>Analytics Overview</h2>
      <canvas id="bookingChart"></canvas>
    </div>

    <!-- BOOKINGS -->
    <h2 class="section-title">Recent <span>Bookings</span></h2>

    <div class="table-box">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Date</th>
            <th>Time</th>
          </tr>
        </thead>

        <tbody>
          <% if(bookings.length> 0){ %>
            <% bookings.forEach((booking)=> { %>
              <tr>
                <td><%= booking.name %></td>
                <td><%= booking.email %></td>
                <td><%= booking.date %></td>
                <td><%= booking.time %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4">No bookings found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- BOTS -->
    <h2 class="section-title">Your <span>AI Bots</span></h2>

    <div class="bots-grid">

      <% if(bots.length> 0){ %>
        <% bots.forEach((bot)=> { %>

          <div class="bot-card">

            <div class="bot-top">
              <div>
                <h3><%= bot.botName %></h3>
                <p><%= bot.category || 'AI Assistant' %></p>
              </div>

              <div class="bot-badge">
                ACTIVE
              </div>
            </div>

            <p><strong>Description:</strong> <%= bot.description || 'No description added' %></p>
            <p><strong>Voice:</strong> <%= bot.voice || 'Default' %></p>
            <p><strong>Language:</strong> <%= bot.language || 'English' %></p>

            <form action="/delete-bot/<%= bot._id %>" method="POST">
              <button type="submit" class="delete-btn">
                <i class="ri-delete-bin-line"></i>
                Delete Bot
              </button>
            </form>

          </div>

        <% }) %>
      <% } else { %>
        <div class="bot-card">
          <h3>No Bots Yet</h3>
          <p>Create your first AI bot to get started.</p>
        </div>
      <% } %>

    </div>

  </main>

  <script>

    // NAV SCROLL
    const nav = document.getElementById('nav');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 30) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });

    // MENU
    const menuicon = document.getElementById('menuicon');
    const fixediv = document.getElementById('fixediv');
    const closeMenu = document.getElementById('closeMenu');

    menuicon.addEventListener('click', () => {
      fixediv.classList.add('open');
    });

    closeMenu.addEventListener('click', () => {
      fixediv.classList.remove('open');
    });

    // CURSOR
    const cur = document.getElementById('cur');
    const ring = document.getElementById('cur-ring');

    window.addEventListener('mousemove', (e) => {
      cur.style.left = e.clientX + 'px';
      cur.style.top = e.clientY + 'px';

      ring.style.left = e.clientX + 'px';
      ring.style.top = e.clientY + 'px';
    });

    // CHART
    const ctx = document.getElementById('bookingChart');

    if (ctx) {
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
          datasets: [{
            label: 'Bookings',
            data: [4, 8, 6, 12, 10, 14, 9],
            borderColor: '#7c6af7',
            backgroundColor: 'rgba(124,106,247,.12)',
            tension: .4,
            fill: true
          }]
