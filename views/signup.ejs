<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SAME FONTS AS HOME -->
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">

    <title>Create Account</title>
    <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ROOT (MATCH HOME) */
        :root {
            --bg: #04040a;
            --surface: #09090f;
            --accent: #ff7518;
            --text: #eeeef5;
            --muted: #5a5a78;
            --border: rgba(255, 255, 255, 0.07);
            --radius: 16px;
        }

        /* BODY */
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* CARD */
        .container {
            width: 100%;
            max-width: 420px;
            background: var(--surface);
            padding: 40px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
        }

        /* LOGO */
        .logo {
            margin-bottom: 20px;
        }

        .logo img {
            width: 70px;
            border-radius: 50%;
        }

        /* TITLE */
        h2 {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            margin-bottom: 25px;
        }

        /* LABEL */
        label {
            font-size: 12px;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 15px;
            margin-bottom: 6px;
            display: block;
        }

        /* INPUT */
        input {
            width: 100%;
            padding: 13px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: #0e0e18;
            color: var(--text);
            outline: none;
            font-size: 14px;
            transition: .3s;
        }

        input:focus {
            border-color: var(--accent);
        }

        /* BUTTON */
        button {
            margin-top: 15px;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: var(--accent);
            color: #04040a;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            cursor: pointer;
            transition: .3s;
        }

        button:hover {
            background: #ff8c3d;
            transform: translateY(-2px);
        }

        /* SECOND BUTTON (LOCATION) */
        button[type="button"] {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--muted);
        }

        button[type="button"]:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        /* TEXT */
        .bottomText {
            margin-top: 20px;
            font-size: 13px;
            text-align: center;
            color: var(--muted);
        }

        .bottomText a {
            color: var(--accent);
            text-decoration: none;
        }

        /* TOAST (UNCHANGED STRUCTURE) */
        #toast {
            position: fixed;
            top: 30px;
            right: 30px;
        }

        .toast {
            background: var(--surface);
            color: var(--text);
            padding: 14px 20px;
            border-radius: 8px;
            margin-top: 10px;
            font-size: 14px;
            border: 1px solid var(--border);
            opacity: 0;
            transform: translateY(-20px);
            transition: .3s;
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast.error {
            background: #ff3b3b;
        }
    </style>

</head>

<body>

    <div class="container">

        <div class="logo">
            <img src="/assets/image/Neuro Assist.png" alt="Neuro Assist">
        </div>

        <h2>Create your account</h2>

        <form id="signupForm">

            <label>Full Name</label>
            <input id="name" type="text" placeholder="John Doe">

            <label>Email</label>
            <input id="email" type="email" placeholder="you@example.com">

            <label>Company</label>
            <input name="companyname" id="company" type="text" placeholder="Your Company">

            <label>Password</label>
            <input id="password" type="password" placeholder="Create password">

            <!-- SAME BUTTON -->
            <button type="button" onclick="getLocation()">Get My Location 📍</button>

            <!-- SAME INPUTS -->
            <input type="text" name="state" id="state" placeholder="State" readonly>
            <input type="text" name="district" id="district" placeholder="District" readonly>

            <!-- SAME SUBMIT -->
            <button type="submit">Create Account</button>

        </form>

        <div class="bottomText">
            Already have an account? <a href="/login">Sign in</a>
        </div>

    </div>

    <div id="toast"></div>
    <script>

        const form = document.getElementById("signupForm")

        form.addEventListener("submit", async function (e) {

            e.preventDefault()

            const name = document.getElementById("name").value.trim()
            const email = document.getElementById("email").value.trim()
            const password = document.getElementById("password").value.trim()
            const companyname = document.getElementById("company").value.trim()
            const state = document.getElementById("state").value.trim()
            const district = document.getElementById("district").value.trim()

            if (!name || !email || !password || !companyname) {
                showToast("Please fill all required fields (name, email, password, company)", "error")
                return
            }

            if (!state || !district) {
                showToast("Please get your location first (required)", "error")
                return
            }

            // Get CSRF token from meta tag
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || ''

            try {

                const res = await fetch("/signup", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ name, email, password, companyname, state, district, _csrf: csrfToken })
                })

                const result = await res.json()

                if (result.success) {

                    showToast(result.message, "success")

                    setTimeout(() => {
                        window.location = result.redirect
                    }, 1200)

                } else {

                    showToast(result.message, "error")

                }

            } catch (err) {

                console.error("Signup error:", err)
                showToast("Server error - please try again", "error")

            }

        })

        function showToast(message, type) {

            const toastContainer = document.getElementById("toast")

            const toast = document.createElement("div")

            toast.classList.add("toast", type)

            toast.innerText = message

            toastContainer.appendChild(toast)

            setTimeout(() => toast.classList.add("show"), 100)

            setTimeout(() => toast.remove(), 3000)

        }

        function getLocation() {
            if (!navigator.geolocation) {
                showToast("Geolocation is not supported by your browser", "error");
                return;
            }

            showToast("Getting location...", "success");

            navigator.geolocation.getCurrentPosition(
                async (pos) => {
                    try {
                        const lat = pos.coords.latitude;
                        const lon = pos.coords.longitude;

                        // 🔥 Reverse geocoding (free API)
                        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&addressdetails=1`);
                        const data = await res.json();

                        const state = data.address.state || data.address.province || "";
                        const district = data.address.county || data.address.city || data.address.town || data.address.village || "";

                        if (state && district) {
                            document.getElementById("state").value = state;
                            document.getElementById("district").value = district;
                            showToast("Location captured successfully!", "success");
                        } else {
                            showToast("Could not determine state and district from location", "error");
                        }
                    } catch (err) {
                        console.error("Geocoding error:", err);
                        showToast("Failed to get location details. Please enter manually.", "error");
                    }
                },
                (err) => {
                    console.error("Geolocation error:", err);
                    let msg = "Failed to get location";
                    if (err.code === 1) {
                        msg = "Location access denied. Please enable location permission or enter manually.";
                    }
                    showToast(msg, "error");
                },
                {
                    enableHighAccuracy: true,
                    timeout: 10000,
                    maximumAge: 0
                }
            );
        }

    </script>


</body>

</html>