<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SAME FONTS AS HOME -->
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">

    <title>Create Account</title>
    <meta name="csrf-token" content="<%= csrfToken ? csrfToken() : '' %>">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ROOT (MATCH HOME) */
        :root {
            --bg: #04040a;
            --surface: #09090f;
            --accent: #ff7518;
            --text: #eeeef5;
            --muted: #5a5a78;
            --border: rgba(255, 255, 255, 0.07);
            --radius: 16px;
        }

        /* BODY */
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* CARD */
        .container {
            width: 100%;
            max-width: 420px;
            background: var(--surface);
            padding: 40px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
        }

        /* LOGO */
        .logo {
            margin-bottom: 20px;
        }

        .logo img {
            width: 70px;
            border-radius: 50%;
        }

        /* TITLE */
        h2 {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            margin-bottom: 25px;
        }

        /* LABEL */
        label {
            font-size: 12px;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 15px;
            margin-bottom: 6px;
            display: block;
        }

        /* INPUT */
        input {
            width: 100%;
            padding: 13px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: #0e0e18;
            color: var(--text);
            outline: none;
            font-size: 14px;
            transition: .3s;
        }

        input:focus {
            border-color: var(--accent);
        }

        /* BUTTON */
        button {
            margin-top: 15px;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: var(--accent);
            color: #04040a;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            cursor: pointer;
            transition: .3s;
        }

        button:hover {
            background: #ff8c3d;
            transform: translateY(-2px);
        }

        /* SECOND BUTTON (LOCATION) */
        button[type="button"] {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--muted);
        }

        button[type="button"]:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        /* TEXT */
        .bottomText {
            margin-top: 20px;
            font-size: 13px;
            text-align: center;
            color: var(--muted);
        }

        .bottomText a {
            color: var(--accent);
            text-decoration: none;
        }

        /* TOAST (UNCHANGED STRUCTURE) */
        #toast {
            position: fixed;
            top: 30px;
            right: 30px;
        }

        .toast {
            background: var(--surface);
            color: var(--text);
            padding: 14px 20px;
            border-radius: 8px;
            margin-top: 10px;
            font-size: 14px;
            border: 1px solid var(--border);
            opacity: 0;
            transform: translateY(-20px);
            transition: .3s;
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast.error {
            background: #ff3b3b;
        }
    </style>

</head>

<body>

    <div class="container">

        <div class="logo">
            <img src="/assets/image/Neuro Assist.png" alt="Neuro Assist">
        </div>

        <h2>Create your account</h2>

        <form id="signupForm">

            <label>Full Name</label>
            <input id="name" type="text" placeholder="John Doe">

            <label>Email</label>
            <input id="email" type="email" placeholder="you@example.com">

            <label>Company</label>
            <input name="companyname" id="company" type="text" placeholder="Your Company">

            <label>Password</label>
            <input id="password" type="password" placeholder="Create password">

            <!-- SAME BUTTON -->
            <button type="button" onclick="getLocation()">Get My Location 📍</button>

            <!-- SAME INPUTS -->
            <input type="text" name="state" id="state" placeholder="State" readonly>
            <input type="text" name="district" id="district" placeholder="District" readonly>

            <!-- SAME SUBMIT -->
            <button type="submit">Create Account</button>

        </form>

        <div class="bottomText">
            Already have an account? <a href="/login">Sign in</a>
        </div>

    </div>

    <div id="toast"></div>
    <script>

        const form = document.getElementById("signupForm")
        const locationBtn = document.querySelector('button[onclick="getLocation()"]')
        const stateInput = document.getElementById("state")
        const districtInput = document.getElementById("district")

        // Add visual feedback to location button
        if (locationBtn) {
            // Replace inline onclick with event listener for better control
            locationBtn.removeAttribute('onclick');
            locationBtn.type = 'button'; // Ensure it's a button, not submit

            locationBtn.addEventListener('click', async function(e) {
                e.preventDefault();
                console.log("📍 Get Location button clicked");

                // Add loading state
                const originalText = this.innerText;
                this.innerText = "Getting location...";
                this.disabled = true;
                this.style.opacity = "0.7";
                this.style.cursor = "not-allowed";

                try {
                    await getLocation();
                } finally {
                    // Restore button state
                    this.innerText = originalText;
                    this.disabled = false;
                    this.style.opacity = "1";
                    this.style.cursor = "pointer";
                }
            });
        }

        form.addEventListener("submit", async function (e) {

            e.preventDefault()

            const name = document.getElementById("name").value.trim()
            const email = document.getElementById("email").value.trim()
            const password = document.getElementById("password").value.trim()
            const companyname = document.getElementById("company").value.trim()
            const state = document.getElementById("state").value.trim()
            const district = document.getElementById("district").value.trim()

            if (!name || !email || !password || !companyname) {
                showToast("Please fill all required fields (name, email, password, company)", "error")
                return
            }

            if (!state || !district) {
                showToast("Please get your location first (required)", "error")
                return
            }

            // Get CSRF token from meta tag
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || ''

            try {

                const res = await fetch("/signup", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ name, email, password, companyname, state, district, _csrf: csrfToken })
                })

                const result = await res.json()

                if (result.success) {

                    showToast(result.message, "success")

                    setTimeout(() => {
                        window.location = result.redirect
                    }, 1200)

                } else {

                    showToast(result.message, "error")

                }

            } catch (err) {

                console.error("Signup error:", err)
                showToast("Server error - please try again", "error")

            }

        })

        function showToast(message, type) {

            console.log(`🍞 Toast: [${type}] ${message}`);

            const toastContainer = document.getElementById("toast")

            // Remove existing toasts to prevent buildup
            const existingToasts = toastContainer.querySelectorAll('.toast');
            existingToasts.forEach(t => t.remove());

            const toast = document.createElement("div")

            toast.classList.add("toast", type)

            toast.innerText = message

            toastContainer.appendChild(toast)

            setTimeout(() => toast.classList.add("show"), 100)

            setTimeout(() => toast.remove(), 3000)

        }

        async function getLocation() {
            console.log("=== getLocation() called ===");

            if (!navigator.geolocation) {
                console.error("❌ Geolocation not supported");
                showToast("Geolocation is not supported by your browser. Please enter location manually.", "error");
                return;
            }

            showToast("Requesting location permission...", "success");
            console.log("📍 Requesting geolocation...");

            try {
                // Use Promise wrapper for better error handling
                const pos = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(
                        resolve,
                        reject,
                        {
                            enableHighAccuracy: true,
                            timeout: 15000, // 15 seconds
                            maximumAge: 0
                        }
                    );
                });

                const lat = pos.coords.latitude;
                const lon = pos.coords.longitude;
                console.log(`✅ Got coordinates: ${lat}, ${lon}`);

                showToast("Location obtained! Fetching address...", "success");
                console.log("🔍 Fetching address from OpenStreetMap...");

                // Add User-Agent header as required by OSM
                const res = await fetch(
                    `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&addressdetails=1`,
                    {
                        headers: {
                            'User-Agent': 'NeuroAssist-App/1.0 (contact@neuroassist.com)',
                            'Accept-Language': 'en'
                        }
                    }
                );

                if (!res.ok) {
                    throw new Error(`OpenStreetMap API responded with status ${res.status}: ${res.statusText}`);
                }

                const data = await res.json();
                console.log("✅ OpenStreetMap response:", data);

                const state = data.address.state || data.address.province || data.address.region || "";
                const district = data.address.district || data.address.county || data.address.city || data.address.town || data.address.village || "";

                if (state && district) {
                    console.log(`✅ Extracted: State="${state}", District="${district}"`);
                    stateInput.value = state;
                    districtInput.value = district;
                    showToast(`Location captured: ${district}, ${state}`, "success");
                } else {
                    console.warn("⚠️ Could not extract state/district from response. Full address:", data.address);

                    // Try to extract any location info
                    const locationParts = [];
                    if (data.address.state || data.address.province) {
                        locationParts.push(data.address.state || data.address.province);
                        stateInput.value = data.address.state || data.address.province;
                    }
                    if (data.address.county || data.address.city || data.address.town || data.address.village) {
                        locationParts.push(
                            data.address.county ||
                            data.address.city ||
                            data.address.town ||
                            data.address.village
                        );
                        districtInput.value =
                            data.address.county ||
                            data.address.city ||
                            data.address.town ||
                            data.address.village || "";
                    }

                    if (stateInput.value && districtInput.value) {
                        showToast("Location partially filled. Please verify and complete if needed.", "success");
                    } else {
                        showToast("Could not determine complete location. Please enter state and district manually.", "error");
                    }
                }

            } catch (err) {
                console.error("❌ Location error:", err);

                let errorMessage = "Failed to get location details. Please enter manually.";

                if (err.code === 1) {
                    errorMessage = "Location access denied. Please enable location permission in browser settings and try again.";
                } else if (err.code === 2) {
                    errorMessage = "Location unavailable. Please check your GPS/network connection and try again.";
                } else if (err.code === 3) {
                    errorMessage = "Location request timed out. Please try again or enter manually.";
                } else if (err.message.includes('OpenStreetMap') || err.message.includes('Failed to fetch')) {
                    errorMessage = "Location service temporarily unavailable. Please enter state and district manually.";
                }

                showToast(errorMessage, "error");
            }
        }

        // Debug: Check if geolocation is available on page load
        console.log("🌍 Geolocation available:", !!navigator.geolocation);
        console.log("🔒 Page protocol:", window.location.protocol);
        console.log("📍 Location button found:", !!locationBtn);

    </script>


</body>

</html>