<body>

    <div id="cur"></div>
    <div id="cur-ring"></div>

    <div class="mesh-bg">
        <div class="mesh-blob mesh-blob-1"></div>
        <div class="mesh-blob mesh-blob-2"></div>
    </div>

    <div class="grid-bg"></div>


    <div class="container">

        <div class="hero-badge">
            <div class="badge-dot"></div>
            SECURE VERIFICATION
        </div>

        <div class="otp-icon">
            <i class="ri-shield-check-line"></i>
        </div>

        <h1>Verify <span>OTP</span></h1>

        <p id="messageText">
            Enter the verification code sent to your email address to continue your secure login.
        </p>

        <form id="otpForm">

            <div class="input-wrap">
                <i class="ri-key-2-line"></i>
                <input type="text" name="otp" placeholder="000000" maxlength="6" required>
            </div>

            <button type="submit">
                Verify Code
            </button>

        </form>

        <div class="message">
            Your OTP expires in a few minutes for security reasons.
        </div>

    </div>


    <script>

        // CURSOR
        const cur = document.getElementById('cur');
        const ring = document.getElementById('cur-ring');

        window.addEventListener('mousemove', (e) => {
            cur.style.left = e.clientX + 'px';
            cur.style.top = e.clientY + 'px';

            ring.style.left = e.clientX + 'px';
            ring.style.top = e.clientY + 'px';
        });


        document.getElementById("otpForm").addEventListener("submit", async function (e) {

            e.preventDefault()

            const otp = this.otp.value

            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || ''

            const res = await fetch("/verify-otp", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    otp,
                    _csrf: csrfToken
                })
            })

            const data = await res.json()

            if (data.success) {

                document.getElementById("messageText").innerText = "Verification successful. Redirecting..."
                document.getElementById("messageText").style.color = "#5bf0c0"

                setTimeout(() => {
                    window.location = data.redirect
                }, 800)

            } else {

                document.getElementById("messageText").innerText = data.message
                document.getElementById("messageText").style.color = "#ff7a7a"

            }

        })

    </script>

</body>

</html>
